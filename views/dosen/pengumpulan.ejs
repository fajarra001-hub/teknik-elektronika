<%- include('../partials/header') %>

<style>
  .pengumpulan-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .pengumpulan-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .btn-action {
    margin: 2px;
    border-radius: 8px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
  }
  .info-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .modal-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
</style>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Pengumpulan Tugas: <%= tugas.judul %></h2>
    <a href="/dosen/tugas" class="btn btn-outline-secondary btn-action">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <!-- Info Tugas -->
  <div class="info-card row g-4">
    <div class="col-md-4">
      <p><strong>Mata Kuliah:</strong> <%= mk.kode %> - <%= mk.nama %></p>
    </div>
    <div class="col-md-4">
      <p><strong>Deadline:</strong> <%= new Date(tugas.deadline).toLocaleString('id-ID') %></p>
    </div>
    <div class="col-md-4">
      <p><strong>Tipe:</strong> <span class="badge bg-primary"><%= tugas.tipe %></span></p>
    </div>
  </div>

  <!-- Statistik -->
  <div class="row g-4 mb-4">
    <div class="col-md-3">
      <div class="card stat-card">
        <div class="card-body text-center">
          <h5 class="text-muted">Total Mahasiswa</h5>
          <h3><%= mahasiswaList.length %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card stat-card">
        <div class="card-body text-center">
          <h5 class="text-muted">Sudah Mengumpul</h5>
          <h3><%= mahasiswaList.filter(m => m.pengumpulan).length %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card stat-card">
        <div class="card-body text-center">
          <h5 class="text-muted">Belum Mengumpul</h5>
          <h3><%= mahasiswaList.filter(m => !m.pengumpulan).length %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card stat-card">
        <div class="card-body text-center">
          <h5 class="text-muted">Sudah Dinilai</h5>
          <h3><%= mahasiswaList.filter(m => m.pengumpulan && m.pengumpulan.nilai !== null).length %></h3>
        </div>
      </div>
    </div>
  </div>

  <!-- Tabel Pengumpulan -->
  <div class="table-responsive">
    <table class="table pengumpulan-table">
      <thead>
        <tr>
          <th>No</th>
          <th>NIM</th>
          <th>Nama</th>
          <th>File Jawaban</th>
          <th>Tanggal Kumpul</th>
          <th>Nilai</th>
          <th>Komentar</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% mahasiswaList.forEach((m, index) => { %>
          <tr>
            <td><%= index + 1 %></td>
            <td><%= m.nim %></td>
            <td><%= m.nama %></td>
            <td>
              <% if (m.pengumpulan) { %>
                <a href="<%= m.pengumpulan.fileUrl %>" target="_blank" class="btn btn-sm btn-outline-info btn-action">
                  <i class="bi bi-file-earmark-pdf"></i> Lihat
                </a>
              <% } else { %>
                <span class="badge bg-warning">Belum</span>
              <% } %>
            </td>
            <td>
              <% if (m.pengumpulan) { %>
                <%= new Date(m.pengumpulan.submittedAt).toLocaleString('id-ID') %>
              <% } else { %>
                -
              <% } %>
            </td>
            <td>
              <span class="nilai-<%= m.id %>">
                <% if (m.pengumpulan && m.pengumpulan.nilai !== null) { %>
                  <%= m.pengumpulan.nilai %>
                <% } else { %>
                  -
                <% } %>
              </span>
            </td>
            <td>
              <span class="komentar-<%= m.id %>">
                <% if (m.pengumpulan && m.pengumpulan.komentar) { %>
                  <%= m.pengumpulan.komentar %>
                <% } else { %>
                  -
                <% } %>
              </span>
            </td>
            <td>
              <% if (m.pengumpulan) { %>
                <button class="btn btn-sm btn-warning btn-action" onclick="editNilai('<%= m.id %>', '<%= m.pengumpulan.id %>', <%= m.pengumpulan.nilai %>, '<%= m.pengumpulan.komentar %>')">
                  <i class="bi bi-pencil"></i> Nilai
                </button>
              <% } else { %>
                <button class="btn btn-sm btn-secondary btn-action" disabled>Belum Kumpul</button>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal Input Nilai -->
<div class="modal fade" id="nilaiModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Input Nilai</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/dosen/pengumpulan/nilai" id="nilaiForm">
        <input type="hidden" name="pengumpulanId" id="pengumpulanId">
        <div class="modal-body">
          <div class="mb-3">
            <label for="nilai" class="form-label fw-semibold">Nilai (0-100)</label>
            <input type="number" class="form-control" id="nilai" name="nilai" min="0" max="100" step="0.01" required>
          </div>
          <div class="mb-3">
            <label for="komentar" class="form-label fw-semibold">Komentar</label>
            <textarea class="form-control" id="komentar" name="komentar" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function editNilai(mahasiswaId, pengumpulanId, nilai, komentar) {
    document.getElementById('pengumpulanId').value = pengumpulanId;
    document.getElementById('nilai').value = nilai || '';
    document.getElementById('komentar').value = komentar || '';
    new bootstrap.Modal(document.getElementById('nilaiModal')).show();
  }
</script>

<%- include('../partials/footer') %>