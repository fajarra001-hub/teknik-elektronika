<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cetak Logbook - <%= mahasiswa.nama %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    @media print {
      .btn { display: none; }
      body { font-size: 12pt; }
      .table thead tr { background-color: #f2f2f2; }
    }
    .print-btn { margin-bottom: 20px; }
    .kop-surat {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 20px;
      border-bottom: 2px solid #0d6efd;
      padding-bottom: 10px;
    }
    .logo-kop {
      width: 100px;
      height: auto;
    }
    .teks-kop {
      flex: 1;
      text-align: left;
    }
    .teks-kop h2 {
      font-size: 28px;
      font-weight: bold;
      margin: 0;
      color: #212529;
    }
    .teks-kop h3 {
      font-size: 22px;
      font-weight: 600;
      margin: 0;
      color: #0d6efd;
      text-transform: uppercase;
    }
    .teks-kop p {
      font-size: 11pt;
      margin: 2px 0;
      color: #6c757d;
    }
    .thumbnail {
      width: 60px;
      height: 60px;
      object-fit: cover;
      border-radius: 4px;
    }
    .gallery {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
    }
  </style>
</head>
<body>
  <div class="container mt-4">
    <button onclick="window.print()" class="btn btn-primary print-btn">
      <i class="bi bi-printer"></i> Print / Simpan PDF
    </button>

    <div class="kop-surat">
      <img src="https://polidewa.ac.id/wp-content/uploads/2025/11/Desain-tanpa-judul-1.png" 
           alt="Logo" class="logo-kop">
      <div class="teks-kop">
        <h2>POLITEKNIK DEWANTARA</h2>
        <h3>PROGRAM STUDI TEKNIK ELEKTRONIKA</h3>
        <p>JL. KH Ahmad Razak 2, No.7, Kota Palopo, Sulawesi Selatan</p>
      </div>
    </div>

    <h4 class="text-center">LOGBOOK MAGANG</h4>
    <p class="text-center"><strong><%= mahasiswa.nama %></strong> (NIM: <%= mahasiswa.nim %>)</p>
    <p class="text-center"><small><%= filterInfo %></small></p>
    <p class="text-center"><small>Dicetak: <%= generatedAt %></small></p>

    <table class="table table-bordered">
      <thead>
        <tr>
          <th>No</th>
          <th>Tanggal</th>
          <th>Kegiatan</th>
          <th>Lokasi</th>
          <th>Durasi (jam)</th>
          <th>Semester</th>
          <th>Dokumentasi</th>
        </tr>
      </thead>
      <tbody>
        <% if (logbookList.length === 0) { %>
          <tr><td colspan="7" class="text-center">Belum ada entri logbook.</td></tr>
        <% } %>
        <% logbookList.forEach((item, index) => { %>
          <tr>
            <td class="text-center"><%= index + 1 %></td>
            <td><%= item.tanggalFormatted %></td>
            <td><%= item.kegiatan %></td>
            <td><%= item.lokasi || '-' %></td>
            <td class="text-center"><%= item.durasi || '-' %></td>
            <td><%= item.semester || '-' %></td>
            <td>
              <% if (item.imageUrls && item.imageUrls.length > 0) { %>
                <div class="gallery">
                  <% item.imageUrls.forEach(url => { 
                    let fileId = url.match(/[?&]id=([^&]+)/)?.[1] || url.split('/').pop();
                  %>
                    <img src="https://drive.google.com/thumbnail?id=<%= fileId %>&sz=w100" class="thumbnail">
                  <% }) %>
                </div>
              <% } else { %>
                -
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <th colspan="4" class="text-end">Total Durasi</th>
          <th class="text-center"><%= totalDurasi.toFixed(1) %></th>
          <th colspan="2"></th>
        </tr>
      </tfoot>
    </table>

    <div style="margin-top: 30px;">
      <p>Mengetahui,</p>
      <p>Ketua Program Studi</p>
      <br><br>
      <p>(______________________)</p>
    </div>
  </div>
</body>
</html>