<%- include('../partials/header') %>

<%
  // Default values jika tidak ada data
  if (typeof mkList === 'undefined') mkList = [];
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h1 {
    font-weight: 700;
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .page-header p {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: 0;
    position: relative;
    z-index: 1;
  }

  /* MK Card */
  .mk-card {
    border: none;
    border-radius: 1.5rem;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    overflow: hidden;
    background: white;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    border: 1px solid rgba(30,58,138,0.1);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .mk-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 35px rgba(30,58,138,0.15);
    border-color: transparent;
  }
  .mk-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    padding: 1.2rem 1.5rem;
    color: white;
  }
  .mk-header h5 {
    margin: 0;
    font-weight: 700;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .mk-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .mk-body h6 {
    font-weight: 700;
    color: #1e293b;
    font-size: 1.2rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }
  .mk-info {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.8rem;
    color: #64748b;
    font-size: 0.95rem;
  }
  .mk-info i {
    width: 20px;
    color: var(--primary-start);
    font-size: 1.1rem;
  }
  .btn-detail {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1rem;
    border-radius: 50px;
    transition: all 0.3s;
    width: 100%;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
    font-size: 0.95rem;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
  }
  .btn-detail:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }

  /* Tombol Kembali */
  .btn-outline-secondary {
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    background: transparent;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-outline-secondary:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }

  /* Alert */
  .alert-info {
    border-radius: 1rem;
    border-left: 4px solid var(--primary-start);
    background: white;
    color: var(--primary-dark);
    border: 1px solid rgba(30,58,138,0.1);
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    padding: 1rem 1.5rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header h1 { font-size: 1.8rem; }
    .page-header p { font-size: 1rem; }
    .mk-header h5 { font-size: 1rem; }
    .mk-body h6 { font-size: 1rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h1 { font-size: 1.5rem; }
    .page-header p { font-size: 0.9rem; }
    .mk-body { padding: 1.2rem; }
    .mk-info { font-size: 0.85rem; }
    .btn-detail { font-size: 0.85rem; }
  }
</style>

<div class="container mt-4">
  <!-- Page Header -->
  <div class="page-header">
    <h1 class="fw-bold">Pilih Mata Kuliah</h1>
    <p class="mb-0">Pilih mata kuliah untuk melihat rekap nilai mahasiswa</p>
  </div>

  <% if (mkList && mkList.length > 0) { %>
    <div class="row g-4">
      <% mkList.forEach(mk => { %>
        <div class="col-md-4">
          <div class="mk-card">
            <div class="mk-header">
              <h5><%= mk.kode %></h5>
            </div>
            <div class="mk-body">
              <h6 class="fw-bold"><%= mk.nama %></h6>
              <div class="mk-info">
                <i class="bi bi-calendar"></i> <span>Semester <%= mk.semester || '-' %></span>
              </div>
              <div class="mk-info">
                <i class="bi bi-clock"></i> <span><%= mk.sks %> SKS</span>
              </div>
              <div class="mk-info">
                <i class="bi bi-people"></i> <span><%= mk.jumlahMahasiswa || '?' %> Mahasiswa</span>
              </div>
              <a href="/dosen/nilai/<%= mk.id %>" class="btn-detail">
                <i class="bi bi-bar-chart"></i> Lihat Rekap Nilai
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>
      Anda belum mengampu mata kuliah apapun.
    </div>
  <% } %>

  <div class="mt-4">
    <a href="/dosen/dashboard" class="btn-outline-secondary">
      <i class="bi bi-arrow-left me-2"></i>Kembali ke Dashboard
    </a>
  </div>
</div>

<%- include('../partials/footer') %>