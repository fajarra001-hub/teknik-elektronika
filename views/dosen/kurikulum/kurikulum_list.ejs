<%- include('../partials/header') %>

<style>
  .kurikulum-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .kurikulum-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .btn-action {
    margin: 2px;
    border-radius: 8px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
  }
  .filter-card {
    border-radius: 1rem;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    background: white;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .table-responsive {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
</style>

<div class="container-fluid mt-4">
  <h2 class="fw-bold mb-4">Kurikulum Prodi Teknik Elektronika</h2>

  <!-- Filter Card -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label for="semester" class="form-label fw-semibold">Filter Semester</label>
        <select class="form-select" id="semester" name="semester">
          <option value="">Semua Semester</option>
          <% semesterList.forEach(s => { %>
            <option value="<%= s %>" <%= s == selectedSemester ? 'selected' : '' %>>Semester <%= s %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
      <div class="col-md-2">
        <a href="/dosen/kurikulum" class="btn btn-outline-secondary w-100">Reset</a>
      </div>
    </form>
  </div>

  <!-- Tabel Mata Kuliah -->
  <div class="table-responsive">
    <table class="table kurikulum-table">
      <thead>
        <tr>
          <th>Kode</th>
          <th>Nama MK</th>
          <th>SKS</th>
          <th>Semester</th>
          <th>Dosen Pengampu</th>
          <th>RPS</th>
          <th>Detail</th>
        </tr>
      </thead>
      <tbody>
        <% if (mkList.length === 0) { %>
          <tr>
            <td colspan="7" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Tidak ada mata kuliah untuk semester ini.</p>
            </td>
          </tr>
        <% } %>
        <% mkList.forEach(mk => { %>
          <tr>
            <td><span class="badge bg-primary bg-opacity-10 text-primary"><%= mk.kode %></span></td>
            <td><strong><%= mk.nama %></strong></td>
            <td class="text-center"><%= mk.sks %></td>
            <td class="text-center"><%= mk.semester %></td>
            <td><%= mk.dosen || '-' %></td>
            <td>
              <% if (mk.rpsUrl) { %>
                <a href="<%= mk.rpsUrl %>" target="_blank" class="btn btn-sm btn-outline-info btn-action">
                  <i class="bi bi-file-pdf"></i> Lihat
                </a>
              <% } else { %>
                <span class="text-muted">-</span>
              <% } %>
            </td>
            <td>
              <a href="/dosen/kurikulum/<%= mk.id %>" class="btn btn-sm btn-outline-primary btn-action">
                <i class="bi bi-eye"></i> Detail
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>