<%- include('../../partials/header') %>

<%
  // Default values
  if (typeof mk === 'undefined') mk = {};
  if (typeof dosenList === 'undefined') dosenList = [];
  if (typeof materi === 'undefined') materi = [];
  if (typeof tugasList === 'undefined') tugasList = [];
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Detail Header */
  .detail-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .detail-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .detail-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .detail-header p {
    font-size: 1.1rem;
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }
  .detail-header .btn-back {
    background: white;
    border: none;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 600;
    color: var(--primary-start);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .detail-header .btn-back:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* Info Card */
  .info-card {
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .info-card h5 {
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.2rem;
  }
  .info-card h5 i {
    color: var(--primary-start);
  }

  /* Dosen Badge */
  .dosen-badge {
    background: var(--primary-light);
    color: var(--primary-start);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    display: inline-block;
    margin-right: 0.5rem;
    margin-bottom: 0.5rem;
    font-weight: 500;
    font-size: 0.9rem;
  }

  /* Tabel Materi (minimalis) */
  .table-responsive {
    border-radius: 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    box-shadow: 0 2px 8px rgba(0,0,0,0.02);
  }
  .materi-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .materi-table th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem;
  }
  .materi-table td {
    padding: 0.75rem;
    border: 1px solid #dee2e6;
    font-size: 0.95rem;
  }
  .materi-table tbody tr:hover {
    background-color: #f2f2f2;
  }

  /* Badge Status */
  .badge-status {
    padding: 0.3rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    display: inline-block;
  }
  .badge-selesai {
    background: var(--success-bg);
    color: var(--success-text);
    border: 1px solid #a7f3d0;
  }
  .badge-belum {
    background: var(--warning-bg);
    color: var(--warning-text);
    border: 1px solid #fde68a;
  }

  /* List Group untuk Tugas */
  .list-group-item {
    border: 1px solid rgba(30,58,138,0.1);
    border-radius: 0.75rem;
    margin-bottom: 0.5rem;
    padding: 1rem;
    background: white;
  }
  .list-group-item .badge {
    background: var(--primary-light);
    color: var(--primary-start);
    font-weight: 500;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.8rem;
  }

  /* Responsif */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .detail-header h1 { font-size: 1.8rem; }
    .detail-header p { font-size: 1rem; }
  }
  @media (max-width: 576px) {
    html { font-size: 14px; }
    .detail-header h1 { font-size: 1.5rem; }
    .detail-header .btn-back { width: 100%; justify-content: center; }
  }
</style>

<div class="container mt-4">
  <!-- Detail Header -->
  <div class="detail-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h1><%= mk.kode %> - <%= mk.nama %></h1>
      <p class="mb-0">
        <i class="bi bi-book me-2"></i><%= mk.sks %> SKS |
        <i class="bi bi-calendar me-2"></i>Semester <%= mk.semester %>
      </p>
    </div>
    <a href="/dosen/kurikulum" class="btn-back mt-2 mt-sm-0">
      <i class="bi bi-arrow-left"></i> Kembali
    </a>
  </div>

  <!-- Dosen Pengampu -->
  <div class="info-card">
    <h5><i class="bi bi-people"></i> Dosen Pengampu</h5>
    <div>
      <% if (dosenList.length > 0) { %>
        <% dosenList.forEach(d => { %>
          <span class="dosen-badge"><%= d %></span>
        <% }) %>
      <% } else { %>
        <p class="text-muted">-</p>
      <% } %>
    </div>
  </div>

  <!-- CPL -->
  <% if (mk.cpl) { %>
    <div class="info-card">
      <h5><i class="bi bi-award"></i> Capaian Pembelajaran Lulusan (CPL)</h5>
      <p><%= mk.cpl %></p>
    </div>
  <% } %>

  <!-- RPS -->
  <% if (mk.rpsUrl) { %>
    <div class="info-card">
      <h5><i class="bi bi-file-earmark-text"></i> Rencana Pembelajaran Semester (RPS)</h5>
      <a href="<%= mk.rpsUrl %>" target="_blank" class="btn-action" style="display: inline-block; padding: 0.5rem 1.5rem;">
        <i class="bi bi-file-pdf"></i> Unduh RPS
      </a>
    </div>
  <% } %>

  <!-- Materi per Pertemuan -->
  <div class="info-card">
    <h5><i class="bi bi-list-task"></i> Materi Perkuliahan (16 Pertemuan)</h5>
    <div class="table-responsive">
      <table class="table materi-table">
        <thead>
          <tr>
            <th>Pertemuan</th>
            <th>Topik</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (materi.length === 0) { %>
            <tr><td colspan="3" class="text-center">Belum ada materi yang diinput.</td></tr>
          <% } else { %>
            <% materi.forEach(m => { %>
              <tr>
                <td class="text-center"><%= m.pertemuan %></td>
                <td><%= m.topik || '-' %></td>
                <td>
                  <span class="badge-status <%= m.status === 'selesai' ? 'badge-selesai' : 'badge-belum' %>">
                    <%= m.status === 'selesai' ? 'Selesai' : 'Belum' %>
                  </span>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Tugas Terkait -->
  <% if (tugasList.length > 0) { %>
    <div class="info-card">
      <h5><i class="bi bi-file-earmark-text"></i> Tugas Terkait</h5>
      <div class="list-group">
        <% tugasList.forEach(t => { %>
          <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <strong><%= t.judul %></strong><br>
              <small class="text-muted">
                <i class="bi bi-calendar3"></i> Deadline: <%= new Date(t.deadline).toLocaleDateString('id-ID') %>
              </small>
            </div>
            <span class="badge"><%= t.tipe %></span>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>
</div>

<%- include('../../partials/footer') %>