<%- include('../partials/header') %>

<%
  // Fungsi untuk mendapatkan thumbnail dari Google Drive (jika diperlukan)
  const getDriveThumbnail = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w100-h100`;
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w100-h100`;
    return url;
  };
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    padding: 2rem;
    border-radius: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    font-size: 2rem;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1rem;
  }
  .page-header .btn-light {
    background: white;
    border: none;
    border-radius: 50px;
    padding: 0.6rem 1.8rem;
    font-weight: 600;
    color: var(--primary-start);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    position: relative;
    z-index: 1;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .page-header .btn-light:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* Filter Section */
  .filter-section {
    background: white;
    border-radius: 1.2rem;
    padding: 1.2rem 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    border: 1px solid rgba(30,58,138,0.1);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .filter-section .form-control,
  .filter-section .form-select {
    border-radius: 50px;
    padding: 0.5rem 1rem;
    border: 1px solid #cbd5e1;
    min-width: 200px;
    flex: 1 1 auto;
  }
  .filter-section .btn-filter {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    border: none;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.2s;
  }
  .filter-section .btn-filter:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }
  .filter-section .btn-reset {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.2s;
  }
  .filter-section .btn-reset:hover {
    background: var(--primary-start);
    color: white;
    transform: translateY(-2px);
  }

  /* Tabel Container */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .mahasiswa-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .mahasiswa-table thead th {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
    padding: 1rem;
    white-space: nowrap;
    text-align: center;
  }
  .mahasiswa-table tbody td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e9ecef;
    font-size: 0.95rem;
  }
  .mahasiswa-table tbody tr:hover td {
    background-color: #f8fafc;
  }

  /* Avatar dan Foto */
  .avatar-circle {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.2rem;
    text-transform: uppercase;
    box-shadow: 0 4px 10px rgba(30,58,138,0.3);
    margin: 0 auto;
  }
  .foto-mahasiswa {
    width: 45px;
    height: 45px;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid white;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    display: block;
    margin: 0 auto;
  }

  /* Tombol Detail */
  .btn-detail {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    font-size: 0.8rem;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-detail:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 8px 15px rgba(30,58,138,0.3);
  }

  /* NIM styling */
  .nim-text {
    font-weight: 500;
    color: #1e293b;
  }

  /* Empty state */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
  .empty-state p {
    color: #6c757d;
    font-size: 1.1rem;
  }

  /* No results message */
  .no-results {
    text-align: center;
    padding: 2rem;
    color: #64748b;
    font-style: italic;
    display: none;
  }

  /* Responsif */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .page-header h2 { font-size: 1.6rem; }
    .page-header .btn-light { width: 100%; justify-content: center; }
    .filter-section { flex-direction: column; align-items: stretch; }
    .filter-section .form-control,
    .filter-section .form-select,
    .filter-section .btn-filter,
    .filter-section .btn-reset { width: 100%; }
    .mahasiswa-table thead th { font-size: 0.8rem; padding: 0.75rem; }
    .mahasiswa-table tbody td { font-size: 0.9rem; padding: 0.5rem; }
  }
  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h2 { font-size: 1.4rem; }
  }
</style>

<div class="container mt-4">
  <!-- Page Header -->
  <div class="page-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2><%= mk.kode %> - <%= mk.nama %></h2>
      <p class="mb-0"><i class="bi bi-people-fill me-2"></i>Daftar mahasiswa yang mengambil mata kuliah ini</p>
    </div>
    <a href="/dosen/mk/<%= mk.id %>" class="btn-light">
      <i class="bi bi-arrow-left"></i> Kembali ke Detail MK
    </a>
  </div>

  <% if (mahasiswaList.length > 0) { %>
    <!-- Filter Section -->
    <div class="filter-section">
      <input type="text" id="searchInput" class="form-control" placeholder="Cari nama atau NIM...">
      <select id="angkatanFilter" class="form-select">
        <option value="">Semua Angkatan</option>
        <!-- Options akan diisi dengan JavaScript -->
      </select>
      <button class="btn-filter" id="applyFilter">Terapkan</button>
      <button class="btn-reset" id="resetFilter">Reset</button>
    </div>
  <% } %>

  <!-- Tabel Mahasiswa -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table mahasiswa-table">
        <thead>
          <tr>
            <th>No</th>
            <th>Foto</th>
            <th>NIM</th>
            <th>Nama</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (mahasiswaList.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <p>Belum ada mahasiswa yang terdaftar.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% mahasiswaList.forEach((m, index) => { 
              const fotoUrl = m.foto ? getDriveThumbnail(m.foto) : null;
              // Menentukan angkatan dari NIM
              let angkatan = '';
              const nim = m.nim || '';
              if (nim) {
                if (nim.length >= 4 && !isNaN(nim.substring(0,4)) && parseInt(nim.substring(0,4)) > 2000) {
                  angkatan = nim.substring(0,4);
                } else if (nim.length >= 2) {
                  angkatan = '20' + nim.substring(0,2);
                }
              }
            %>
            <tr data-nama="<%= m.nama.toLowerCase() %>" data-nim="<%= nim %>" data-angkatan="<%= angkatan %>">
              <td class="fw-bold text-center"><%= index + 1 %></td>
              <td class="text-center">
                <% if (fotoUrl) { %>
                  <img src="<%= fotoUrl %>" alt="foto <%= m.nama %>" class="foto-mahasiswa" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(m.nama) %>&background=1e3a8a&color=fff&size=45';">
                <% } else { %>
                  <div class="avatar-circle"><%= (m.nama || '?').charAt(0).toUpperCase() %></div>
                <% } %>
              </td>
              <td class="text-center"><span class="nim-text"><%= nim || '-' %></span></td>
              <td><strong><%= m.nama %></strong></td>
              <td class="text-center">
                <a href="/dosen/mahasiswa/<%= m.id %>" class="btn-detail">
                  <i class="bi bi-eye"></i> Detail
                </a>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
      <div id="noFilterResult" class="no-results">Tidak ada mahasiswa yang cocok dengan filter.</div>
    </div>
  </div>
</div>

<% if (mahasiswaList.length > 0) { %>
<script>
  (function() {
    // Fungsi untuk mendapatkan daftar angkatan unik dari data attribute
    function getUniqueAngkatan() {
      const rows = document.querySelectorAll('.mahasiswa-table tbody tr[data-angkatan]');
      const angkatanSet = new Set();
      rows.forEach(row => {
        const angkatan = row.getAttribute('data-angkatan');
        if (angkatan) angkatanSet.add(angkatan);
      });
      return Array.from(angkatanSet).sort();
    }

    // Isi dropdown angkatan
    const angkatanFilter = document.getElementById('angkatanFilter');
    const angkatanList = getUniqueAngkatan();
    angkatanList.forEach(angkatan => {
      const option = document.createElement('option');
      option.value = angkatan;
      option.textContent = angkatan;
      angkatanFilter.appendChild(option);
    });

    // Fungsi filter
    function filterTable() {
      const searchInput = document.getElementById('searchInput').value.toLowerCase().trim();
      const angkatanValue = document.getElementById('angkatanFilter').value;
      const rows = document.querySelectorAll('.mahasiswa-table tbody tr[data-nama]');
      let visibleCount = 0;

      rows.forEach(row => {
        const nama = row.getAttribute('data-nama') || '';
        const nim = row.getAttribute('data-nim') || '';
        const angkatan = row.getAttribute('data-angkatan') || '';

        let matchSearch = true;
        if (searchInput !== '') {
          matchSearch = nama.includes(searchInput) || nim.includes(searchInput);
        }

        let matchAngkatan = true;
        if (angkatanValue !== '') {
          matchAngkatan = angkatan === angkatanValue;
        }

        if (matchSearch && matchAngkatan) {
          row.style.display = '';
          visibleCount++;
        } else {
          row.style.display = 'none';
        }
      });

      const noResultDiv = document.getElementById('noFilterResult');
      if (visibleCount === 0) {
        noResultDiv.style.display = 'block';
      } else {
        noResultDiv.style.display = 'none';
      }
    }

    // Reset filter
    function resetFilter() {
      document.getElementById('searchInput').value = '';
      document.getElementById('angkatanFilter').value = '';
      const rows = document.querySelectorAll('.mahasiswa-table tbody tr[data-nama]');
      rows.forEach(row => row.style.display = '');
      document.getElementById('noFilterResult').style.display = 'none';
    }

    // Event listeners
    document.getElementById('applyFilter').addEventListener('click', filterTable);
    document.getElementById('resetFilter').addEventListener('click', resetFilter);
    document.getElementById('searchInput').addEventListener('keyup', function(e) {
      if (e.key === 'Enter') filterTable();
    });
    document.getElementById('angkatanFilter').addEventListener('change', filterTable);
  })();
</script>
<% } %>

<%- include('../partials/footer') %>