<%- include('../partials/header') %>

<style>
  .detail-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-radius: 1rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
  }
  .laporan-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
</style>

<div class="container-fluid mt-4">
  <div class="detail-header d-flex justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-file-earmark-pdf me-2"></i>Laporan Magang - <%= mahasiswa.nama %></h2>
      <p class="mb-0 opacity-75">NIM: <%= mahasiswa.nim || '-' %></p>
    </div>
    <a href="/dosen/laporan-magang" class="btn btn-light">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <% for (let i = 1; i <= 3; i++) { 
    const laporan = laporanList.find(l => l.laporanKe === i);
  %>
    <div class="laporan-card">
      <h5 class="fw-bold mb-3">Laporan Magang <%= i %></h5>
      <% if (laporan) { %>
        <p><strong>File:</strong> <a href="<%= laporan.fileUrl %>" target="_blank"><%= laporan.fileName %></a></p>
        <p><strong>Diunggah:</strong> <%= new Date(laporan.uploadedAt).toLocaleString('id-ID') %></p>
        <p><strong>Status:</strong> 
          <% if (laporan.status === 'submitted') { %>
            <span class="badge bg-warning text-dark">Menunggu</span>
          <% } else if (laporan.status === 'approved') { %>
            <span class="badge bg-success">Disetujui</span>
          <% } else if (laporan.status === 'rejected') { %>
            <span class="badge bg-danger">Ditolak</span>
          <% } %>
        </p>
        <% if (laporan.catatanAdmin) { %>
          <p><strong>Catatan Admin:</strong> <%= laporan.catatanAdmin %></p>
        <% } %>
      <% } else { %>
        <p class="text-muted">Belum ada laporan.</p>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>