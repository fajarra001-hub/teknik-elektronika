<%- include('../partials/header') %>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0;
    position: relative;
    z-index: 1;
    font-size: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-gradient {
    background: white;
    border: none;
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    position: relative;
    z-index: 1;
    font-size: 0.95rem;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* Tabel Container */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(30,58,138,0.1);
    padding: 0;
  }
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* Tabel minimalis */
  .artikel-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .artikel-table thead th {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
    padding: 1.2rem 1rem;
    white-space: nowrap;
    text-align: left;
  }
  .artikel-table tbody td {
    vertical-align: middle;
    padding: 1.2rem 1rem;
    background-color: white;
    border-bottom: 1px solid #e9ecef;
    font-size: 0.95rem;
  }
  .artikel-table tbody tr:hover td {
    background-color: #f8fafc;
  }
  .artikel-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* Badge status */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    background: #f8f9fa;
    border: 1px solid transparent;
  }
  .badge-pending {
    background: #fef3c7;
    color: #92400e;
    border-color: #fde68a;
  }
  .badge-approved {
    background: #d1fae5;
    color: #065f46;
    border-color: #a7f3d0;
  }
  .badge-rejected {
    background: #fee2e2;
    color: #991b1b;
    border-color: #fecaca;
  }

  /* Tombol aksi */
  .btn-icon-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: none;
    transition: all 0.3s;
    color: white;
    margin: 0 2px;
    text-decoration: none;
    cursor: pointer;
    font-size: 1rem;
  }
  .btn-icon-sm i {
    font-size: 1rem;
  }
  .btn-detail {
    background: var(--primary-start);
  }
  .btn-detail:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }
  .btn-edit {
    background: #f97316;
  }
  .btn-edit:hover {
    background: #ea580c;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(249,115,22,0.3);
  }
  .btn-delete {
    background: #ef4444;
  }
  .btn-delete:hover {
    background: #dc2626;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(239,68,68,0.3);
  }

  /* Alert */
  .custom-alert {
    border-radius: 1rem;
    border-left: 4px solid #17a2b8;
    background: white;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(23,162,184,0.2);
    color: #0f2b5c;
  }

  /* Empty state */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8fafc;
    border-radius: 1.5rem;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1.5rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    margin-bottom: 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .page-header h2 { font-size: 1.6rem; }
    .btn-gradient { width: 100%; justify-content: center; }
    .artikel-table thead th { font-size: 0.8rem; padding: 1rem 0.8rem; }
    .artikel-table tbody td { font-size: 0.9rem; padding: 1rem 0.8rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h2 { font-size: 1.4rem; }
    .artikel-table thead th { font-size: 0.75rem; padding: 0.8rem 0.5rem; }
    .artikel-table tbody td { font-size: 0.85rem; padding: 0.8rem 0.5rem; }
    .badge-status { font-size: 0.7rem; padding: 0.3rem 0.8rem; }
    .btn-icon-sm { width: 30px; height: 30px; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .page-header h2 { font-size: 1.2rem; }
  }
</style>

<div class="container mt-4">
  <!-- Header dengan tombol buat baru -->
  <div class="page-header">
    <h2><i class="bi bi-journal-richtext me-2"></i>Artikel Saya</h2>
    <a href="/dosen/artikel/create" class="btn-gradient">
      <i class="bi bi-plus-circle"></i> Buat Artikel Baru
    </a>
  </div>

  <!-- Notifikasi sukses hapus -->
  <% if (typeof success !== 'undefined' && success === 'deleted') { %>
    <div class="custom-alert">
      <i class="bi bi-trash-fill me-2" style="color: #17a2b8;"></i>Artikel berhasil dihapus.
      <button type="button" class="btn-close float-end" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Tabel Artikel -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table artikel-table">
        <thead>
          <tr>
            <th>Judul</th>
            <th>Abstrak</th>
            <th>Tanggal Upload</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (artikelList.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-journal-text"></i>
                  <h4>Belum Ada Artikel</h4>
                  <p class="text-muted">Buat artikel pertama Anda dengan klik tombol "Buat Artikel Baru".</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% artikelList.forEach(a => { %>
              <tr>
                <td><strong><%= a.judul %></strong></td>
                <td><%= (a.abstrak || '').substring(0, 80) %><%= (a.abstrak || '').length > 80 ? '...' : '' %></td>
                <td><%= new Date(a.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) %></td>
                <td>
                  <% if (a.status === 'pending') { %>
                    <span class="badge-status badge-pending"><i class="bi bi-hourglass-split"></i> Menunggu</span>
                  <% } else if (a.status === 'approved') { %>
                    <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i> Disetujui</span>
                  <% } else if (a.status === 'rejected') { %>
                    <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i> Ditolak</span>
                  <% } %>
                </td>
                <td>
                  <div class="d-flex gap-1">
                    <a href="/dosen/artikel/<%= a.id %>" class="btn-icon-sm btn-detail" title="Detail">
                      <i class="bi bi-eye"></i>
                    </a>
                    <a href="/dosen/artikel/<%= a.id %>/edit" class="btn-icon-sm btn-edit" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <form method="POST" action="/dosen/artikel/<%= a.id %>/delete" style="display:inline;" onsubmit="return confirm('Yakin hapus artikel ini?')">
                      <button class="btn-icon-sm btn-delete" title="Hapus">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>