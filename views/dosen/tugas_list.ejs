<%- include('../partials/header') %>

<%
  // Fungsi untuk memformat tanggal
  const formatDate = (date) => {
    if (!date) return '-';
    return new Date(date).toLocaleDateString('id-ID', { 
      day: 'numeric', 
      month: 'short', 
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  };
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin: 0;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 2rem;
  }
  .page-header .btn-create {
    background: white;
    border: none;
    border-radius: 50px;
    padding: 0.6rem 1.8rem;
    font-weight: 600;
    color: var(--primary-start);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    position: relative;
    z-index: 1;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
  }
  .page-header .btn-create:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* Table Container */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(30,58,138,0.1);
    padding: 1.5rem;
  }
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 1rem;
  }
  .tugas-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .tugas-table th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem 1rem;
    white-space: nowrap;
  }
  .tugas-table td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border: 1px solid #dee2e6;
    font-size: 0.95rem;
  }
  .tugas-table tbody tr:hover {
    background-color: #f2f2f2;
  }

  /* Badge Tipe Tugas */
  .badge-tipe {
    background: var(--primary-light);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: 1px solid rgba(30,58,138,0.2);
  }
  .badge-tipe i {
    font-size: 0.9rem;
  }

  /* Tombol Aksi */
  .btn-action {
    border-radius: 50px;
    padding: 0.3rem 1rem;
    font-size: 0.8rem;
    transition: all 0.2s;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    border: 1.5px solid transparent;
    text-decoration: none;
    cursor: pointer;
    background: transparent;
  }
  .btn-action-outline {
    border-color: var(--primary-start);
    color: var(--primary-start);
  }
  .btn-action-outline:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }
  .btn-action-danger {
    border-color: #dc3545;
    color: #dc3545;
  }
  .btn-action-danger:hover {
    background: #dc3545;
    border-color: #dc3545;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(220,53,69,0.3);
  }

  /* Empty state */
  .empty-state {
    padding: 3rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1rem;
  }
  .empty-state i {
    font-size: 3rem;
    color: #adb5bd;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    font-size: 1rem;
  }
  .empty-state .btn-create {
    display: inline-block;
    margin-top: 1rem;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 500;
  }

  /* Responsif */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .page-header h2 { font-size: 1.6rem; }
  }
  @media (max-width: 576px) {
    html { font-size: 14px; }
    .tugas-table th { font-size: 0.8rem; padding: 0.5rem; }
    .tugas-table td { font-size: 0.85rem; padding: 0.5rem; }
  }
</style>

<div class="container mt-4">
  <!-- Page Header dengan gradien -->
  <div class="page-header">
    <h2>
      <i class="bi bi-list-task"></i> Daftar Tugas
    </h2>
    <a href="/dosen/tugas/create" class="btn-create">
      <i class="bi bi-plus-circle"></i> Buat Tugas Baru
    </a>
  </div>

  <!-- Tabel Tugas (tanpa kolom File) -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table tugas-table">
        <thead>
          <tr>
            <th>Judul</th>
            <th>Mata Kuliah</th>
            <th>Deadline</th>
            <th>Tipe</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (tugasList.length === 0) { %>
            <tr>
              <td colspan="5" class="text-center py-4">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <p>Belum ada tugas yang dibuat.</p>
                  <a href="/dosen/tugas/create" class="btn-create">
                    <i class="bi bi-plus-circle"></i> Buat Tugas Sekarang
                  </a>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% tugasList.forEach(t => { %>
              <tr>
                <td>
                  <strong style="color: #1e293b;"><%= t.judul %></strong>
                </td>
                <td>
                  <span class="badge bg-light text-dark px-3 py-2">
                    <%= t.mkKode || '-' %>
                  </span>
                </td>
                <td>
                  <span class="deadline">
                    <i class="bi bi-calendar3"></i> <%= formatDate(t.deadline) %>
                  </span>
                </td>
                <td>
                  <span class="badge-tipe">
                    <i class="bi bi-tag"></i> <%= t.tipe || '-' %>
                  </span>
                </td>
                <td>
                  <div class="d-flex gap-2 flex-wrap">
                    <a href="/dosen/tugas/<%= t.id %>" class="btn-action btn-action-outline">
                      <i class="bi bi-eye"></i> Detail
                    </a>
                    <form method="POST" action="/dosen/tugas/<%= t.id %>/delete" style="display:inline;" onsubmit="return confirm('Yakin ingin menghapus tugas ini?')">
                      <button type="submit" class="btn-action btn-action-danger">
                        <i class="bi bi-trash"></i> Hapus
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>