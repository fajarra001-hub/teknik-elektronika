<%- include('../partials/header') %>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 1.5rem 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    font-size: 2rem;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1rem;
  }
  .btn-back {
    background: white;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    color: var(--primary-start);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    border: none;
    font-size: 0.95rem;
  }
  .btn-back:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* Bulan Card */
  .bulan-card {
    background: white;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    transition: all 0.3s;
    height: 100%;
    border: 1px solid rgba(30,58,138,0.1);
    display: flex;
    flex-direction: column;
  }
  .bulan-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 35px rgba(30,58,138,0.15);
  }
  .bulan-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    padding: 1rem 1.5rem;
    font-weight: 700;
    font-size: 1.2rem;
    text-align: center;
    letter-spacing: 0.5px;
  }
  .bulan-body {
    padding: 1.5rem;
    flex: 1;
  }

  /* Kalender Grid */
  .calendar-grid {
    margin-bottom: 1rem;
  }
  .weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--primary-dark);
    margin-bottom: 0.25rem;
  }
  .days-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }
  .day-cell {
    aspect-ratio: 1 / 1;
    background: #f8f9fa;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    position: relative;
  }
  .day-cell .day-number {
    font-weight: 500;
  }
  .day-cell.has-event {
    background: var(--primary-light);
    color: var(--primary-dark);
    cursor: pointer;
  }
  .event-dot {
    width: 4px;
    height: 4px;
    background: var(--primary-start);
    border-radius: 50%;
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%);
  }

  /* Event List */
  .event-list {
    margin-top: 0.5rem;
    max-height: 150px;
    overflow-y: auto;
    padding-right: 0.25rem;
  }
  .event-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid #e9ecef;
    font-size: 0.8rem;
  }
  .event-item:last-child {
    border-bottom: none;
  }
  .event-badge {
    width: 22px;
    height: 22px;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 600;
    flex-shrink: 0;
  }
  .event-info {
    flex: 1;
  }
  .event-info strong {
    display: block;
    color: #1e293b;
    font-size: 0.85rem;
  }
  .event-info small {
    color: #64748b;
    font-size: 0.7rem;
  }
  .empty-events {
    text-align: center;
    color: #adb5bd;
    padding: 0.5rem 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header h2 { font-size: 1.6rem; }
    .page-header p { font-size: 0.95rem; }
    .btn-back { padding: 0.4rem 1.2rem; font-size: 0.9rem; }
    .bulan-header { font-size: 1.1rem; }
    .bulan-body { padding: 1.2rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h2 { font-size: 1.4rem; }
    .page-header { padding: 1.5rem; }
    .bulan-header { font-size: 1rem; }
    .bulan-body { padding: 1rem; }
    .event-info strong { font-size: 0.8rem; }
    .event-info small { font-size: 0.65rem; }
    .weekdays { font-size: 0.65rem; }
    .day-cell { font-size: 0.7rem; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .page-header h2 { font-size: 1.2rem; }
    .bulan-header { font-size: 0.95rem; }
  }

  @media (max-width: 340px) {
    html { font-size: 12px; }
    .bulan-header { font-size: 0.9rem; }
  }
</style>

<div class="container mt-4">
  <!-- Header -->
  <div class="page-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-calendar-event-fill me-2"></i>Kalender Akademik</h2>
      <p class="mb-0">Jadwal penting 6 bulan ke depan</p>
    </div>
    <a href="/dosen/dashboard" class="btn-back mt-2 mt-sm-0">
      <i class="bi bi-arrow-left"></i> Kembali ke Dashboard
    </a>
  </div>

  <!-- Daftar Bulan (2 kolom pada layar sedang, 3 pada layar besar) -->
  <div class="row g-4">
    <% months.forEach(month => { %>
      <div class="col-md-6 col-lg-4">
        <div class="bulan-card">
          <div class="bulan-header">
            <%= month.monthName %>
          </div>
          <div class="bulan-body">
            <!-- Grid Kalender -->
            <div class="calendar-grid">
              <div class="weekdays">
                <span>Sen</span><span>Sel</span><span>Rab</span><span>Kam</span><span>Jum</span><span>Sab</span><span>Min</span>
              </div>
              <div class="days-grid">
                <% month.days.forEach(day => { %>
                  <div class="day-cell <%= day.date ? (day.events.length > 0 ? 'has-event' : '') : '' %>">
                    <% if (day.date) { %>
                      <span class="day-number"><%= day.date %></span>
                      <% if (day.events.length > 0) { %>
                        <span class="event-dot"></span>
                      <% } %>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            </div>

            <!-- Daftar Event Bulan Ini -->
            <div class="event-list">
              <% if (month.events.length === 0) { %>
                <div class="empty-events">
                  <i class="bi bi-calendar-x"></i>
                  <p class="small">Tidak ada event</p>
                </div>
              <% } else { %>
                <% month.events.forEach(e => { 
                  const tgl = new Date(e.tanggal);
                  const day = tgl.getDate();
                %>
                  <div class="event-item">
                    <span class="event-badge"><%= day %></span>
                    <div class="event-info">
                      <strong><%= e.judul %></strong>
                      <small><%= e.kategori || 'umum' %> <%= e.waktu ? ' • ' + e.waktu : '' %></small>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>