<%- include('../partials/header') %>

<%
  // Fungsi untuk mendapatkan thumbnail dari Google Drive
  const getDriveThumbnail = (url, size = 400) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w${size}`;
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w${size}`;
    return url;
  };

  const fotoThumb = dosen.foto ? getDriveThumbnail(dosen.foto, 400) : null;
  const fotoPreview = dosen.foto ? getDriveThumbnail(dosen.foto, 200) : null;
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* Profile Header */
  .profile-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    padding: 2.5rem 2rem;
    border-radius: 1.5rem;
    margin-bottom: 2rem;
    text-align: center;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .profile-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .profile-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 4px solid rgba(255,255,255,0.5);
    object-fit: cover;
    margin-bottom: 1rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    position: relative;
    z-index: 1;
  }
  .profile-avatar-placeholder {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: white;
    color: var(--primary-start);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    margin: 0 auto 1rem;
    border: 4px solid rgba(255,255,255,0.5);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    position: relative;
    z-index: 1;
  }
  .profile-header h3 {
    font-weight: 700;
    margin-bottom: 0.3rem;
    position: relative;
    z-index: 1;
    font-size: 2rem;
  }
  .profile-header p {
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1rem;
  }

  /* Info Card */
  .info-card {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 2rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .info-card h5 {
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.3rem;
  }
  .info-card h5 i {
    color: var(--primary-start);
  }

  /* Form Elements */
  .form-label {
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 0.3rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .form-label i {
    color: var(--primary-start);
    font-size: 1rem;
  }
  .form-control {
    border-radius: 0.9rem;
    border: 1px solid #cbd5e1;
    padding: 0.6rem 1.2rem;
    transition: all 0.2s;
    font-size: 0.95rem;
  }
  .form-control:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.2rem rgba(30,58,138,0.25);
  }
  .form-control[readonly],
  .form-control[disabled] {
    background-color: #e9ecef;
    opacity: 0.8;
  }
  .text-danger {
    color: #dc3545;
  }

  /* Preview Foto */
  .foto-preview {
    max-width: 100px;
    border-radius: 1rem;
    border: 2px solid white;
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    margin-bottom: 0.5rem;
  }

  /* Buttons */
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }

  .btn-outline-gradient {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(30,58,138,0.3);
  }

  .btn-warning {
    background: #ffc107;
    border: none;
    color: #212529;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-warning:hover {
    background: #e0a800;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(255,193,7,0.3);
  }

  /* Alert */
  .alert {
    border-radius: 1rem;
    border: none;
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    border-left: 4px solid transparent;
  }
  .alert-success {
    background: #d4edda;
    color: #155724;
    border-left-color: #28a745;
  }
  .alert-info {
    background: #d1ecf1;
    color: #0c5460;
    border-left-color: #17a2b8;
  }

  /* Divider */
  hr {
    border-top: 1px solid rgba(30,58,138,0.2);
    margin: 2rem 0;
  }

  /* Responsif */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .profile-header h3 { font-size: 1.6rem; }
    .profile-avatar { width: 100px; height: 100px; }
    .profile-avatar-placeholder { width: 100px; height: 100px; font-size: 3rem; }
    .info-card { padding: 1.5rem; }
    .d-flex.justify-content-between {
      flex-direction: column;
      gap: 1rem;
    }
    .btn-gradient, .btn-outline-gradient, .btn-warning {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .profile-header h3 { font-size: 1.4rem; }
    .profile-avatar { width: 80px; height: 80px; }
    .profile-avatar-placeholder { width: 80px; height: 80px; font-size: 2.5rem; }
  }
</style>

<div class="container mt-4">
  <!-- Alert Notifikasi -->
  <% if (typeof success !== 'undefined' && success === 'updated') { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>Biodata berhasil diperbarui.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <% if (typeof reset !== 'undefined' && reset === 'email_sent') { %>
    <div class="alert alert-info alert-dismissible fade show" role="alert">
      <i class="bi bi-envelope-fill me-2"></i>Instruksi reset password telah dikirim ke email Anda.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Profile Header -->
  <div class="profile-header">
    <% if (fotoThumb) { %>
      <img src="<%= fotoThumb %>" alt="foto <%= dosen.nama %>" class="profile-avatar" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(dosen.nama) %>&background=1e3a8a&color=fff&size=120';">
    <% } else { %>
      <div class="profile-avatar-placeholder">
        <i class="bi bi-person-circle"></i>
      </div>
    <% } %>

    <h3><%= dosen.nama %></h3>
    <p class="mb-0"><i class="bi bi-qr-code me-2"></i><%= dosen.nip || '-' %></p>
  </div>

  <div class="row">
    <div class="col-md-8 mx-auto">
      <div class="info-card">
        <h5><i class="bi bi-pencil-square"></i> Edit Biodata</h5>

        <form method="POST" action="/dosen/biodata/update" enctype="multipart/form-data">
          <div class="mb-3">
            <label for="nip" class="form-label">
              <i class="bi bi-qr-code"></i> NIP
            </label>
            <input type="text" class="form-control" id="nip" value="<%= dosen.nip || '' %>" readonly disabled>
            <small class="text-muted">NIP tidak dapat diubah</small>
          </div>

          <div class="mb-3">
            <label for="nama" class="form-label">
              <i class="bi bi-person"></i> Nama <span class="text-danger">*</span>
            </label>
            <input type="text" class="form-control" id="nama" name="nama" value="<%= dosen.nama || '' %>" required>
          </div>

          <div class="mb-3">
            <label for="email" class="form-label">
              <i class="bi bi-envelope"></i> Email <span class="text-danger">*</span>
            </label>
            <input type="email" class="form-control" id="email" name="email" value="<%= dosen.email || '' %>" required>
          </div>

          <div class="mb-3">
            <label for="kontak" class="form-label">
              <i class="bi bi-telephone"></i> Kontak (No. HP)
            </label>
            <input type="text" class="form-control" id="kontak" name="kontak" value="<%= dosen.kontak || '' %>">
          </div>

          <div class="mb-4">
            <label for="foto" class="form-label">
              <i class="bi bi-camera"></i> Foto Profil
            </label>
            <% if (fotoPreview) { %>
              <div class="mb-2">
                <img src="<%= fotoPreview %>" alt="preview" class="foto-preview" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(dosen.nama) %>&background=1e3a8a&color=fff&size=100';">
              </div>
            <% } %>
            <input type="file" class="form-control" id="foto" name="foto" accept="image/*">
            <small class="text-muted">Kosongkan jika tidak ingin mengubah foto</small>
          </div>

          <div class="d-flex justify-content-between align-items-center">
            <a href="/dosen/dashboard" class="btn-outline-gradient">
              <i class="bi bi-arrow-left"></i> Kembali
            </a>
            <button type="submit" class="btn-gradient">
              <i class="bi bi-save"></i> Simpan Perubahan
            </button>
          </div>
        </form>

        <hr>

        <h5 class="mb-3"><i class="bi bi-key"></i> Keamanan Akun</h5>
        <p class="text-muted small">Klik tombol di bawah untuk mengirim email reset password ke alamat email Anda.</p>
        <form method="POST" action="/dosen/biodata/ubah-password" onsubmit="return confirm('Kirim email reset password?')">
          <button type="submit" class="btn-warning">
            <i class="bi bi-key"></i> Kirim Email Reset Password
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>