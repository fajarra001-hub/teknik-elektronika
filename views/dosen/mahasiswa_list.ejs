<%- include('../partials/header') %>

<style>
  .mahasiswa-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .mahasiswa-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .avatar-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 1.2rem;
  }
  .filter-card {
    border-radius: 1rem;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    background: white;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .table-responsive {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .foto-mahasiswa {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 50%;
  }
</style>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Mahasiswa Bimbingan</h2>
    <a href="/dosen/dashboard" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <!-- Filter Card -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-3">
        <label for="angkatan" class="form-label fw-semibold">Filter Angkatan</label>
        <select class="form-select" id="angkatan" name="angkatan">
          <option value="">Semua Angkatan</option>
          <% if (angkatanList && angkatanList.length) { %>
            <% angkatanList.forEach(a => { %>
              <option value="<%= a %>" <%= a === filterAngkatan ? 'selected' : '' %>><%= a %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="col-md-4">
        <label for="search" class="form-label fw-semibold">Cari Nama/NIM</label>
        <input type="text" class="form-control" id="search" name="search" placeholder="Ketik nama atau NIM" value="<%= search || '' %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
      <div class="col-md-2">
        <a href="/dosen/mahasiswa" class="btn btn-outline-secondary w-100">Reset</a>
      </div>
    </form>
  </div>

  <!-- Tabel Mahasiswa -->
  <div class="table-responsive">
    <table class="table mahasiswa-table">
      <thead>
        <tr>
          <th>No</th>
          <th>Foto</th>
          <th>NIM</th>
          <th>Nama</th>
          <th>Angkatan</th>
          <th>Mata Kuliah</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (mahasiswaList.length === 0) { %>
          <tr>
            <td colspan="7" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Tidak ada mahasiswa bimbingan.</p>
            </td>
          </tr>
        <% } else { %>
          <% mahasiswaList.forEach((m, index) => { %>
          <tr>
            <td class="fw-bold"><%= index + 1 %></td>
            <td>
              <% if (m.foto) { %>
                <img src="<%= m.foto %>" alt="foto" class="foto-mahasiswa">
              <% } else { %>
                <div class="avatar-circle"><%= (m.nama || '?').charAt(0).toUpperCase() %></div>
              <% } %>
            </td>
            <td><%= m.nim || '-' %></td>
            <td><%= m.nama %></td>
            <td><%= m.angkatan || '-' %></td>
            <td>
              <% if (m.mkDiambil && m.mkDiambil.length > 0) { %>
                <span class="badge bg-info"><%= m.mkDiambil.length %> MK</span>
              <% } else { %>
                <span class="badge bg-secondary">0</span>
              <% } %>
            </td>
            <td>
              <a href="/dosen/mahasiswa/<%= m.id %>" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-eye"></i> Detail
              </a>
            </td>
          </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>