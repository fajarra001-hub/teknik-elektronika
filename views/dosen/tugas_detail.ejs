<%- include('../partials/header') %>

<style>
  .detail-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    padding: 1.5rem;
    border-radius: 1rem;
    margin-bottom: 2rem;
  }
  .info-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .mahasiswa-table th {
    background: #f8f9fa;
    font-weight: 600;
  }
  .btn-nilai {
    background: #ffc107;
    border: none;
    color: #212529;
    border-radius: 8px;
    padding: 0.25rem 0.75rem;
    font-size: 0.85rem;
  }
</style>

<div class="container-fluid mt-4">
  <div class="detail-header">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h1><%= tugas.judul %></h1>
        <p class="mb-0 opacity-75">
          <i class="bi bi-book me-2"></i><%= tugas.mkKode %> - <%= tugas.mkNama %> |
          <i class="bi bi-calendar me-2"></i>Deadline: <%= new Date(tugas.deadline).toLocaleString('id-ID') %> |
          <span class="badge bg-light text-dark"><%= tugas.tipe %></span>
        </p>
      </div>
      <div>
        <a href="/dosen/tugas" class="btn btn-light">
          <i class="bi bi-arrow-left me-2"></i>Kembali
        </a>
      </div>
    </div>
  </div>

  <!-- Deskripsi Tugas -->
  <div class="info-card">
    <h5 class="fw-bold mb-3">Deskripsi</h5>
    <p><%= tugas.deskripsi || 'Tidak ada deskripsi.' %></p>
    <% if (tugas.fileUrl) { %>
      <a href="<%= tugas.fileUrl %>" target="_blank" class="btn btn-outline-primary">
        <i class="bi bi-download"></i> Unduh Soal
      </a>
    <% } %>
  </div>

  <!-- Daftar Mahasiswa dan Pengumpulan -->
  <div class="info-card">
    <h5 class="fw-bold mb-3">Daftar Mahasiswa dan Pengumpulan</h5>
    <div class="table-responsive">
      <table class="table mahasiswa-table">
        <thead>
          <tr>
            <th>NIM</th>
            <th>Nama</th>
            <th>Status</th>
            <th>File</th>
            <th>Nilai</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (mahasiswaList.length === 0) { %>
            <tr><td colspan="6" class="text-center">Tidak ada mahasiswa terdaftar.</td></tr>
          <% } %>
          <% mahasiswaList.forEach(m => { %>
            <tr>
              <td><%= m.nim %></td>
              <td><%= m.nama %></td>
              <td>
                <% if (m.pengumpulan) { %>
                  <span class="badge bg-success">Sudah</span>
                <% } else { %>
                  <span class="badge bg-secondary">Belum</span>
                <% } %>
              </td>
              <td>
                <% if (m.pengumpulan && m.pengumpulan.fileUrl) { %>
                  <a href="<%= m.pengumpulan.fileUrl %>" target="_blank" class="btn btn-sm btn-outline-info">Lihat</a>
                <% } else { %>
                  -
                <% } %>
              </td>
              <td>
                <% if (m.pengumpulan && m.pengumpulan.nilai) { %>
                  <%= m.pengumpulan.nilai %>
                <% } else { %>
                  -
                <% } %>
              </td>
              <td>
                <button class="btn btn-sm btn-warning" onclick="beriNilai('<%= m.pengumpulan ? m.pengumpulan.id : '' %>', '<%= m.nama %>')">Nilai</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Modal Nilai -->
<div class="modal fade" id="nilaiModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Input Nilai untuk <span id="namaMahasiswa"></span></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/dosen/pengumpulan/nilai" id="nilaiForm">
        <input type="hidden" name="pengumpulanId" id="pengumpulanId">
        <div class="modal-body">
          <div class="mb-3">
            <label for="nilai" class="form-label">Nilai (0-100)</label>
            <input type="number" class="form-control" id="nilai" name="nilai" min="0" max="100" step="0.01" required>
          </div>
          <div class="mb-3">
            <label for="komentar" class="form-label">Komentar</label>
            <textarea class="form-control" id="komentar" name="komentar" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function beriNilai(pengumpulanId, nama) {
    if (!pengumpulanId) {
      alert('Mahasiswa belum mengumpulkan tugas.');
      return;
    }
    document.getElementById('pengumpulanId').value = pengumpulanId;
    document.getElementById('namaMahasiswa').textContent = nama;
    new bootstrap.Modal(document.getElementById('nilaiModal')).show();
  }
</script>

<%- include('../partials/footer') %>