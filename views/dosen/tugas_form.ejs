<%- include('../partials/header') %>

<style>
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 1.5rem;
    color: white;
  }
  .form-header h3 {
    margin: 0;
    font-weight: 600;
  }
  .form-body {
    padding: 2rem;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
  .form-label {
    font-weight: 600;
    color: #1e293b;
  }
  .form-control, .form-select {
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid #cbd5e1;
    transition: all 0.3s;
  }
  .form-control:focus, .form-select:focus {
    border-color: #2193b0;
    box-shadow: 0 0 0 0.2rem rgba(33,147,176,0.25);
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3><i class="bi bi-plus-circle me-2"></i>Buat Tugas Baru</h3>
    </div>
    <div class="form-body">
      <form method="POST" action="/dosen/tugas" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="mkId" class="form-label">Mata Kuliah <span class="text-danger">*</span></label>
          <select class="form-select" id="mkId" name="mkId" required>
            <option value="" disabled selected>-- Pilih Mata Kuliah --</option>
            <% mkList.forEach(mk => { %>
              <option value="<%= mk.id %>"><%= mk.kode %> - <%= mk.nama %></option>
            <% }) %>
          </select>
        </div>

        <div class="mb-3">
          <label for="judul" class="form-label">Judul Tugas <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="judul" name="judul" placeholder="Contoh: Tugas 1 - Persamaan Diferensial" required>
        </div>

        <div class="mb-3">
          <label for="deskripsi" class="form-label">Deskripsi</label>
          <textarea class="form-control" id="deskripsi" name="deskripsi" rows="4" placeholder="Jelaskan detail tugas, petunjuk pengerjaan, dll."></textarea>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="deadline" class="form-label">Deadline <span class="text-danger">*</span></label>
            <input type="datetime-local" class="form-control" id="deadline" name="deadline" required>
          </div>
          <div class="col-md-6 mb-3">
            <label for="tipe" class="form-label">Tipe Tugas</label>
            <select class="form-select" id="tipe" name="tipe">
              <option value="tugas">Tugas</option>
              <option value="uts">UTS</option>
              <option value="uas">UAS</option>
            </select>
          </div>
        </div>

        <div class="mb-3">
          <label for="file" class="form-label">File Soal (opsional)</label>
          <input type="file" class="form-control" id="file" name="file" accept=".pdf,.doc,.docx,.zip">
          <small class="text-muted">Upload file soal (PDF, DOC, ZIP) maks. 10MB</small>
        </div>

        <div class="d-flex justify-content-between mt-4">
          <a href="/dosen/tugas" class="btn-outline-gradient">
            <i class="bi bi-arrow-left me-2"></i>Kembali
          </a>
          <button type="submit" class="btn-gradient">
            <i class="bi bi-save me-2"></i>Simpan Tugas
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>