<%- include('../partials/header-landing') %>

<style>
  .hero-detail {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 3rem 0;
    color: white;
    margin-bottom: 2rem;
  }
  .hero-detail h1 {
    font-size: 2.5rem;
    font-weight: 700;
  }
  .meta-info {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    margin-bottom: 2rem;
  }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #4a5568;
  }
  .meta-item i {
    font-size: 1.2rem;
    color: #2193b0;
    width: 24px;
  }
  .content-wrapper {
    background: white;
    border-radius: 1rem;
    padding: 2.5rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .gallery-item {
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s;
  }
  .gallery-item:hover {
    transform: scale(1.05);
  }
  .gallery-item img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .btn-back {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 600;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-back:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
</style>

<!-- Hero -->
<section class="hero-detail">
  <div class="container">
    <h1><%= aktivitas.judul %></h1>
    <p class="lead"><%= aktivitas.deskripsi %></p>
  </div>
</section>

<!-- Main Content -->
<div class="container mb-5">
  <div class="row">
    <div class="col-lg-8">
      <!-- Meta Info -->
      <div class="meta-info">
        <div class="row g-3">
          <div class="col-md-4">
            <div class="meta-item">
              <i class="bi bi-calendar-event"></i>
              <span><%= new Date(aktivitas.tanggal).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
            </div>
          </div>
          <div class="col-md-4">
            <div class="meta-item">
              <i class="bi bi-geo-alt"></i>
              <span><%= aktivitas.lokasi || 'Tidak disebutkan' %></span>
            </div>
          </div>
          <div class="col-md-4">
            <div class="meta-item">
              <i class="bi bi-tag"></i>
              <span>
                <% if (aktivitas.kategori === 'akademik') { %>📚 Akademik<% } %>
                <% if (aktivitas.kategori === 'himpunan') { %>👥 Himpunan<% } %>
                <% if (aktivitas.kategori === 'prestasi') { %>🏆 Prestasi<% } %>
                <% if (aktivitas.kategori === 'pengabdian') { %>🤝 Pengabdian<% } %>
              </span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Konten Utama -->
      <div class="content-wrapper">
        <div class="mb-4">
          <img src="<%= aktivitas.gambar || 'https://via.placeholder.com/1200x600?text=Kegiatan' %>" 
               alt="<%= aktivitas.judul %>" class="img-fluid rounded">
        </div>
        
        <div class="content-body">
          <%= aktivitas.konten || '<p>Belum ada deskripsi lengkap untuk kegiatan ini.</p>' %>
        </div>
      </div>
    </div>
    
    <!-- Sidebar -->
    <div class="col-lg-4">
      <!-- Informasi Tambahan -->
      <div class="card mb-4">
        <div class="card-header bg-light">
          <h5 class="mb-0">Informasi Kegiatan</h5>
        </div>
        <div class="card-body">
          <ul class="list-unstyled">
            <li class="mb-3"><i class="bi bi-check2-circle text-success me-2"></i>Kategori: <%= aktivitas.kategori %></li>
            <li class="mb-3"><i class="bi bi-check2-circle text-success me-2"></i>Dipublikasikan: <%= new Date(aktivitas.createdAt).toLocaleDateString('id-ID') %></li>
          </ul>
        </div>
      </div>
      
      <!-- Galeri (jika ada dokumentasi) -->
      <% if (aktivitas.dokumentasi && aktivitas.dokumentasi.length > 0) { %>
        <div class="card">
          <div class="card-header bg-light">
            <h5 class="mb-0">Galeri Dokumentasi</h5>
          </div>
          <div class="card-body">
            <div class="row g-2">
              <% aktivitas.dokumentasi.forEach(foto => { %>
                <div class="col-6">
                  <div class="gallery-item">
                    <img src="<%= foto %>" alt="Dokumentasi" class="img-fluid">
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>
      
      <!-- Tombol Kembali -->
      <div class="mt-4">
        <a href="/aktivitas" class="btn-back">
          <i class="bi bi-arrow-left me-2"></i>Kembali ke Aktivitas
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer-landing') %>