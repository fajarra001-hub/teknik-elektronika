<%- include('partials/header-landing') %>

<style>
  /* Hero section kecil untuk judul */
  .hero-detail {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 3rem 0;
    color: white;
    margin-bottom: 2rem;
  }
  .hero-detail h1 {
    font-size: 2.5rem;
    font-weight: 700;
  }

  /* Meta info (breadcrumb, tanggal, penulis) */
  .meta-info {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem 2rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    margin-bottom: 2rem;
  }
  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #4a5568;
  }
  .meta-item i {
    color: #2193b0;
    font-size: 1.1rem;
  }

  /* Konten berita */
  .content-wrapper {
    background: white;
    border-radius: 1rem;
    padding: 2.5rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .content-body {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #1e293b;
  }
  .content-body p {
    margin-bottom: 1.5rem;
  }
  .content-body img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
  .content-body h2, .content-body h3 {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  /* Gambar utama */
  .featured-image {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: 1rem;
    margin-bottom: 2rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
  }

  /* Tombol kembali */
  .btn-back {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }
  .btn-back:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }

  /* Breadcrumb */
  .breadcrumb-custom {
    background: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }
  .breadcrumb-custom a {
    color: #2193b0;
    text-decoration: none;
  }
  .breadcrumb-custom a:hover {
    text-decoration: underline;
  }
  .breadcrumb-custom span {
    color: #6c757d;
  }
</style>

<!-- Hero Section (judul) -->
<section class="hero-detail">
  <div class="container">
    <h1><%= berita.judul %></h1>
  </div>
</section>

<!-- Konten utama -->
<div class="container mb-5">
  <div class="row">
    <div class="col-lg-10 offset-lg-1">
      <!-- Breadcrumb -->
      <div class="breadcrumb-custom">
        <a href="/">Beranda</a> <i class="bi bi-chevron-right small"></i>
        <a href="/#berita">Berita</a> <i class="bi bi-chevron-right small"></i>
        <span><%= berita.judul %></span>
      </div>

      <!-- Meta info (tanggal & penulis) -->
      <div class="meta-info">
        <div class="row">
          <div class="col-md-6">
            <div class="meta-item">
              <i class="bi bi-calendar3"></i>
              <span><%= new Date(berita.tanggal).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
            </div>
          </div>
          <div class="col-md-6">
            <div class="meta-item">
              <i class="bi bi-person-circle"></i>
              <span><%= berita.penulis || 'Admin' %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Gambar utama (jika ada) -->
      <% if (berita.gambar) { %>
        <img src="<%= berita.gambar %>" alt="<%= berita.judul %>" class="featured-image">
      <% } %>

      <!-- Isi berita -->
      <div class="content-wrapper">
        <div class="content-body">
          <!-- Gunakan replace untuk mengubah newline menjadi <br> (jika teks biasa) -->
          <%= berita.isi.replace(/\n/g, '<br>') %>
        </div>
      </div>

      <!-- Tombol kembali -->
      <div class="text-center">
        <a href="/#berita" class="btn-back">
          <i class="bi bi-arrow-left"></i> Kembali ke Berita
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer-landing') %>