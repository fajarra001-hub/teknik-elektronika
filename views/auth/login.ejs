<%- include('../partials/header') %>

<style>
  .login-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
    padding: 2rem 0;
  }
  .login-card {
    border: none;
    border-radius: 1.5rem;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    overflow: hidden;
    backdrop-filter: blur(10px);
    background: rgba(255,255,255,0.95);
  }
  .login-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 2rem;
    text-align: center;
    border-bottom: none;
  }
  .login-header h4 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    color: white;
  }
  .login-header p {
    color: rgba(255,255,255,0.9);
    margin-bottom: 0;
  }
  .login-body {
    padding: 2.5rem;
  }
  .form-label {
    font-weight: 600;
    color: #1e293b;
  }
  .form-control {
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid #cbd5e1;
    transition: all 0.3s;
  }
  .form-control:focus {
    border-color: #2193b0;
    box-shadow: 0 0 0 0.2rem rgba(33,147,176,0.25);
  }
  .btn-login {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    border-radius: 0.75rem;
    padding: 0.75rem;
    font-weight: 600;
    font-size: 1.1rem;
    color: white;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-login:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.4);
  }
  .btn-login:active {
    transform: translateY(0);
  }
  .form-text {
    color: #475569;
    font-size: 0.85rem;
  }
  .alert {
    border-radius: 0.75rem;
  }
  @media (max-width: 768px) {
    .login-card {
      margin: 0 1rem;
    }
    .login-header h4 {
      font-size: 1.5rem;
    }
  }
</style>

<div class="login-page">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-6 col-lg-5">
        <div class="login-card">
          <div class="login-header">
            <h4>Selamat Datang</h4>
            <p>Dosen & Mahasiswa Teknik Elektronika</p>
          </div>
          <div class="login-body">
            <% if (error) { %>
              <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% } %>
            <form id="loginForm">
              <div class="mb-4">
                <label for="nim" class="form-label">NIM (Mahasiswa) / Email (Admin & Dosen)</label>
                <input type="text" class="form-control" id="nim" placeholder="Contoh: 24100200 atau admin@polidewa.ac.id" required>
                <div class="form-text">Mahasiswa cukup masukkan NIM, admin/dosen masukkan email lengkap.</div>
              </div>
              <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control" id="password" placeholder="••••••••" required>
              </div>
              <button type="submit" class="btn btn-login w-100">Login</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Firebase Client SDK -->
<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-auth.js"></script>
<script>
  // Firebase configuration
  const firebaseConfig = {
    apiKey: "AIzaSyDT4IVvCSpmYRxUiLVlJhGWFZtR9HwVbgw",
    authDomain: "elk-polidewa.firebaseapp.com",
    projectId: "elk-polidewa"
  };

  firebase.initializeApp(firebaseConfig);
  console.log('Firebase initialized');

  document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    console.log('Form submitted');

    const nim = document.getElementById('nim').value.trim();
    const password = document.getElementById('password').value;

    // Tentukan email: jika mengandung '@', anggap email; jika tidak, tambahkan domain mahasiswa
    const email = nim.includes('@') ? nim : nim + '@teknik-elektronika.ac.id';
    console.log('Email untuk login:', email);

    try {
      const userCredential = await firebase.auth().signInWithEmailAndPassword(email, password);
      console.log('Login Firebase sukses, UID:', userCredential.user.uid);

      const idToken = await userCredential.user.getIdToken();

      // Kirim token ke server via POST
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '/auth/login';
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'idToken';
      input.value = idToken;
      form.appendChild(input);
      document.body.appendChild(form);
      form.submit();
    } catch (error) {
      console.error('Error Firebase:', error);
      alert('Login gagal: ' + error.message);
    }
  });
</script>

<%- include('../partials/footer') %>