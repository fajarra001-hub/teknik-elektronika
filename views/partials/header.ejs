<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teknik Elektronika - Politeknik Dewantara</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #f8fafc;
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
        }
        /* Navbar dengan gradien biru laut */
        .navbar-custom {
            background: linear-gradient(135deg, #2193b0, #6dd5ed);
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            padding: 0.5rem 1rem;
        }
        .navbar-custom .navbar-brand,
        .navbar-custom .nav-link {
            color: white !important;
            font-weight: 500;
        }
        .navbar-custom .nav-link:hover {
            color: rgba(255,255,255,0.8) !important;
        }
        .navbar-custom .navbar-toggler-icon {
            filter: invert(1);
        }
        .navbar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .navbar-brand img {
            height: 70px; /* diperbesar */
            width: auto;
        }
        .separator {
            color: white;
            font-size: 2.5rem;
            font-weight: 200;
            opacity: 0.7;
            line-height: 1;
            margin: 0 5px;
        }
        .brand-text {
            font-size: 1.4rem;
            font-weight: 700;
            line-height: 1.3;
            color: white;
            text-decoration: none;
        }
        .brand-sub {
            font-size: 0.9rem;
            font-weight: 400;
            opacity: 0.9;
            display: block;
        }
        @media (max-width: 768px) {
            .navbar-brand img {
                height: 50px;
            }
            .separator {
                font-size: 2rem;
            }
            .brand-text {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container">
            <a class="navbar-brand" href="/dashboard">
                <!-- Logo dari link (bisa diganti dengan logo lokal jika ada) -->
                <img src="https://polidewa.ac.id/wp-content/uploads/2025/11/Desain-tanpa-judul-1.png" alt="Logo Politeknik Dewantara">
                <span class="separator">|</span>
                <span class="brand-text">
                    TEKNIK ELEKTRONIKA (D3)
                    <span class="brand-sub">by Politeknik Dewantara</span>
                </span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="bi bi-house-door"></i> Home</a>
                    </li>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> <%= user.nama || user.email %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/dashboard">Dashboard</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/auth/logout">Logout</a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/auth/login"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Konten halaman dimulai di sini (dibuka dengan div container) -->
    <div class="container mt-3">