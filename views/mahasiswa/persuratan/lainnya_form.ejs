<%- include('../../partials/header') %>

<style>
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 2rem;
    color: white;
  }
  .form-header h2 {
    font-weight: 700;
  }
  .form-body {
    padding: 2rem;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
</style>

<div class="container-fluid mt-4">
  <div class="form-card">
    <div class="form-header">
      <h2><i class="bi bi-envelope-plus me-2"></i>Ajukan Surat Lainnya</h2>
      <p class="mb-0">Isi formulir di bawah untuk mengajukan surat yang Anda perlukan</p>
    </div>
    <div class="form-body">
      <form method="POST" action="/mahasiswa/persuratan/lainnya">
        <div class="mb-3">
          <label for="jenisSurat" class="form-label fw-bold">Jenis Surat <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="jenisSurat" name="jenisSurat" placeholder="Contoh: Surat Rekomendasi, Surat Keterangan Lulus, dll." required>
        </div>
        <div class="mb-3">
          <label for="keperluan" class="form-label fw-bold">Keperluan <span class="text-danger">*</span></label>
          <textarea class="form-control" id="keperluan" name="keperluan" rows="3" placeholder="Jelaskan keperluan surat ini" required></textarea>
        </div>
        <div class="mb-3">
          <label for="keterangan" class="form-label fw-bold">Keterangan Tambahan (opsional)</label>
          <textarea class="form-control" id="keterangan" name="keterangan" rows="2" placeholder="Informasi lain yang perlu diketahui"></textarea>
        </div>
        <div class="d-flex gap-3 mt-4">
          <button type="submit" class="btn-gradient"><i class="bi bi-send me-2"></i>Ajukan</button>
          <a href="/mahasiswa/persuratan" class="btn-outline-gradient"><i class="bi bi-arrow-left me-2"></i>Kembali</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>