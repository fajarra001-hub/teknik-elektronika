<%- include('../../partials/header') %>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --danger-bg: #fee2e2;
    --danger-text: #991b1b;
    --info-bg: #dbeafe;
    --info-text: #1e40af;
    --secondary-bg: #e9ecef;
    --secondary-text: #495057;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== HEADER ===== */
  .persuratan-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .persuratan-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .persuratan-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    font-size: 2.2rem;
  }
  .persuratan-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1.1rem;
  }

  /* ===== TOMBOL GRADIEN ===== */
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
    text-decoration: none;
    display: inline-block;
    font-size: 0.95rem;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
    font-size: 0.95rem;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.3);
  }
  .btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  /* ===== ACTION BUTTONS ===== */
  .action-buttons {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  /* ===== TABEL MINIMALIS (seperti di MK) ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .table-responsive {
    border-radius: 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .surat-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .surat-table th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem 1rem;
    white-space: nowrap;
  }
  .surat-table td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border: 1px solid #dee2e6;
    font-size: 0.9rem;
  }
  .surat-table tbody tr:hover {
    background-color: #f2f2f2;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    border: 1px solid transparent;
  }
  .badge-pending {
    background: var(--warning-bg);
    color: var(--warning-text);
    border-color: #fde68a;
  }
  .badge-approved {
    background: var(--success-bg);
    color: var(--success-text);
    border-color: #a7f3d0;
  }
  .badge-rejected {
    background: var(--danger-bg);
    color: var(--danger-text);
    border-color: #fecaca;
  }
  .badge-cancelled {
    background: var(--secondary-bg);
    color: var(--secondary-text);
    border-color: #ced4da;
  }
  .badge-completed {
    background: var(--info-bg);
    color: var(--info-text);
    border-color: #bfdbfe;
  }

  /* ===== TOMBOL AKSI TABEL ===== */
  .btn-outline-primary {
    border: 1px solid var(--primary-start);
    color: var(--primary-start);
    background: transparent;
    border-radius: 50px;
    padding: 0.3rem 0.8rem;
    font-size: 0.8rem;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-outline-primary:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
  }
  .btn-outline-success {
    border: 1px solid #10b981;
    color: #10b981;
    background: transparent;
    border-radius: 50px;
    padding: 0.3rem 0.8rem;
    font-size: 0.8rem;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-outline-success:hover {
    background: #10b981;
    border-color: transparent;
    color: white;
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
    margin: 2rem 0;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1.5rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    margin-bottom: 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .persuratan-header h2 { font-size: 1.8rem; }
    .persuratan-header p { font-size: 1rem; }
    .surat-table th { font-size: 0.8rem; padding: 0.5rem; }
    .surat-table td { font-size: 0.85rem; padding: 0.5rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .persuratan-header h2 { font-size: 1.5rem; }
    .persuratan-header p { font-size: 0.9rem; }
    .action-buttons { flex-direction: column; }
    .btn-gradient, .btn-outline-gradient { text-align: center; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .persuratan-header h2 { font-size: 1.3rem; }
  }

  @media (max-width: 340px) {
    html { font-size: 12px; }
  }
</style>

<div class="container mt-4">
  <!-- HEADER DENGAN GRADIEN (tanpa tombol) -->
  <div class="persuratan-header">
    <h2><i class="bi bi-envelope-paper-fill me-2"></i>Persuratan</h2>
    <p class="mb-0">Kelola pengajuan surat aktif kuliah dan surat lainnya</p>
  </div>

  <!-- TOMBOL AKSI (dipisah dari header) -->
  <div class="action-buttons">
    <a href="/mahasiswa/persuratan/aktif-kuliah" class="btn-gradient btn-icon">
      <i class="bi bi-envelope-paper"></i> Surat Aktif Kuliah
    </a>
    <a href="/mahasiswa/persuratan/lainnya" class="btn-outline-gradient btn-icon">
      <i class="bi bi-envelope-plus"></i> Surat Lainnya
    </a>
  </div>

  <!-- TABEL DAFTAR SURAT -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table surat-table">
        <thead>
          <tr>
            <th>No</th>
            <th>Jenis Surat</th>
            <th>Nomor Surat</th>
            <th>Tanggal Pengajuan</th>
            <th>Semester</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (suratList.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <h4>Belum Ada Surat</h4>
                  <p>Ajukan surat pertama Anda dengan klik tombol di atas.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% suratList.forEach((surat, index) => { %>
            <tr>
              <td class="fw-semibold"><%= index + 1 %></td>
              <td><%= surat.jenis %></td>
              <td><%= surat.nomorSurat || '-' %></td>
              <td><%= new Date(surat.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
              <td><%= surat.semester || '-' %></td>
              <td>
                <% if (surat.status === 'pending') { %>
                  <span class="badge-status badge-pending"><i class="bi bi-hourglass-split"></i> Menunggu</span>
                <% } else if (surat.status === 'approved') { %>
                  <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i> Disetujui</span>
                <% } else if (surat.status === 'rejected') { %>
                  <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i> Ditolak</span>
                <% } else if (surat.status === 'cancelled') { %>
                  <span class="badge-status badge-cancelled"><i class="bi bi-x-octagon"></i> Dibatalkan</span>
                <% } else if (surat.status === 'completed') { %>
                  <span class="badge-status badge-completed"><i class="bi bi-check2-all"></i> Selesai</span>
                <% } %>
              </td>
              <td>
                <div class="d-flex gap-2">
                  <a href="/mahasiswa/persuratan/<%= surat.id %>" class="btn-outline-primary" title="Detail">
                    <i class="bi bi-eye"></i>
                  </a>
                  <% if (surat.status === 'completed' && surat.fileUrl) { %>
                    <a href="/mahasiswa/persuratan/<%= surat.id %>/download" class="btn-outline-success" target="_blank" title="Unduh">
                      <i class="bi bi-download"></i>
                    </a>
                  <% } %>
                </div>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>