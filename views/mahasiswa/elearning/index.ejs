<%- include('../../partials/header') %>

<%
  // Fungsi untuk mengekstrak ID file dari URL Google Drive (jika diperlukan nanti)
  const getFileIdFromUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px; /* basis desktop */
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== HEADER ===== */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.8rem;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1rem;
  }
  .btn-back {
    background: white;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    color: var(--primary-start);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    border: none;
    font-size: 0.95rem;
  }
  .btn-back:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* ===== COURSE CARD ===== */
  .course-card {
    background: white;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: 1px solid rgba(30,58,138,0.1);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .course-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 35px rgba(30,58,138,0.15);
    border-color: transparent;
  }
  .course-image {
    height: 140px;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 3.5rem;
    transition: all 0.3s;
  }
  .course-card:hover .course-image {
    transform: scale(1.02);
  }
  .course-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .course-code {
    color: var(--primary-start);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: var(--primary-light);
    display: inline-block;
    padding: 0.2rem 0.8rem;
    border-radius: 50px;
    align-self: flex-start;
  }
  .course-name {
    font-weight: 700;
    font-size: 1.2rem;
    color: #1e293b;
    margin: 0.75rem 0 0.5rem;
    line-height: 1.4;
  }
  .course-detail {
    color: #64748b;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    flex-grow: 1;
  }
  .course-detail i {
    color: var(--primary-start);
    width: 1.2rem;
  }
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
    text-decoration: none;
    display: inline-block;
    text-align: center;
    font-size: 0.95rem;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    background: white;
    border-radius: 1.5rem;
    padding: 4rem 2rem;
    text-align: center;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 1px solid rgba(30,58,138,0.1);
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1.5rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
  }
  .empty-state p {
    color: #6c757d;
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  /* ===== RESPONSIVE UNTUK HP ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header { padding: 1.5rem; }
    .page-header h2 { font-size: 1.6rem; }
    .page-header p { font-size: 0.95rem; }
    .btn-back { padding: 0.4rem 1.2rem; font-size: 0.9rem; }
    .course-image { height: 120px; font-size: 3rem; }
    .course-body { padding: 1.2rem; }
    .course-name { font-size: 1.1rem; }
    .empty-state { padding: 3rem 1.5rem; }
    .empty-state i { font-size: 3.5rem; }
    .empty-state h4 { font-size: 1.4rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h2 { font-size: 1.4rem; }
    .page-header p { font-size: 0.9rem; }
    .btn-back { padding: 0.3rem 1rem; font-size: 0.85rem; }
    .course-image { height: 100px; font-size: 2.5rem; }
    .course-body { padding: 1rem; }
    .course-code { font-size: 0.8rem; }
    .course-name { font-size: 1rem; }
    .course-detail { font-size: 0.85rem; }
    .btn-gradient { padding: 0.5rem 1rem; font-size: 0.9rem; }
    .empty-state { padding: 2.5rem 1rem; }
    .empty-state i { font-size: 3rem; }
    .empty-state h4 { font-size: 1.3rem; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .page-header h2 { font-size: 1.3rem; }
    .page-header p { font-size: 0.85rem; }
    .btn-back { padding: 0.3rem 0.8rem; }
    .course-image { height: 90px; font-size: 2.2rem; }
    .course-name { font-size: 0.95rem; }
    .course-detail { font-size: 0.8rem; }
    .btn-gradient { padding: 0.4rem 0.8rem; }
    .empty-state h4 { font-size: 1.2rem; }
  }

  @media (max-width: 340px) {
    html { font-size: 12px; }
    .page-header h2 { font-size: 1.2rem; }
    .page-header p { font-size: 0.8rem; }
    .course-image { height: 80px; font-size: 2rem; }
    .course-name { font-size: 0.9rem; }
    .btn-gradient { padding: 0.3rem 0.6rem; }
    .empty-state h4 { font-size: 1.1rem; }
  }
</style>

<div class="container mt-4"> <!-- Ubah container-fluid menjadi container agar selaras dengan navbar -->
  <!-- Header dengan gradien -->
  <div class="page-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-laptop"></i> ELK‑Learning</h2>
      <p class="mb-0">Mata kuliah yang Anda ambil dan materi perkuliahan</p>
    </div>
    <a href="/mahasiswa/dashboard" class="btn-back mt-2 mt-sm-0">
      <i class="bi bi-arrow-left"></i> Kembali ke Dashboard
    </a>
  </div>

  <!-- Daftar Mata Kuliah -->
  <div class="row g-4">
    <% if (mkList.length === 0) { %>
      <div class="col-12">
        <div class="empty-state">
          <i class="bi bi-book"></i>
          <h4>Belum Ada Mata Kuliah</h4>
          <p class="text-muted">Anda belum terdaftar di mata kuliah manapun.</p>
          <a href="/mahasiswa/akademik/krs" class="btn-gradient">
            <i class="bi bi-pencil-square me-2"></i>Buat KRS
          </a>
        </div>
      </div>
    <% } else { %>
      <% mkList.forEach(mk => { %>
        <div class="col-md-4">
          <div class="course-card">
            <div class="course-image">
              <i class="bi bi-journal-bookmark-fill"></i>
            </div>
            <div class="course-body">
              <span class="course-code"><%= mk.kode %></span>
              <h5 class="course-name"><%= mk.nama %></h5>
              <div class="course-detail">
                <p class="mb-1"><i class="bi bi-calendar me-1"></i> <%= mk.semester %></p>
                <p class="mb-0"><i class="bi bi-people me-1"></i> <%= mk.jumlahMahasiswa || 0 %> mahasiswa terdaftar</p>
              </div>
              <a href="/mahasiswa/elearning/mk/<%= mk.id %>" class="btn-gradient w-100">
                <i class="bi bi-eye me-2"></i>Lihat Detail
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<%- include('../../partials/footer') %>