<%- include('../../partials/header') %>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --info-bg: #dbeafe;
    --info-text: #1e40af;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== HEADER TUGAS ===== */
  .tugas-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .tugas-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .tugas-header h2 {
    font-weight: 700;
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .tugas-header p {
    font-size: 1rem;
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }
  .tugas-header .btn-light {
    background: white;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    color: var(--primary-start);
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    font-size: 0.95rem;
    text-decoration: none;
    display: inline-block;
  }
  .tugas-header .btn-light:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* ===== INFO CARD ===== */
  .info-card {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .info-card h5 {
    font-weight: 700;
    color: #1e293b;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
  }
  .info-card h5 i {
    color: var(--primary-start);
  }

  /* ===== DEADLINE CARD (VARIASI) ===== */
  .deadline-card {
    border-left: 5px solid #dc3545;
    background: #fff5f5;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    padding: 0.3rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .badge-belum {
    background: var(--warning-bg);
    color: var(--warning-text);
  }
  .badge-dikumpulkan {
    background: var(--success-bg);
    color: var(--success-text);
  }
  .badge-dinilai {
    background: var(--info-bg);
    color: var(--info-text);
  }

  /* ===== TOMBOL GRADIEN ===== */
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
    text-decoration: none;
    display: inline-block;
    text-align: center;
    font-size: 0.95rem;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }
  .btn-gradient.btn-sm {
    padding: 0.4rem 1.2rem;
    font-size: 0.85rem;
  }

  .btn-outline-gradient {
    background: transparent;
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
    font-size: 0.95rem;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
  }
  .btn-outline-gradient.btn-sm {
    padding: 0.4rem 1.2rem;
    font-size: 0.85rem;
  }

  /* ===== FILE INFO ===== */
  .file-info {
    background: #f8fafc;
    padding: 1rem;
    border-radius: 1rem;
    margin-top: 1rem;
    border: 1px solid #e2e8f0;
  }

  /* ===== NILAI DISPLAY ===== */
  .nilai-display {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--primary-start);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .tugas-header { padding: 1.5rem; }
    .tugas-header h2 { font-size: 1.6rem; }
    .tugas-header p { font-size: 0.95rem; }
    .tugas-header .btn-light { padding: 0.4rem 1.2rem; font-size: 0.9rem; }
    .info-card { padding: 1.2rem; }
    .info-card h5 { font-size: 1.1rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .tugas-header h2 { font-size: 1.4rem; }
    .btn-gradient, .btn-outline-gradient { padding: 0.5rem 1.5rem; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .tugas-header h2 { font-size: 1.2rem; }
  }
</style>

<div class="container mt-4">
  <!-- Header Tugas -->
  <div class="tugas-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2><%= tugas.judul %></h2>
      <p class="mb-0">
        <i class="bi bi-book me-2"></i><%= mk.kode %> - <%= mk.nama %> |
        <i class="bi bi-tag me-2"></i><%= tugas.tipe %>
      </p>
    </div>
    <a href="/mahasiswa/elearning/mk/<%= mk.id %>" class="btn-light mt-2 mt-sm-0">
      <i class="bi bi-arrow-left me-2"></i>Kembali ke MK
    </a>
  </div>

  <div class="row">
    <!-- Kolom Kiri: Detail Tugas -->
    <div class="col-lg-8">
      <div class="info-card">
        <h5><i class="bi bi-info-circle"></i> Deskripsi Tugas</h5>
        <p><%= tugas.deskripsi %></p>

        <% if (tugas.fileUrl) { %>
          <div class="file-info">
            <i class="bi bi-file-earmark-text me-2"></i>File Soal: 
            <a href="<%= tugas.fileUrl %>" target="_blank" class="btn-outline-gradient btn-sm ms-2">
              <i class="bi bi-download"></i> Unduh
            </a>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Kolom Kanan: Deadline & Status -->
    <div class="col-lg-4">
      <div class="info-card deadline-card">
        <h5><i class="bi bi-calendar-event"></i> Deadline</h5>
        <p class="mb-1"><%= new Date(tugas.deadline).toLocaleString('id-ID', { dateStyle: 'full', timeStyle: 'short' }) %></p>
        <% if (deadlineLewat) { %>
          <span class="badge-status" style="background:#fee2e2; color:#991b1b;">Deadline telah lewat</span>
        <% } else { %>
          <span class="badge-status" style="background:#d1fae5; color:#065f46;">Deadline masih aktif</span>
        <% } %>
      </div>

      <div class="info-card">
        <h5><i class="bi bi-check-circle"></i> Status Pengumpulan</h5>
        <% if (pengumpulan) { %>
          <span class="badge-status badge-dikumpulkan">Sudah dikumpulkan</span>
          <p class="mt-3"><i class="bi bi-clock me-2"></i><%= new Date(pengumpulan.submittedAt).toLocaleString('id-ID') %></p>
          <div class="file-info">
            <i class="bi bi-file-earmark me-2"></i>File Jawaban:
            <a href="<%= pengumpulan.fileUrl %>" target="_blank" class="btn-outline-gradient btn-sm ms-2">
              <i class="bi bi-eye"></i> Lihat
            </a>
          </div>
          <% if (pengumpulan.nilai !== null) { %>
            <hr>
            <h5 class="fw-bold mb-2">Nilai & Komentar</h5>
            <div class="nilai-display"><%= pengumpulan.nilai %></div>
            <% if (pengumpulan.komentar) { %>
              <p class="mt-2"><i class="bi bi-chat"></i> <%= pengumpulan.komentar %></p>
            <% } %>
          <% } %>
        <% } else { %>
          <span class="badge-status badge-belum">Belum dikumpulkan</span>
        <% } %>
      </div>

      <!-- Form Upload (hanya jika belum dikumpul dan deadline belum lewat) -->
      <% if (!pengumpulan && !deadlineLewat) { %>
        <div class="info-card">
          <h5><i class="bi bi-cloud-upload"></i> Kumpulkan Tugas</h5>
          <form method="POST" action="/mahasiswa/elearning/tugas/<%= tugas.id %>/kumpul" enctype="multipart/form-data">
            <div class="mb-3">
              <label for="file" class="form-label">Pilih file (PDF, DOC, ZIP)</label>
              <input type="file" class="form-control" id="file" name="file" accept=".pdf,.doc,.docx,.zip" required>
            </div>
            <button type="submit" class="btn-gradient w-100">Upload Tugas</button>
          </form>
        </div>
      <% } %>

      <!-- Tombol Hapus (jika sudah dikumpul dan deadline belum lewat) -->
      <% if (pengumpulan && !deadlineLewat) { %>
        <div class="info-card">
          <form method="POST" action="/mahasiswa/elearning/tugas/<%= tugas.id %>/hapus" onsubmit="return confirm('Yakin ingin menghapus pengumpulan?')">
            <button type="submit" class="btn btn-outline-danger w-100">
              <i class="bi bi-trash me-2"></i>Hapus Pengumpulan
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>