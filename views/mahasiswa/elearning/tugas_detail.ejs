<%- include('../../partials/header') %>

<style>
  .tugas-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-radius: 1rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
  }
  .tugas-header h2 {
    font-weight: 700;
  }
  .info-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .deadline-card {
    border-left: 5px solid #dc3545;
    background: #fff5f5;
  }
  .badge-status {
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
  }
  .badge-belum { background: #ffc107; color: #212529; }
  .badge-dikumpulkan { background: #28a745; color: white; }
  .badge-dinilai { background: #17a2b8; color: white; }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
  .file-info {
    background: #f8f9fa;
    padding: 1rem;
    border-radius: 0.75rem;
    margin-top: 1rem;
  }
  .nilai-display {
    font-size: 2.5rem;
    font-weight: 700;
    color: #2193b0;
  }
</style>

<div class="container-fluid mt-4">
  <!-- Header Tugas -->
  <div class="tugas-header d-flex justify-content-between align-items-center">
    <div>
      <h2><%= tugas.judul %></h2>
      <p class="mb-0 opacity-75">
        <i class="bi bi-book me-2"></i><%= mk.kode %> - <%= mk.nama %> |
        <i class="bi bi-tag me-2"></i><%= tugas.tipe %>
      </p>
    </div>
    <a href="/mahasiswa/elearning/mk/<%= mk.id %>" class="btn btn-light">
      <i class="bi bi-arrow-left me-2"></i>Kembali ke MK
    </a>
  </div>

  <div class="row">
    <!-- Kolom Kiri: Detail Tugas -->
    <div class="col-lg-8">
      <div class="info-card">
        <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Deskripsi Tugas</h5>
        <p><%= tugas.deskripsi %></p>

        <% if (tugas.fileUrl) { %>
          <div class="file-info">
            <i class="bi bi-file-earmark-text me-2"></i>File Soal: 
            <a href="<%= tugas.fileUrl %>" target="_blank" class="btn btn-sm btn-outline-primary ms-2">
              <i class="bi bi-download"></i> Unduh
            </a>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Kolom Kanan: Deadline & Status -->
    <div class="col-lg-4">
      <div class="info-card deadline-card">
        <h5 class="fw-bold mb-3"><i class="bi bi-calendar-event me-2"></i>Deadline</h5>
        <p class="mb-1"><%= new Date(tugas.deadline).toLocaleString('id-ID', { dateStyle: 'full', timeStyle: 'short' }) %></p>
        <% if (deadlineLewat) { %>
          <span class="badge bg-danger">Deadline telah lewat</span>
        <% } else { %>
          <span class="badge bg-success">Deadline masih aktif</span>
        <% } %>
      </div>

      <div class="info-card">
        <h5 class="fw-bold mb-3"><i class="bi bi-check-circle me-2"></i>Status Pengumpulan</h5>
        <% if (pengumpulan) { %>
          <span class="badge-status badge-dikumpulkan">Sudah dikumpulkan</span>
          <p class="mt-3"><i class="bi bi-clock me-2"></i><%= new Date(pengumpulan.submittedAt).toLocaleString('id-ID') %></p>
          <div class="file-info">
            <i class="bi bi-file-earmark me-2"></i>File Jawaban:
            <a href="<%= pengumpulan.fileUrl %>" target="_blank" class="btn btn-sm btn-outline-success ms-2">
              <i class="bi bi-eye"></i> Lihat
            </a>
          </div>
          <% if (pengumpulan.nilai !== null) { %>
            <hr>
            <h5 class="fw-bold mb-2">Nilai & Komentar</h5>
            <div class="nilai-display"><%= pengumpulan.nilai %></div>
            <% if (pengumpulan.komentar) { %>
              <p class="mt-2"><i class="bi bi-chat"></i> <%= pengumpulan.komentar %></p>
            <% } %>
          <% } %>
        <% } else { %>
          <span class="badge-status badge-belum">Belum dikumpulkan</span>
        <% } %>
      </div>

      <!-- Form Upload (hanya jika belum dikumpul dan deadline belum lewat) -->
      <% if (!pengumpulan && !deadlineLewat) { %>
        <div class="info-card">
          <h5 class="fw-bold mb-3"><i class="bi bi-cloud-upload me-2"></i>Kumpulkan Tugas</h5>
          <form method="POST" action="/mahasiswa/elearning/tugas/<%= tugas.id %>/kumpul" enctype="multipart/form-data">
            <div class="mb-3">
              <label for="file" class="form-label">Pilih file (PDF, DOC, ZIP)</label>
              <input type="file" class="form-control" id="file" name="file" accept=".pdf,.doc,.docx,.zip" required>
            </div>
            <button type="submit" class="btn-gradient w-100">Upload Tugas</button>
          </form>
        </div>
      <% } %>

      <!-- Tombol Hapus (jika sudah dikumpul dan deadline belum lewat) -->
      <% if (pengumpulan && !deadlineLewat) { %>
        <div class="info-card">
          <form method="POST" action="/mahasiswa/elearning/tugas/<%= tugas.id %>/hapus" onsubmit="return confirm('Yakin ingin menghapus pengumpulan?')">
            <button type="submit" class="btn btn-outline-danger w-100">
              <i class="bi bi-trash me-2"></i>Hapus Pengumpulan
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>