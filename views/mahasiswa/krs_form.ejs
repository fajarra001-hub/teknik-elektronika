<%- include('../partials/header') %>

<style>
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 2rem;
    color: white;
  }
  .form-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .form-body {
    padding: 2rem;
  }
  .course-item {
    border: 1px solid #e9ecef;
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin-bottom: 0.5rem;
    transition: all 0.2s;
  }
  .course-item:hover {
    background-color: #f8f9fa;
    border-color: #2193b0;
  }
  .course-item.selected {
    background-color: #e3f2fd;
    border-color: #2193b0;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .semester-options {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .semester-option {
    border: 1px solid #dee2e6;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .semester-option:hover {
    background-color: #e9ecef;
  }
  .semester-option.active {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    border-color: transparent;
  }
  .search-box {
    margin-bottom: 1.5rem;
  }
</style>

<div class="container-fluid mt-4">
  <div class="form-card">
    <div class="form-header">
      <h2>Buat KRS Baru</h2>
      <p class="mb-0">Pilih mata kuliah untuk semester yang akan diambil</p>
    </div>
    <div class="form-body">
      <form id="krsForm" method="POST" action="/mahasiswa/akademik/krs">
        <div class="mb-4">
          <label class="form-label fw-bold">Pilih Semester</label>
          <div class="semester-options" id="semesterOptions">
            <div class="semester-option" data-value="Ganjil 2024/2025">Ganjil 2024/2025</div>
            <div class="semester-option" data-value="Genap 2024/2025">Genap 2024/2025</div>
            <div class="semester-option" data-value="Ganjil 2025/2026">Ganjil 2025/2026</div>
            <div class="semester-option" data-value="Genap 2025/2026">Genap 2025/2026</div>
          </div>
          <input type="hidden" name="semester" id="selectedSemester" required>
        </div>

        <div class="mb-4">
          <label class="form-label fw-bold">Cari Mata Kuliah</label>
          <input type="text" class="form-control search-box" id="searchCourse" placeholder="Ketik kode atau nama mata kuliah...">
        </div>

        <div class="mb-4">
          <label class="form-label fw-bold">Daftar Mata Kuliah</label>
          <div id="courseList">
            <% if (courses && courses.length > 0) { %>
              <% courses.forEach(course => { %>
                <div class="course-item" data-id="<%= course.id %>" data-kode="<%= course.kode %>" data-nama="<%= course.nama %>" data-sks="<%= course.sks %>">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <strong><%= course.kode %></strong> - <%= course.nama %>
                      <span class="badge bg-secondary ms-2"><%= course.sks %> SKS</span>
                    </div>
                    <div class="form-check">
                      <input class="form-check-input course-checkbox" type="checkbox" value="<%= course.id %>">
                    </div>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="alert alert-warning">Tidak ada mata kuliah tersedia.</div>
            <% } %>
          </div>
        </div>

        <div class="mb-4">
          <div class="d-flex justify-content-between align-items-center">
            <span class="fw-bold">Total SKS: <span id="totalSks">0</span></span>
            <span class="text-muted">Maksimal 24 SKS</span>
          </div>
        </div>

        <input type="hidden" name="courses" id="selectedCourses" required>

        <div class="d-flex gap-3">
          <button type="submit" class="btn-gradient" id="submitBtn" disabled>
            <i class="bi bi-save me-2"></i>Simpan KRS
          </button>
          <a href="/mahasiswa/akademik/krs" class="btn btn-outline-secondary">Batal</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // Pilih semester
  const semesterOptions = document.querySelectorAll('.semester-option');
  const selectedSemester = document.getElementById('selectedSemester');
  semesterOptions.forEach(opt => {
    opt.addEventListener('click', function() {
      semesterOptions.forEach(o => o.classList.remove('active'));
      this.classList.add('active');
      selectedSemester.value = this.dataset.value;
    });
  });

  // Pencarian mata kuliah
  const searchInput = document.getElementById('searchCourse');
  const courseItems = document.querySelectorAll('.course-item');
  searchInput.addEventListener('keyup', function() {
    const keyword = this.value.toLowerCase();
    courseItems.forEach(item => {
      const kode = item.dataset.kode.toLowerCase();
      const nama = item.dataset.nama.toLowerCase();
      if (kode.includes(keyword) || nama.includes(keyword)) {
        item.style.display = 'block';
      } else {
        item.style.display = 'none';
      }
    });
  });

  // Hitung total SKS
  const checkboxes = document.querySelectorAll('.course-checkbox');
  const totalSpan = document.getElementById('totalSks');
  const selectedCoursesInput = document.getElementById('selectedCourses');
  const submitBtn = document.getElementById('submitBtn');

  function updateTotal() {
    let total = 0;
    const selected = [];
    checkboxes.forEach(cb => {
      if (cb.checked) {
        const sks = parseInt(cb.closest('.course-item').dataset.sks);
        total += sks;
        selected.push(cb.value);
      }
    });
    totalSpan.textContent = total;
    selectedCoursesInput.value = JSON.stringify(selected);

    // Aktifkan tombol jika semester terpilih dan ada mata kuliah dipilih
    if (selectedSemester.value && selected.length > 0) {
      submitBtn.disabled = false;
    } else {
      submitBtn.disabled = true;
    }
  }

  checkboxes.forEach(cb => cb.addEventListener('change', updateTotal));

  // Update jika semester berubah
  semesterOptions.forEach(opt => {
    opt.addEventListener('click', function() {
      updateTotal();
    });
  });

  // Styling item yang dipilih
  checkboxes.forEach(cb => {
    cb.addEventListener('change', function() {
      const item = this.closest('.course-item');
      if (this.checked) {
        item.classList.add('selected');
      } else {
        item.classList.remove('selected');
      }
    });
  });
</script>

<%- include('../partials/footer') %>