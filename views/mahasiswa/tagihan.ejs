<%- include('../partials/header') %>

<style>
  .profile-card {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 10px 30px rgba(33,147,176,0.3);
  }
  .stat-card {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    transition: transform 0.3s, box-shadow 0.3s;
    height: 100%;
  }
  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(33,147,176,0.15);
  }
  .stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }
  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.2;
  }
  .stat-label {
    color: #64748b;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .menu-card {
    border: none;
    border-radius: 1rem;
    transition: all 0.3s;
    overflow: hidden;
    background: white;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    height: 100%;
  }
  .menu-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(33,147,176,0.15);
  }
  .menu-icon {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    margin: 0 auto 1rem;
  }
  .menu-title {
    font-weight: 700;
    color: #1e293b;
  }
  .menu-desc {
    color: #64748b;
    font-size: 0.9rem;
  }
  .tagihan-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow: hidden;
  }
  .tagihan-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    padding: 1rem 1.5rem;
  }
  .tagihan-item {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #e9ecef;
  }
  .tagihan-item:last-child {
    border-bottom: none;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    display: inline-block;
    text-decoration: none;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
</style>

<div class="container-fluid mt-4">
  <!-- Notifikasi Upload Sukses -->
  <% if (uploadSuccess) { %>
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>File KRS berhasil diupload ke Google Drive!
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Profile Card -->
  <div class="profile-card">
    <div class="d-flex align-items-center">
      <div class="flex-shrink-0">
        <i class="bi bi-person-circle fs-1"></i>
      </div>
      <div class="flex-grow-1 ms-3">
        <h2 class="fw-bold mb-1">Selamat Datang, <%= user.nama || user.email %>!</h2>
        <p class="mb-0 opacity-75">
          <i class="bi bi-qr-code me-2"></i>NIM: <%= user.nim || '-' %> 
          <span class="mx-3">|</span>
          <i class="bi bi-envelope me-2"></i><%= user.email %>
        </p>
      </div>
    </div>
  </div>

  <!-- Statistik Cards -->
  <div class="row g-4 mb-5">
    <div class="col-md-3">
      <div class="stat-card text-center">
        <div class="stat-icon bg-primary bg-opacity-10 text-primary mx-auto">
          <i class="bi bi-book"></i>
        </div>
        <div class="stat-value"><%= totalSks || 0 %></div>
        <div class="stat-label">SKS Diambil</div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stat-card text-center">
        <div class="stat-icon bg-success bg-opacity-10 text-success mx-auto">
          <i class="bi bi-calendar-week"></i>
        </div>
        <div class="stat-value"><%= semesterSekarang || 'Genap 2025/2026' %></div>
        <div class="stat-label">Semester Aktif</div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stat-card text-center">
        <div class="stat-icon bg-info bg-opacity-10 text-info mx-auto">
          <i class="bi bi-bar-chart-steps"></i>
        </div>
        <div class="stat-value"><%= pertemuanRata || 0 %> / 16</div>
        <div class="stat-label">Pertemuan Terkini</div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="stat-card text-center">
        <div class="stat-icon bg-warning bg-opacity-10 text-warning mx-auto">
          <i class="bi bi-file-earmark-text"></i>
        </div>
        <div class="stat-value"><%= tugasAktif.length %></div>
        <div class="stat-label">Tugas Aktif</div>
      </div>
    </div>
  </div>

  <!-- Tagihan SPP -->
  <div class="row mb-5">
    <div class="col-12">
      <div class="tagihan-card">
        <div class="tagihan-header d-flex justify-content-between align-items-center">
          <h5 class="fw-bold mb-0"><i class="bi bi-cash-coin me-2"></i>Tagihan SPP</h5>
          <a href="/mahasiswa/tagihan" class="btn btn-sm btn-light">Lihat Semua</a>
        </div>
        <div class="card-body p-0">
          <% if (tagihan.length === 0) { %>
            <div class="p-4 text-center text-muted">
              <i class="bi bi-check-circle-fill fs-2 text-success d-block mb-2"></i>
              <p>Tidak ada tagihan aktif.</p>
            </div>
          <% } else { %>
            <% tagihan.slice(0, 3).forEach(t => { %>
              <div class="tagihan-item d-flex justify-content-between align-items-center">
                <div>
                  <strong><%= t.semester %></strong>
                  <p class="mb-0 text-muted small">Jatuh tempo: <%= t.jatuhTempo ? new Date(t.jatuhTempo).toLocaleDateString('id-ID') : '-' %></p>
                </div>
                <div class="text-end">
                  <span class="fw-bold fs-5">Rp <%= new Intl.NumberFormat('id-ID').format(t.jumlah) %></span><br>
                  <span class="badge bg-<%= t.status === 'lunas' ? 'success' : 'warning' %>">
                    <%= t.status %>
                  </span>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Menu Akses Cepat -->
  <h4 class="fw-bold mb-3">Layanan Mahasiswa</h4>
  <div class="row g-4">
    <!-- Akademik -->
    <div class="col-md-4">
      <a href="/mahasiswa/akademik" class="text-decoration-none">
        <div class="menu-card p-3 text-center">
          <div class="menu-icon bg-primary bg-opacity-10 text-primary">
            <i class="bi bi-journal-bookmark-fill"></i>
          </div>
          <h6 class="menu-title">Akademik</h6>
          <p class="menu-desc small">KRS, KHS, Transkrip, Kalender</p>
        </div>
      </a>
    </div>
    <!-- ELK-Learning -->
    <div class="col-md-4">
      <a href="/mahasiswa/elearning" class="text-decoration-none">
        <div class="menu-card p-3 text-center">
          <div class="menu-icon bg-success bg-opacity-10 text-success">
            <i class="bi bi-laptop"></i>
          </div>
          <h6 class="menu-title">ELK-Learning</h6>
          <p class="menu-desc small">Jadwal kuliah, tugas, kumpul tugas</p>
        </div>
      </a>
    </div>
    <!-- ELK-Magang -->
    <div class="col-md-4">
      <a href="/mahasiswa/magang" class="text-decoration-none">
        <div class="menu-card p-3 text-center">
          <div class="menu-icon bg-warning bg-opacity-10 text-warning">
            <i class="bi bi-briefcase"></i>
          </div>
          <h6 class="menu-title">ELK-Magang</h6>
          <p class="menu-desc small">Logbook, upload nilai, permohonan seminar</p>
        </div>
      </a>
    </div>
    <!-- Persuratan -->
    <div class="col-md-4">
      <a href="/mahasiswa/persuratan" class="text-decoration-none">
        <div class="menu-card p-3 text-center">
          <div class="menu-icon bg-info bg-opacity-10 text-info">
            <i class="bi bi-envelope-paper"></i>
          </div>
          <h6 class="menu-title">Persuratan</h6>
          <p class="menu-desc small">Surat aktif kuliah</p>
        </div>
      </a>
    </div>
    <!-- Tracer Study -->
    <div class="col-md-4">
      <a href="/mahasiswa/tracer" class="text-decoration-none">
        <div class="menu-card p-3 text-center">
          <div class="menu-icon bg-danger bg-opacity-10 text-danger">
            <i class="bi bi-bar-chart-line"></i>
          </div>
          <h6 class="menu-title">Tracer Study</h6>
          <p class="menu-desc small">Isi survei keberkerjaan</p>
        </div>
      </a>
    </div>
    <!-- Biodata -->
    <div class="col-md-4">
      <a href="/mahasiswa/biodata" class="text-decoration-none">
        <div class="menu-card p-3 text-center">
          <div class="menu-icon bg-secondary bg-opacity-10 text-secondary">
            <i class="bi bi-person-circle"></i>
          </div>
          <h6 class="menu-title">Biodata</h6>
          <p class="menu-desc small">Profil, foto, ubah password</p>
        </div>
      </a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>