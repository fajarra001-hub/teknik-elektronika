<%- include('../partials/header') %>

<%
  // ========== DEFAULT VALUES UNTUK MENCEGAH ERROR ==========
  if (typeof tagihan === 'undefined') tagihan = [];
  if (typeof totalTagihan === 'undefined') totalTagihan = 0;
  if (typeof totalLunas === 'undefined') totalLunas = 0;
  if (typeof sisaTagihan === 'undefined') sisaTagihan = 0;
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== HEADER ===== */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    font-size: 2.2rem;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1.1rem;
  }
  .page-header .btn-light {
    border-radius: 50px;
    padding: 0.6rem 1.5rem;
    font-weight: 500;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    background: white;
    color: var(--primary-start);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .page-header .btn-light:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* ===== SUMMARY CARD (hanya total tagihan) ===== */
  .summary-card {
    background: white;
    border-radius: 1.5rem;
    padding: 2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    margin-bottom: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
    transition: transform 0.3s, box-shadow 0.3s;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .summary-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 35px rgba(30,58,138,0.15);
  }
  .summary-icon {
    width: 60px;
    height: 60px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.2rem;
    background: var(--primary-light);
    color: var(--primary-start);
  }
  .summary-content {
    flex: 1;
  }
  .summary-label {
    color: #64748b;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .summary-value {
    font-weight: 700;
    font-size: 2.2rem;
    color: #1e293b;
    line-height: 1.2;
  }

  /* ===== TABEL MINIMALIS (seperti di MK) ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(30,58,138,0.1);
    transition: box-shadow 0.3s;
    padding: 1.5rem;
  }
  .table-container:hover {
    box-shadow: 0 20px 35px rgba(30,58,138,0.15);
  }
  .table-responsive {
    border-radius: 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .table-tagihan {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .table-tagihan th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem 1rem;
    white-space: nowrap;
  }
  .table-tagihan td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border: 1px solid #dee2e6;
    font-size: 0.95rem;
  }
  .table-tagihan tbody tr:hover {
    background-color: #f2f2f2;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    border: 1px solid transparent;
  }
  .badge-lunas {
    background: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
  }
  .badge-belum {
    background: #fef3c7;
    color: #92400e;
    border-color: #fde68a;
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
    margin: 2rem 0;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1.5rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    margin-bottom: 0;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header h2 { font-size: 1.8rem; }
    .page-header p { font-size: 1rem; }
    .summary-card { padding: 1.5rem; }
    .summary-icon { width: 50px; height: 50px; font-size: 1.8rem; }
    .summary-value { font-size: 1.8rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h2 { font-size: 1.5rem; }
    .page-header p { font-size: 0.9rem; }
    .summary-card { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .table-tagihan th { font-size: 0.8rem; padding: 0.5rem; }
    .table-tagihan td { font-size: 0.85rem; padding: 0.5rem; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .page-header h2 { font-size: 1.3rem; }
    .table-tagihan th { font-size: 0.75rem; }
  }

  @media (max-width: 340px) {
    html { font-size: 12px; }
  }
</style>

<div class="container mt-4">
  <!-- Header dengan tombol kembali -->
  <div class="page-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-cash-coin me-2"></i>Tagihan SPP</h2>
      <p class="mb-0">Riwayat tagihan SPP per semester</p>
    </div>
    <a href="javascript:history.back()" class="btn-light mt-2 mt-sm-0">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <!-- Ringkasan Total Tagihan (hanya total tagihan yang belum lunas) -->
  <div class="summary-card">
    <div class="summary-icon">
      <i class="bi bi-hourglass-split"></i>
    </div>
    <div class="summary-content">
      <div class="summary-label">Total Tagihan (Belum Lunas)</div>
      <div class="summary-value">
        Rp <%= new Intl.NumberFormat('id-ID').format(totalTagihan) %>
      </div>
    </div>
  </div>

  <!-- Tabel Tagihan -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table table-tagihan">
        <thead>
          <tr>
            <th>Semester</th>
            <th>Jumlah</th>
            <th>Jatuh Tempo</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (tagihan.length === 0) { %>
            <tr>
              <td colspan="4" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <h4>Tidak Ada Tagihan</h4>
                  <p class="text-muted">Tidak ada tagihan SPP yang perlu dibayar saat ini.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% tagihan.forEach(t => { %>
              <tr>
                <td><strong><%= t.semester %></strong></td>
                <td>Rp <%= new Intl.NumberFormat('id-ID').format(t.jumlah) %></td>
                <td>
                  <%= t.jatuhTempo ? new Date(t.jatuhTempo).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) : '-' %>
                </td>
                <td>
                  <% if (t.status === 'lunas') { %>
                    <span class="badge-status badge-lunas"><i class="bi bi-check-circle"></i> Lunas</span>
                  <% } else { %>
                    <span class="badge-status badge-belum"><i class="bi bi-hourglass-split"></i> Belum Lunas</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>