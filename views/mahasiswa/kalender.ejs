<%- include('../../partials/header') %>

<style>
  .kalender-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-radius: 1rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
  }
  .kalender-header h2 {
    font-weight: 700;
  }
  .event-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    margin-bottom: 1.5rem;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .event-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(33,147,176,0.15);
  }
  .event-date {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    padding: 1rem;
    text-align: center;
    font-weight: 700;
    min-width: 100px;
  }
  .event-date .day {
    font-size: 2rem;
    line-height: 1.2;
  }
  .event-date .month {
    font-size: 1rem;
    text-transform: uppercase;
    opacity: 0.9;
  }
  .event-content {
    padding: 1rem 1.5rem;
    flex: 1;
  }
  .event-title {
    font-weight: 700;
    font-size: 1.2rem;
    color: #1e293b;
    margin-bottom: 0.5rem;
  }
  .event-desc {
    color: #64748b;
    font-size: 0.9rem;
    margin-bottom: 0;
  }
  .event-type {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
    background: #e9ecef;
    color: #495057;
  }
  .event-type-seminar { background: #28a745; color: white; }
  .event-type-libur { background: #ffc107; color: #212529; }
  .event-type-wisuda { background: #dc3545; color: white; }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .empty-state {
    background: white;
    border-radius: 1rem;
    padding: 3rem;
    text-align: center;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
</style>

<div class="container-fluid mt-4">
  <!-- Header -->
  <div class="kalender-header d-flex justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-calendar-event me-2"></i>Kalender Akademik</h2>
      <p class="mb-0 opacity-75">Jadwal penting, libur, dan kegiatan akademik</p>
    </div>
    <a href="/mahasiswa/akademik" class="btn btn-light">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <!-- Daftar Event -->
  <% if (events.length === 0) { %>
    <div class="empty-state">
      <i class="bi bi-calendar-x fs-1 text-muted d-block mb-3"></i>
      <h5 class="fw-bold">Belum Ada Jadwal</h5>
      <p class="text-muted">Belum ada event yang tercatat dalam kalender akademik.</p>
    </div>
  <% } else { %>
    <div class="event-list">
      <% events.forEach(e => { %>
        <% 
          const date = new Date(e.tanggal);
          const day = date.getDate();
          const month = date.toLocaleDateString('id-ID', { month: 'short' });
          const year = date.getFullYear();
        %>
        <div class="event-card d-flex flex-wrap">
          <div class="event-date">
            <div class="day"><%= day %></div>
            <div class="month"><%= month %> <%= year %></div>
          </div>
          <div class="event-content">
            <h5 class="event-title"><%= e.judul %></h5>
            <p class="event-desc"><%= e.deskripsi || 'Tidak ada deskripsi' %></p>
            <div class="mt-2">
              <span class="event-type <%= e.tipe ? 'event-type-' + e.tipe : '' %>">
                <%= e.tipe || 'umum' %>
              </span>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../../partials/footer') %>