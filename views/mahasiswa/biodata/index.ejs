<%- include('../../partials/header') %>

<style>
  .biodata-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-radius: 1rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
  }
  .biodata-header h2 {
    font-weight: 700;
  }
  .profile-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow: hidden;
  }
  .profile-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid #2193b0;
    margin: 0 auto 1rem;
  }
  .avatar-circle {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    font-weight: 600;
    margin: 0 auto 1rem;
  }
  .info-item {
    padding: 1rem;
    border-bottom: 1px solid #e9ecef;
  }
  .info-item:last-child {
    border-bottom: none;
  }
  .info-label {
    font-weight: 600;
    color: #1e293b;
    width: 120px;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
</style>

<%
  // Fungsi untuk mengekstrak file ID dari URL Google Drive
  const getFileIdFromUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
  const fileId = user.foto ? getFileIdFromUrl(user.foto) : null;
%>

<div class="container-fluid mt-4">
  <!-- Header -->
  <div class="biodata-header d-flex justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-person-circle me-2"></i>Biodata Saya</h2>
      <p class="mb-0 opacity-75">Informasi pribadi mahasiswa</p>
    </div>
    <a href="/mahasiswa/dashboard" class="btn btn-light">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <!-- Profile Card -->
  <div class="profile-card">
    <div class="row g-0">
      <div class="col-md-4 text-center p-4 bg-light">
        <% if (fileId) { %>
          <img src="https://drive.google.com/thumbnail?id=<%= fileId %>&sz=w300" 
               alt="foto" 
               class="profile-avatar"
               onerror="this.onerror=null; this.src='https://drive.google.com/uc?export=view&id=<%= fileId %>';">
        <% } else if (user.foto) { %>
          <!-- Fallback jika URL tidak bisa diekstrak -->
          <img src="<%= user.foto %>" alt="foto" class="profile-avatar">
        <% } else { %>
          <div class="avatar-circle">
            <%= (user.nama || '?').charAt(0).toUpperCase() %>
          </div>
        <% } %>
        <h5 class="fw-bold mt-2"><%= user.nama %></h5>
        <p class="text-muted"><%= user.nim || '-' %></p>
        <a href="/mahasiswa/biodata/edit" class="btn-gradient btn-sm">
          <i class="bi bi-pencil me-2"></i>Edit Profil
        </a>
      </div>
      <div class="col-md-8">
        <div class="info-item d-flex">
          <span class="info-label">NIM</span>
          <span>: <%= user.nim || '-' %></span>
        </div>
        <div class="info-item d-flex">
          <span class="info-label">Nama</span>
          <span>: <%= user.nama || '-' %></span>
        </div>
        <div class="info-item d-flex">
          <span class="info-label">Email</span>
          <span>: <%= user.email || '-' %></span>
        </div>
        <div class="info-item d-flex">
          <span class="info-label">No. HP</span>
          <span>: <%= user.noHp || '-' %></span>
        </div>
        <div class="info-item d-flex">
          <span class="info-label">Program Studi</span>
          <span>: Teknik Elektronika</span>
        </div>
        <div class="info-item d-flex">
          <span class="info-label">Angkatan</span>
          <span>: <%= user.nim && user.nim.length >= 2 ? '20' + user.nim.substring(0,2) : '-' %></span>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>