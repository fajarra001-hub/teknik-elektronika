<%- include('../partials/header') %>

<style>
  .detail-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
  }
  .detail-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 2rem;
    color: white;
  }
  .detail-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .detail-body {
    padding: 2rem;
  }
  .info-table th {
    width: 200px;
    font-weight: 600;
    color: #1e293b;
  }
  .badge-status {
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .badge-pending { background: #ffc107; color: #212529; }
  .badge-approved { background: #28a745; color: white; }
  .badge-rejected { background: #dc3545; color: white; }
  .mk-table th {
    background: #f8f9fa;
    font-weight: 600;
  }
  .btn-action {
    padding: 0.5rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    transition: all 0.3s;
  }
</style>

<div class="container-fluid mt-4">
  <div class="detail-card">
    <div class="detail-header">
      <div class="d-flex justify-content-between align-items-center">
        <h2>Detail KRS</h2>
        <span class="badge-status 
          <%= krs.status === 'pending' ? 'badge-pending' : '' %>
          <%= krs.status === 'approved' ? 'badge-approved' : '' %>
          <%= krs.status === 'rejected' ? 'badge-rejected' : '' %>">
          <%= krs.status %>
        </span>
      </div>
      <p class="mb-0">Semester: <%= krs.semester || '-' %></p>
    </div>
    <div class="detail-body">
      <h5 class="fw-bold mb-3">Data Mahasiswa</h5>
      <table class="table table-borderless info-table">
        <tr>
          <th>NIM</th>
          <td><%= user.nim || '-' %></td>
        </tr>
        <tr>
          <th>Nama</th>
          <td><%= user.nama || '-' %></td>
        </tr>
        <tr>
          <th>Program Studi</th>
          <td>Teknik Elektronika</td>
        </tr>
      </table>

      <hr>

      <h5 class="fw-bold mb-3">Mata Kuliah yang Direncanakan</h5>
      <div class="table-responsive">
        <table class="table table-bordered mk-table">
          <thead>
            <tr>
              <th>No</th>
              <th>Kode</th>
              <th>Nama Mata Kuliah</th>
              <th>SKS</th>
            </tr>
          </thead>
          <tbody>
            <% if (mkList && mkList.length > 0) { %>
              <% mkList.forEach((mk, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= mk.kode || '-' %></td>
                <td><%= mk.nama || '-' %></td>
                <td><%= mk.sks || '-' %></td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center">Tidak ada mata kuliah</td>
              </tr>
            <% } %>
          </tbody>
          <tfoot>
            <tr>
              <th colspan="3" class="text-end">Total SKS</th>
              <th>
                <% 
                  let total = 0;
                  if (mkList) mkList.forEach(m => total += (m.sks || 0));
                %>
                <%= total %>
              </th>
            </tr>
          </tfoot>
        </table>
      </div>

      <hr>

      <h5 class="fw-bold mb-3">File KRS</h5>
      <% if (krs.driveFileLink) { %>
        <a href="<%= krs.driveFileLink %>" target="_blank" class="btn btn-outline-info">
          <i class="bi bi-file-earmark-pdf"></i> Lihat File KRS
        </a>
      <% } else { %>
        <p class="text-muted">Belum ada file yang diupload.</p>
      <% } %>

      <div class="mt-4">
        <a href="/mahasiswa/akademik/krs" class="btn btn-outline-secondary btn-action">
          <i class="bi bi-arrow-left me-2"></i>Kembali
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>