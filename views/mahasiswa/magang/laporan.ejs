<%- include('../../partials/header') %>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --danger-bg: #fee2e2;
    --danger-text: #991b1b;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== HEADER ===== */
  .laporan-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .laporan-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .laporan-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    font-size: 2.2rem;
  }
  .laporan-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1.1rem;
  }
  .laporan-header .btn-light {
    background: white;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    color: var(--primary-start);
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    transition: all 0.3s;
    font-size: 0.95rem;
    text-decoration: none;
    display: inline-block;
  }
  .laporan-header .btn-light:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* ===== CARD LAPORAN ===== */
  .card-laporan {
    border: none;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    transition: all 0.3s;
    overflow: hidden;
    background: white;
    border: 1px solid rgba(30,58,138,0.1);
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .card-laporan:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 35px rgba(30,58,138,0.15);
  }
  .card-header-laporan {
    background: linear-gradient(135deg, var(--primary-light), rgba(59,130,246,0.1));
    border-bottom: 1px solid rgba(30,58,138,0.1);
    padding: 1rem 1.25rem;
    font-weight: 600;
    color: var(--primary-dark);
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    font-size: 0.8rem;
    padding: 0.35rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .badge-pending {
    background: var(--warning-bg);
    color: var(--warning-text);
  }
  .badge-approved {
    background: var(--success-bg);
    color: var(--success-text);
  }
  .badge-rejected {
    background: var(--danger-bg);
    color: var(--danger-text);
  }
  .badge-secondary {
    background: #e9ecef;
    color: #495057;
  }

  /* ===== TOMBOL GRADIEN ===== */
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 500;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(30,58,138,0.3);
  }

  /* ===== FILE INFO ===== */
  .file-info {
    background-color: #f8fafc;
    border-left: 4px solid var(--primary-start);
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    transition: all 0.2s;
  }
  .file-info:hover {
    background-color: #eef2f7;
  }
  .file-link {
    display: inline-block;
    max-width: 200px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    vertical-align: middle;
    color: var(--primary-start);
    font-weight: 500;
    text-decoration: none;
  }
  .file-link:hover {
    text-decoration: underline;
    color: var(--primary-dark);
  }
  .file-size {
    font-size: 0.75rem;
    color: #6c757d;
    margin-left: 2rem;
  }

  /* ===== REJECTION REASON ===== */
  .rejection-reason {
    background-color: var(--danger-bg);
    border: 1px solid #f5c6cb;
    border-radius: 0.75rem;
    padding: 0.75rem;
    color: var(--danger-text);
    font-size: 0.9rem;
    margin-top: 1rem;
  }

  /* ===== KOMENTAR ===== */
  .komentar-section {
    margin-top: 1rem;
    padding-top: 0.5rem;
    border-top: 1px dashed #dee2e6;
  }
  .komentar-item {
    background-color: #f8fafc;
    border-left: 3px solid var(--primary-start);
    border-radius: 0.75rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 0.5rem;
  }
  .komentar-item .penulis {
    font-weight: 600;
    color: #1e293b;
  }
  .komentar-item .tanggal {
    font-size: 0.7rem;
    color: #6c757d;
  }
  .komentar-item p {
    margin-top: 0.3rem;
    margin-bottom: 0;
    font-size: 0.9rem;
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    background-color: #f8fafc;
    border-radius: 1rem;
    padding: 2rem 1rem;
    text-align: center;
    color: #6c757d;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* ===== FORM UPLOAD ===== */
  .form-upload {
    margin-top: 1rem;
  }
  .form-control-file {
    border: 2px dashed #ced4da;
    border-radius: 0.75rem;
    padding: 0.75rem;
    transition: all 0.2s;
    background-color: #f8fafc;
    width: 100%;
  }
  .form-control-file:hover {
    border-color: var(--primary-start);
    background-color: #eef2f7;
  }
  .form-control-file:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.2rem rgba(30,58,138,0.25);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .laporan-header h2 { font-size: 1.8rem; }
    .laporan-header p { font-size: 1rem; }
    .laporan-header .btn-light { padding: 0.4rem 1.2rem; font-size: 0.9rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .laporan-header h2 { font-size: 1.5rem; }
    .laporan-header p { font-size: 0.9rem; }
    .card-header-laporan { font-size: 0.95rem; }
    .badge-status { font-size: 0.75rem; }
    .btn-gradient, .btn-outline-gradient { padding: 0.4rem 1rem; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .laporan-header h2 { font-size: 1.3rem; }
  }

  @media (max-width: 340px) {
    html { font-size: 12px; }
  }
</style>

<div class="container mt-4">
  <!-- Header -->
  <div class="laporan-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2 class="fw-bold mb-2"><i class="bi bi-file-earmark-pdf me-2"></i>Laporan Magang</h2>
      <p class="mb-0">Unggah laporan magang 1, 2, dan 3 sesuai ketentuan</p>
    </div>
    <a href="/mahasiswa/magang" class="btn-light mt-3 mt-sm-0">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <!-- Info petunjuk -->
  <div class="alert alert-info d-flex align-items-center mb-4" role="alert" style="border-left: 4px solid var(--primary-start); border-radius: 0.75rem; background: white; border: 1px solid rgba(30,58,138,0.1);">
    <i class="bi bi-info-circle-fill fs-4 me-3" style="color: var(--primary-start);"></i>
    <div>
      <strong>Petunjuk:</strong> Unggah file PDF maksimal 10MB. Setelah diunggah, laporan akan diperiksa oleh pembimbing. Status akan diperbarui secara otomatis.
    </div>
  </div>

  <!-- Kartu Laporan -->
  <div class="row g-4">
    <% for (let i = 1; i <= 3; i++) { 
      const item = laporanList[i-1];
      const status = item.exists ? item.data.status : null;
      const isApproved = status === 'approved';
      const isRejected = status === 'rejected';
      const isSubmitted = status === 'submitted';
    %>
      <div class="col-md-4">
        <div class="card-laporan">
          <div class="card-header-laporan d-flex justify-content-between align-items-center">
            <span><i class="bi bi-file-text me-2"></i>Laporan Magang <%= i %></span>
            <% if (item.exists) { %>
              <span class="badge-status <%= isApproved ? 'badge-approved' : (isRejected ? 'badge-rejected' : 'badge-pending') %>">
                <%= isApproved ? 'Disetujui' : (isRejected ? 'Ditolak' : 'Menunggu') %>
              </span>
            <% } else { %>
              <span class="badge-status badge-secondary">Belum Upload</span>
            <% } %>
          </div>
          <div class="card-body d-flex flex-column">
            <% if (item.exists) { %>
              <!-- Info file -->
              <div class="file-info">
                <div class="d-flex align-items-center">
                  <i class="bi bi-file-pdf text-danger fs-4 me-3"></i>
                  <div class="flex-grow-1" style="min-width: 0;">
                    <a href="<%= item.data.fileUrl %>" target="_blank" class="file-link" title="<%= item.data.fileName %>">
                      <%= item.data.fileName %>
                    </a>
                    <% if (item.data.fileSize) { %>
                      <div class="file-size">
                        <i class="bi bi-database me-1"></i><%= (item.data.fileSize / 1024 / 1024).toFixed(2) %> MB
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>

              <!-- Tanggal upload -->
              <p class="mb-2 text-muted small">
                <i class="bi bi-calendar3 me-1"></i>Diunggah: <%= new Date(item.data.uploadedAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
              </p>

              <!-- ===== KOMENTAR ===== -->
              <% if (item.data.komentar && item.data.komentar.length > 0) { %>
                <div class="komentar-section">
                  <h6 class="fw-bold mb-2"><i class="bi bi-chat-dots me-1"></i>Komentar</h6>
                  <% item.data.komentar.forEach(k => { %>
                    <div class="komentar-item">
                      <div class="d-flex justify-content-between align-items-center">
                        <span class="penulis"><%= k.penulis %></span>
                        <span class="tanggal"><%= new Date(k.tanggal).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></span>
                      </div>
                      <p><%= k.isi %></p>
                    </div>
                  <% }) %>
                </div>
              <% } %>

              <!-- Alasan penolakan jika ada -->
              <% if (isRejected && item.data.rejectionReason) { %>
                <div class="rejection-reason">
                  <i class="bi bi-exclamation-triangle-fill me-2"></i>
                  <strong>Alasan ditolak:</strong> <%= item.data.rejectionReason %>
                </div>
              <% } %>

              <!-- Tombol aksi berdasarkan status -->
              <div class="mt-auto pt-3">
                <% if (isApproved) { %>
                  <a href="<%= item.data.fileUrl %>" target="_blank" class="btn-outline-gradient w-100">
                    <i class="bi bi-eye me-2"></i>Lihat Laporan
                  </a>
                <% } else if (isRejected) { %>
                  <button class="btn-gradient w-100" type="button" data-bs-toggle="collapse" data-bs-target="#uploadForm<%= i %>" aria-expanded="false" aria-controls="uploadForm<%= i %>">
                    <i class="bi bi-arrow-repeat me-2"></i>Upload Ulang
                  </button>
                  <div class="collapse mt-3" id="uploadForm<%= i %>">
                    <form method="POST" action="/mahasiswa/magang/laporan/upload" enctype="multipart/form-data">
                      <input type="hidden" name="laporanKe" value="<%= i %>">
                      <div class="mb-2">
                        <input type="file" class="form-control-file" name="file" accept=".pdf" required>
                      </div>
                      <button type="submit" class="btn-gradient w-100">
                        <i class="bi bi-cloud-upload me-2"></i>Unggah
                      </button>
                    </form>
                  </div>
                <% } else if (isSubmitted) { %>
                  <button class="btn btn-secondary w-100" disabled style="border-radius: 50px;">
                    <i class="bi bi-hourglass-split me-2"></i>Menunggu Verifikasi
                  </button>
                <% } %>
              </div>
            <% } else { %>
              <!-- Belum ada laporan: tampilkan form upload -->
              <div class="empty-state">
                <i class="bi bi-cloud-upload fs-1 mb-3"></i>
                <p class="mb-3">Belum ada laporan diunggah</p>
                <form method="POST" action="/mahasiswa/magang/laporan/upload" enctype="multipart/form-data">
                  <input type="hidden" name="laporanKe" value="<%= i %>">
                  <div class="mb-3">
                    <input type="file" class="form-control-file" name="file" accept=".pdf" required>
                  </div>
                  <button type="submit" class="btn-gradient w-100">
                    <i class="bi bi-cloud-upload me-2"></i>Upload Laporan
                  </button>
                </form>
              </div>
            <% } %>
          </div>
          <!-- Footer card untuk info tambahan -->
          <div class="card-footer bg-transparent border-0 pt-0 pb-3 text-center">
            <small class="text-muted">Format PDF, maks. 10MB</small>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Catatan tambahan -->
  <div class="mt-5 text-center text-muted">
    <p class="small">
      <i class="bi bi-shield-check me-1"></i> Pastikan laporan sudah sesuai dengan panduan sebelum mengunggah.
    </p>
  </div>
</div>

<%- include('../../partials/footer') %>