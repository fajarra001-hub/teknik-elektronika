<%- include('../../partials/header') %>

<style>
  @media (max-width: 480px) {
    body {
        zoom: 0.72; 
    }
}
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 2rem;
    color: white;
  }
  .form-header h2 {
    font-weight: 700;
  }
  .form-body {
    padding: 2rem;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h2><i class="bi bi-plus-circle me-2"></i>Ajukan Seminar Magang</h2>
      <p class="mb-0">Isi formulir di bawah untuk mengajukan jadwal seminar</p>
    </div>
    <div class="form-body">
      <form method="POST" action="/mahasiswa/magang/seminar">
        <div class="mb-3">
          <label for="judul" class="form-label fw-bold">Judul Seminar <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="judul" name="judul" placeholder="Contoh: Implementasi IoT pada Smart Home" required>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="tanggal" class="form-label fw-bold">Tanggal <span class="text-danger">*</span></label>
            <input type="date" class="form-control" id="tanggal" name="tanggal" required>
          </div>
          <div class="col-md-6 mb-3">
            <label for="waktu" class="form-label fw-bold">Waktu <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="waktu" name="waktu" placeholder="09:00 - 12:00" required>
          </div>
        </div>

        <div class="mb-3">
          <label for="tempat" class="form-label fw-bold">Tempat <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="tempat" name="tempat" placeholder="Ruang Seminar A" required>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="pembimbing1" class="form-label fw-bold">Pembimbing 1</label>
            <input type="text" class="form-control" id="pembimbing1" name="pembimbing1" placeholder="Nama pembimbing">
          </div>
          <div class="col-md-6 mb-3">
            <label for="pembimbing2" class="form-label fw-bold">Pembimbing 2</label>
            <input type="text" class="form-control" id="pembimbing2" name="pembimbing2" placeholder="Nama pembimbing">
          </div>
        </div>

        <div class="mb-3">
          <label for="penguji" class="form-label fw-bold">Penguji</label>
          <input type="text" class="form-control" id="penguji" name="penguji" placeholder="Nama penguji">
        </div>

        <div class="d-flex justify-content-between">
          <a href="/mahasiswa/magang/seminar" class="btn btn-outline-secondary">Batal</a>
          <button type="submit" class="btn-gradient">Ajukan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>