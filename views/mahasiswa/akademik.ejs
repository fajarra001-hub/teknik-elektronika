<%- include('../partials/header') %>

<%
  // Fungsi untuk mengekstrak ID file dari URL Google Drive (jika diperlukan nanti)
  const getFileIdFromUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== HEADER ===== */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 2.2rem;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1.1rem;
  }
  .page-header .btn-back {
    background: white;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    color: var(--primary-start);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    border: none;
    font-size: 0.95rem;
  }
  .page-header .btn-back:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* ===== MENU CARDS ===== */
  .menu-card {
    background: white;
    border-radius: 1.5rem;
    padding: 2rem 1.5rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: 1px solid rgba(30,58,138,0.1);
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .menu-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 35px rgba(30,58,138,0.15);
    border-color: transparent;
  }
  .menu-icon {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.8rem;
    margin-bottom: 1.5rem;
    transition: all 0.3s;
  }
  .menu-card:hover .menu-icon {
    transform: scale(1.1);
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end)) !important;
    color: white !important;
    box-shadow: 0 10px 20px rgba(30,58,138,0.3);
  }
  .menu-title {
    font-weight: 700;
    font-size: 1.3rem;
    color: #1e293b;
    margin-bottom: 0.5rem;
  }
  .menu-desc {
    color: #64748b;
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
    text-decoration: none;
    display: inline-block;
    font-size: 0.95rem;
  }
  .btn-gradient:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header h2 { font-size: 1.8rem; }
    .page-header p { font-size: 1rem; }
    .menu-icon { width: 70px; height: 70px; font-size: 2.2rem; }
    .menu-title { font-size: 1.1rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h2 { font-size: 1.5rem; }
    .page-header p { font-size: 0.9rem; }
    .page-header .btn-back { padding: 0.4rem 1rem; font-size: 0.85rem; }
    .menu-card { padding: 1.5rem 1rem; }
    .menu-icon { width: 60px; height: 60px; font-size: 1.8rem; margin-bottom: 1rem; }
    .menu-title { font-size: 1rem; }
    .menu-desc { font-size: 0.85rem; }
    .btn-gradient { padding: 0.4rem 1rem; font-size: 0.85rem; }
  }

  @media (max-width: 400px) {
    html { font-size: 13px; }
    .page-header h2 { font-size: 1.3rem; }
    .menu-icon { width: 55px; height: 55px; font-size: 1.6rem; }
  }

  @media (max-width: 340px) {
    html { font-size: 12px; }
    .menu-title { font-size: 0.9rem; }
  }
</style>

<div class="container mt-4">
  <!-- Header dengan gradien dan tombol kembali -->
  <div class="page-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-journal-bookmark-fill"></i> Akademik</h2>
      <p class="mb-0">Kelola KRS, lihat KHS, transkrip, dan kalender akademik</p>
    </div>
    <a href="/mahasiswa/dashboard" class="btn-back mt-2 mt-sm-0">
      <i class="bi bi-arrow-left"></i> Kembali ke Dashboard
    </a>
  </div>

  <!-- Grid Menu -->
  <div class="row g-4">
    <!-- KRS -->
    <div class="col-md-6 col-lg-3">
      <div class="menu-card">
        <div class="menu-icon" style="background: rgba(30,58,138,0.1); color: var(--primary-start);">
          <i class="bi bi-pencil-square"></i>
        </div>
        <h5 class="menu-title">Kartu Rencana Studi</h5>
        <p class="menu-desc">Buat KRS baru, lihat daftar KRS, dan unggah file KRS</p>
        <a href="/mahasiswa/akademik/krs" class="btn-gradient">Kelola KRS</a>
      </div>
    </div>

    <!-- KHS -->
    <div class="col-md-6 col-lg-3">
      <div class="menu-card">
        <div class="menu-icon" style="background: rgba(30,58,138,0.1); color: var(--primary-start);">
          <i class="bi bi-file-earmark-text"></i>
        </div>
        <h5 class="menu-title">Kartu Hasil Studi</h5>
        <p class="menu-desc">Lihat KHS per semester yang telah diupload</p>
        <a href="/mahasiswa/akademik/khs" class="btn-gradient">Lihat KHS</a>
      </div>
    </div>

    <!-- Transkrip -->
    <div class="col-md-6 col-lg-3">
      <div class="menu-card">
        <div class="menu-icon" style="background: rgba(30,58,138,0.1); color: var(--primary-start);">
          <i class="bi bi-bar-chart-line"></i>
        </div>
        <h5 class="menu-title">Transkrip Nilai</h5>
        <p class="menu-desc">Cetak transkrip nilai dan IPK kumulatif</p>
        <a href="/mahasiswa/akademik/transkrip" class="btn-gradient">Lihat Transkrip</a>
      </div>
    </div>

    <!-- Kalender Akademik (mungkin perlu ditambahkan) -->
    <div class="col-md-6 col-lg-3">
      <div class="menu-card">
        <div class="menu-icon" style="background: rgba(30,58,138,0.1); color: var(--primary-start);">
          <i class="bi bi-calendar-event"></i>
        </div>
        <h5 class="menu-title">Kalender Akademik</h5>
        <p class="menu-desc">Jadwal penting, libur, dan kegiatan akademik</p>
        <a href="/mahasiswa/kalender" class="btn-gradient">Lihat Kalender</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>