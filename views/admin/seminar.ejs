<%- include('../partials/header') %>

<style>
  .seminar-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .seminar-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .btn-action {
    margin: 2px;
    border-radius: 8px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
  }
  .filter-card {
    border-radius: 1rem;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    background: white;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .table-responsive {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
</style>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Kelola Jadwal Seminar</h2>
    <a href="/admin/seminar/tambah" class="btn btn-primary">
      <i class="bi bi-plus-circle me-2"></i>Tambah Seminar
    </a>
  </div>

  <!-- Notifikasi Sukses -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>Data seminar berhasil <%= success %>.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Tabel Seminar -->
  <div class="table-responsive">
    <table class="table seminar-table">
      <thead>
        <tr>
          <th>Judul</th>
          <th>Tanggal</th>
          <th>Waktu</th>
          <th>Tempat</th>
          <th>Pemateri</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (seminar.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Belum ada jadwal seminar.</p>
            </td>
          </tr>
        <% } %>
        <% seminar.forEach(s => { %>
        <tr>
          <td><strong><%= s.judul %></strong></td>
          <td><%= new Date(s.tanggal).toLocaleDateString('id-ID') %></td>
          <td><%= s.waktu || '-' %></td>
          <td><%= s.tempat || '-' %></td>
          <td><%= s.pemateri || '-' %></td>
          <td>
            <a href="/admin/seminar/edit/<%= s.id %>" class="btn btn-sm btn-warning btn-action">
              <i class="bi bi-pencil"></i> Edit
            </a>
            <form method="POST" action="/admin/seminar/hapus/<%= s.id %>" style="display:inline;" onsubmit="return confirm('Yakin hapus seminar ini?')">
              <button type="submit" class="btn btn-sm btn-danger btn-action">
                <i class="bi bi-trash"></i> Hapus
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>