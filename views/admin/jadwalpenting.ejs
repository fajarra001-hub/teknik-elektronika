<%- include('../partials/header') %>

<style>
  .jadwal-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .jadwal-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .btn-action {
    margin: 2px;
    border-radius: 8px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
  }
  .badge-kategori {
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
  }
  .kategori-seminar { background: #28a745; color: white; }
  .kategori-wisuda { background: #dc3545; color: white; }
  .kategori-libur { background: #ffc107; color: #212529; }
  .kategori-pendaftaran { background: #17a2b8; color: white; }
  .kategori-umum { background: #6c757d; color: white; }
  .modal-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
</style>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Kelola Jadwal Penting</h2>
    <a href="/admin/jadwalpenting/create" class="btn btn-primary">
      <i class="bi bi-plus-circle me-2"></i>Tambah Jadwal
    </a>
  </div>

  <!-- Notifikasi Sukses (opsional) -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>Data jadwal berhasil <%= success %>.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Tabel Jadwal -->
  <div class="table-responsive">
    <table class="table jadwal-table">
      <thead>
        <tr>
          <th>Tanggal</th>
          <th>Judul</th>
          <th>Waktu</th>
          <th>Tempat</th>
          <th>Kategori</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (jadwal.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Belum ada jadwal penting.</p>
            </td>
          </tr>
        <% } %>
        <% jadwal.forEach(j => { %>
          <tr>
            <td><%= new Date(j.tanggal).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></td>
            <td><strong><%= j.judul %></strong></td>
            <td><%= j.waktu || '-' %></td>
            <td><%= j.tempat || '-' %></td>
            <td>
              <span class="badge-kategori 
                <%= j.kategori === 'seminar' ? 'kategori-seminar' : '' %>
                <%= j.kategori === 'wisuda' ? 'kategori-wisuda' : '' %>
                <%= j.kategori === 'libur' ? 'kategori-libur' : '' %>
                <%= j.kategori === 'pendaftaran' ? 'kategori-pendaftaran' : '' %>
                <%= j.kategori === 'umum' ? 'kategori-umum' : '' %>">
                <%= j.kategori || 'umum' %>
              </span>
            </td>
            <td>
              <a href="/admin/jadwalpenting/<%= j.id %>/edit" class="btn btn-sm btn-warning btn-action">
                <i class="bi bi-pencil"></i> Edit
              </a>
              <form method="POST" action="/admin/jadwalpenting/<%= j.id %>/delete" style="display:inline;" onsubmit="return confirm('Yakin hapus jadwal ini?')">
                <button type="submit" class="btn btn-sm btn-danger btn-action">
                  <i class="bi bi-trash"></i> Hapus
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>