<%- include('../partials/header') %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Detail KRS - <%= mahasiswa.nama %></h2>
    <a href="javascript:history.back()" class="btn btn-outline-secondary">Kembali</a>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h5 class="card-title">Informasi KRS</h5>
      <p><strong>NIM:</strong> <%= mahasiswa.nim || '-' %></p>
      <p><strong>Semester:</strong> <%= krs.semester || '-' %></p>
      <p><strong>Status:</strong> 
        <span class="badge <%= krs.status === 'approved' ? 'bg-success' : 'bg-warning' %>">
          <%= krs.status || 'pending' %>
        </span>
      </p>
      <p><strong>Dibuat:</strong> <%= krs.createdAt ? new Date(krs.createdAt).toLocaleString('id-ID') : '-' %></p>
      <% if (krs.approvedAt) { %>
        <p><strong>Disetujui:</strong> <%= new Date(krs.approvedAt).toLocaleString('id-ID') %></p>
      <% } %>
    </div>
  </div>

  <h4 class="mb-3">Mata Kuliah yang Diambil</h4>
  <div class="table-responsive">
    <table class="table table-bordered">
      <thead>
        <tr>
          <th>Kode</th>
          <th>Nama Mata Kuliah</th>
          <th>SKS</th>
        </tr>
      </thead>
      <tbody>
        <% if (mkList && mkList.length > 0) { %>
          <% mkList.forEach(mk => { %>
            <tr>
              <td><%= mk.kode || '-' %></td>
              <td><%= mk.nama || '-' %></td>
              <td><%= mk.sks || '-' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="3" class="text-center text-muted">Tidak ada mata kuliah yang diambil.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>