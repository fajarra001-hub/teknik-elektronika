<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rekap Pengajaran - <%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    @media print {
      .btn { display: none; }
      body { font-size: 12pt; }
      h2 { margin-top: 20px; }
      .table thead tr { background-color: #f2f2f2; }
    }
    .print-btn {
      margin-bottom: 20px;
    }
  </style>
</head>
<body>
  <div class="container mt-4">
    <button onclick="window.print()" class="btn btn-primary print-btn">
      <i class="bi bi-printer"></i> Print / Simpan PDF
    </button>

    <h2 class="text-center">LAPORAN REKAP PENGAJARAN</h2>
    <p class="text-center">Program Studi Teknik Elektronika - Politeknik Dewantara</p>
    <p class="text-center"><small>Periode: <%= generatedAt %></small></p>

    <table class="table table-bordered">
      <thead>
        <tr>
          <th>Kode MK</th>
          <th>Nama MK</th>
          <th>Semester</th>
          <th>Dosen</th>
          <th>Pertemuan</th>
          <th>Jadwal</th>
        </tr>
      </thead>
      <tbody>
        <% if (data.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center">Tidak ada data</td>
          </tr>
        <% } %>
        <% data.forEach(item => { %>
          <tr>
            <td><%= item.kode %></td>
            <td><%= item.nama %></td>
            <td><%= item.semester %></td>
            <td><%= item.dosen %></td>
            <td><%= item.pertemuan %></td>
            <td><%= item.jadwal %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>