<%- include('../partials/header') %>

<%
  // Fungsi untuk format angka (opsional, bisa digunakan di view)
  const formatRupiah = (angka) => {
    return new Intl.NumberFormat('id-ID').format(angka);
  };
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --gradient: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    --shadow-sm: 0 0.5rem 1rem rgba(0,0,0,0.08);
    --shadow-hover: 0 1rem 2rem rgba(0,0,0,0.12);
    --border-radius: 1rem;
    --font-sans: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: var(--font-sans);
    background-color: #f8fafc;
  }

  /* ===== PAGE HEADER ===== */
  .page-header {
    background: var(--gradient);
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
    font-size: 2.2rem;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
    font-size: 1rem;
  }

  /* ===== FILTER CARD ===== */
  .filter-card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(30,58,138,0.1);
  }
  .filter-card .form-label {
    font-weight: 600;
    color: #1e293b;
    font-size: 0.9rem;
  }
  .filter-card .form-select,
  .filter-card .form-control {
    border-radius: 50px;
    border: 1px solid #dee2e6;
    padding: 0.6rem 1rem;
    transition: all 0.2s;
    font-size: 0.95rem;
  }
  .filter-card .form-select:focus,
  .filter-card .form-control:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.25rem rgba(30,58,138,0.25);
  }
  .btn-filter {
    background: var(--gradient);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
    width: 100%;
  }
  .btn-filter:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }
  .btn-reset {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  .btn-reset:hover {
    background: var(--gradient);
    border-color: transparent;
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(30,58,138,0.3);
  }

  /* ===== INFO JUMLAH ===== */
  .info-count {
    background: white;
    border-radius: 50px;
    padding: 0.5rem 1rem;
    display: inline-block;
    border: 1px solid rgba(30,58,138,0.1);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  .info-count strong {
    color: var(--primary-start);
  }

  /* ===== TABEL MINIMALIS ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    border: 1px solid rgba(30,58,138,0.1);
    transition: box-shadow 0.3s;
  }
  .table-container:hover {
    box-shadow: var(--shadow-hover);
  }
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .tagihan-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .tagihan-table thead th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem 1rem;
    white-space: nowrap;
  }
  .tagihan-table tbody td {
    vertical-align: middle;
    padding: 0.75rem 1rem;
    border: 1px solid #dee2e6;
    font-size: 0.95rem;
  }
  .tagihan-table tbody tr:hover {
    background-color: #f2f2f2;
  }

  /* ===== BADGE ===== */
  .badge-count {
    background: var(--primary-light);
    color: var(--primary-dark);
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.8rem;
    border: 1px solid rgba(30,58,138,0.2);
  }
  .badge-nim {
    background: #e9ecef;
    color: #1e293b;
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  /* ===== TOMBOL AKSI ===== */
  .btn-detail {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    border-radius: 50px;
    padding: 0.3rem 1rem;
    font-size: 0.8rem;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    text-decoration: none;
    font-weight: 500;
  }
  .btn-detail:hover {
    background: var(--gradient);
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    font-size: 1rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .page-header h2 { font-size: 1.8rem; }
    .page-header p { font-size: 0.95rem; }
    .filter-card .row { flex-direction: column; }
    .btn-filter, .btn-reset { width: 100%; margin-bottom: 0.5rem; }
    .tagihan-table thead th { font-size: 0.8rem; padding: 0.5rem; }
    .tagihan-table tbody td { font-size: 0.85rem; padding: 0.5rem; }
  }
  @media (max-width: 576px) {
    html { font-size: 14px; }
    .page-header h2 { font-size: 1.5rem; }
  }
</style>

<div class="container mt-4">
  <!-- Header -->
  <div class="page-header">
    <h2><i class="bi bi-cash-coin me-2"></i>Kelola Tagihan Mahasiswa</h2>
    <p class="mb-0">Daftar mahasiswa dan ringkasan tagihan SPP</p>
  </div>

  <!-- Filter Card -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label for="angkatan" class="form-label"><i class="bi bi-funnel me-1"></i> Filter Angkatan</label>
        <select class="form-select" id="angkatan" name="angkatan">
          <option value="">Semua Angkatan</option>
          <% angkatanList.forEach(a => { %>
            <option value="<%= a %>" <%= filters && filters.angkatan === a ? 'selected' : '' %>><%= a %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label for="search" class="form-label"><i class="bi bi-search me-1"></i> Cari NIM / Nama</label>
        <input type="text" class="form-control" id="search" name="search" placeholder="Ketik NIM atau nama..." value="<%= filters && filters.search ? filters.search : '' %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn-filter">Terapkan</button>
      </div>
      <div class="col-md-2">
        <a href="/admin/tagihan" class="btn-reset"><i class="bi bi-arrow-counterclockwise"></i> Reset</a>
      </div>
    </form>
  </div>

  <!-- Info jumlah -->
  <div class="info-count">
    <i class="bi bi-people-fill me-1" style="color: var(--primary-start);"></i> Menampilkan <strong><%= mahasiswaList.length %></strong> mahasiswa
  </div>

  <!-- Tabel -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table tagihan-table">
        <thead>
          <tr>
            <th>No</th>
            <th>NIM</th>
            <th>Nama</th>
            <th>Jumlah Tagihan</th>
            <th>Total Belum Lunas</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (mahasiswaList.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <h4>Tidak Ada Data</h4>
                  <p class="text-muted">Tidak ada mahasiswa yang ditemukan.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% mahasiswaList.forEach((m, index) => { %>
            <tr>
              <td class="fw-bold text-center"><%= index + 1 %></td>
              <td><span class="badge-nim"><%= m.nim || '-' %></span></td>
              <td><strong><%= m.nama %></strong></td>
              <td class="text-center"><span class="badge-count"><%= m.tagihanCount %></span></td>
              <td class="fw-semibold">Rp <%= formatRupiah(m.totalBelumLunas) %></td>
              <td class="text-center">
                <a href="/admin/tagihan/mahasiswa/<%= m.id %>" class="btn-detail">
                  <i class="bi bi-eye"></i> Detail Tagihan
                </a>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>