<%- include('../partials/header') %>

<style>
  .profile-card {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-radius: 1rem;
    padding: 1.5rem;
    color: white;
    margin-bottom: 2rem;
  }
  .tagihan-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .tagihan-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .btn-action {
    margin: 2px;
    border-radius: 8px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
  }
</style>

<div class="container-fluid mt-4">
  <div class="profile-card d-flex justify-content-between align-items-center">
    <div>
      <h4 class="fw-bold mb-1"><%= mahasiswa.nama %></h4>
      <p class="mb-0"><i class="bi bi-qr-code me-2"></i>NIM: <%= mahasiswa.nim || '-' %> | <i class="bi bi-envelope me-2"></i><%= mahasiswa.email %></p>
    </div>
    <div>
      <a href="/admin/tagihan" class="btn btn-light me-2">Kembali</a>
      <a href="/admin/tagihan/mahasiswa/<%= mahasiswa.id %>/tambah" class="btn btn-success">Tambah Tagihan</a>
    </div>
  </div>

  <div class="table-responsive">
    <table class="table tagihan-table">
      <thead>
        <tr>
          <th>No</th>
          <th>Semester</th>
          <th>Jumlah</th>
          <th>Jatuh Tempo</th>
          <th>Status</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (tagihan.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Belum ada tagihan untuk mahasiswa ini.</p>
            </td>
          </tr>
        <% } else { %>
          <% tagihan.forEach((t, index) => { %>
          <tr>
            <td class="text-center"><%= index + 1 %></td>
            <td><%= t.semester %></td>
            <td class="text-end">Rp <%= new Intl.NumberFormat('id-ID').format(t.jumlah) %></td>
            <td><%= t.jatuhTempo ? new Date(t.jatuhTempo).toLocaleDateString('id-ID') : '-' %></td>
            <td>
              <span class="badge bg-<%= t.status === 'lunas' ? 'success' : 'warning' %>">
                <%= t.status %>
              </span>
            </td>
            <td>
              <a href="/admin/tagihan/mahasiswa/<%= mahasiswa.id %>/edit/<%= t.id %>" class="btn btn-sm btn-warning btn-action">
                <i class="bi bi-pencil"></i> Edit
              </a>
              <form method="POST" action="/admin/tagihan/mahasiswa/<%= mahasiswa.id %>/hapus/<%= t.id %>" style="display:inline;" onsubmit="return confirm('Yakin hapus tagihan ini?')">
                <button class="btn btn-sm btn-danger btn-action"><i class="bi bi-trash"></i> Hapus</button>
              </form>
            </td>
          </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>