<%- include('../partials/header') %>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* ===== HEADER ===== */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }

  /* ===== TAB NAVIGASI ===== */
  .nav-tabs-custom {
    border-bottom: 2px solid var(--primary-light);
    margin-bottom: 2rem;
  }
  .nav-tabs-custom .nav-link {
    border: none;
    color: #64748b;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 50px 50px 0 0;
    transition: all 0.2s;
    margin-right: 0.3rem;
  }
  .nav-tabs-custom .nav-link:hover {
    color: var(--primary-dark);
    background: var(--primary-light);
  }
  .nav-tabs-custom .nav-link.active {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    box-shadow: 0 5px 15px rgba(33,147,176,0.3);
  }

  /* ===== SECTION TITLE ===== */
  .section-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1e293b;
    margin: 1.5rem 0 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .section-title i {
    color: var(--primary-start);
  }

  /* ===== TABEL ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    overflow: hidden;
    border: 1px solid rgba(33,147,176,0.1);
    margin-bottom: 2rem;
  }
  .table thead th {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
    padding: 1rem 0.75rem;
    white-space: nowrap;
  }
  .table tbody td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
    border-bottom: 1px solid #e9ecef;
  }
  .table tbody tr:hover {
    background-color: var(--primary-light);
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.85rem;
    background: #f8f9fa;
    border: 1px solid transparent;
  }
  .badge-pending { background: #fff3cd; color: #856404; border-color: #ffeeba; }
  .badge-approved { background: #d4edda; color: #155724; border-color: #c3e6cb; }
  .badge-rejected { background: #f8d7da; color: #721c24; border-color: #f5c6cb; }

  /* ===== TOMBOL AKSI ===== */
  .btn-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
    color: white;
    margin: 0 2px;
  }
  .btn-action i {
    font-size: 1rem;
  }
  .btn-edit {
    background: #ffc107;
  }
  .btn-edit:hover {
    background: #e0a800;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(255,193,7,0.3);
  }
  .btn-delete {
    background: #dc3545;
  }
  .btn-delete:hover {
    background: #c82333;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(220,53,69,0.3);
  }
  .btn-view {
    background: var(--primary-start);
  }
  .btn-view:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(33,147,176,0.3);
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 3rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1rem;
    color: #6c757d;
  }
  .empty-state i {
    font-size: 3rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
</style>

<div class="container-fluid mt-4">
  <!-- Header -->
  <div class="page-header">
    <h2><i class="bi bi-journal-richtext me-2"></i>Kelola E-Library</h2>
    <p class="mb-0 opacity-75">Atur konten laporan magang dan artikel dosen yang telah dipublikasikan</p>
  </div>

  <!-- Tab navigasi -->
  <ul class="nav nav-tabs-custom">
    <li class="nav-item">
      <a class="nav-link <%= currentType === 'all' ? 'active' : '' %>" href="/admin/elk-library?type=all">
        <i class="bi bi-grid-3x3-gap-fill me-1"></i>Semua
      </a>
    </li>
    <li class="nav-item">
      <a class="nav-link <%= currentType === 'laporan' ? 'active' : '' %>" href="/admin/elk-library?type=laporan">
        <i class="bi bi-file-earmark-pdf me-1"></i>Laporan Magang
      </a>
    </li>
    <li class="nav-item">
      <a class="nav-link <%= currentType === 'artikel' ? 'active' : '' %>" href="/admin/elk-library?type=artikel">
        <i class="bi bi-file-text me-1"></i>Artikel Dosen
      </a>
    </li>
  </ul>

  <!-- Laporan Magang -->
  <% if (currentType === 'all' || currentType === 'laporan') { %>
    <div class="section-title">
      <i class="bi bi-file-earmark-pdf-fill"></i> Laporan Magang
    </div>
    <div class="table-container">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>Judul Publik</th>
              <th>Mahasiswa</th>
              <th>Pembimbing</th>
              <th>Tahun</th>
              <th>Status</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (laporanList.length === 0) { %>
              <tr><td colspan="6" class="empty-state">Belum ada laporan magang.</td></tr>
            <% } else { %>
              <% laporanList.forEach(l => { %>
                <tr>
                  <td><strong><%= l.judulPublik || '-' %></strong></td>
                  <td><%= l.nama %> (<%= l.nim %>)</td>
                  <td><%= l.pembimbing || '-' %></td>
                  <td><%= l.tahun || '-' %></td>
                  <td>
                    <span class="badge-status 
                      <%= l.status === 'pending' ? 'badge-pending' : '' %>
                      <%= l.status === 'approved' ? 'badge-approved' : '' %>
                      <%= l.status === 'rejected' ? 'badge-rejected' : '' %>">
                      <%= l.status === 'pending' ? 'Menunggu' : (l.status === 'approved' ? 'Disetujui' : (l.status === 'rejected' ? 'Ditolak' : l.status)) %>
                    </span>
                  </td>
                  <td>
                    <div class="d-flex gap-1">
                      <a href="/admin/elk-library/laporan/<%= l.id %>" class="btn-action btn-view" title="Lihat">
                        <i class="bi bi-eye"></i>
                      </a>
                      <a href="/admin/elk-library/laporan/<%= l.id %>/edit" class="btn-action btn-edit" title="Edit">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form method="POST" action="/admin/elk-library/laporan/<%= l.id %>/delete" style="display:inline;" onsubmit="return confirm('Yakin hapus laporan ini?')">
                        <button class="btn-action btn-delete" title="Hapus">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <!-- Artikel Dosen -->
  <% if (currentType === 'all' || currentType === 'artikel') { %>
    <div class="section-title">
      <i class="bi bi-file-text-fill"></i> Artikel Dosen
    </div>
    <div class="table-container">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>Judul</th>
              <th>Penulis</th>
              <th>Tahun</th>
              <th>Status</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (artikelList.length === 0) { %>
              <tr><td colspan="5" class="empty-state">Belum ada artikel dosen.</td></tr>
            <% } else { %>
              <% artikelList.forEach(a => { %>
                <tr>
                  <td><strong><%= a.judul %></strong></td>
                  <td><%= a.penulis || (a.authors ? a.authors.join(', ') : '-') %></td>
                  <td><%= a.publicationYear || a.tahun || '-' %></td>
                  <td>
                    <span class="badge-status 
                      <%= a.status === 'pending' ? 'badge-pending' : '' %>
                      <%= a.status === 'approved' ? 'badge-approved' : '' %>
                      <%= a.status === 'rejected' ? 'badge-rejected' : '' %>">
                      <%= a.status === 'pending' ? 'Menunggu' : (a.status === 'approved' ? 'Disetujui' : (a.status === 'rejected' ? 'Ditolak' : a.status)) %>
                    </span>
                  </td>
                  <td>
                    <div class="d-flex gap-1">
                      <a href="/admin/elk-library/artikel/<%= a.id %>" class="btn-action btn-view" title="Lihat">
                        <i class="bi bi-eye"></i>
                      </a>
                      <a href="/admin/elk-library/artikel/<%= a.id %>/edit" class="btn-action btn-edit" title="Edit">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form method="POST" action="/admin/elk-library/artikel/<%= a.id %>/delete" style="display:inline;" onsubmit="return confirm('Yakin hapus artikel ini?')">
                        <button class="btn-action btn-delete" title="Hapus">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>