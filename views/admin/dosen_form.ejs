<%- include('../partials/header') %>

<style>
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 1.5rem;
    color: white;
  }
  .form-header h3 {
    margin: 0;
    font-weight: 600;
  }
  .form-body {
    padding: 2rem;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
  .form-label {
    font-weight: 600;
    color: #1e293b;
  }
  .form-control, .form-select {
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid #cbd5e1;
    transition: all 0.3s;
  }
  .form-control:focus, .form-select:focus {
    border-color: #2193b0;
    box-shadow: 0 0 0 0.2rem rgba(33,147,176,0.25);
  }
  .avatar-preview {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #2193b0;
    margin-bottom: 1rem;
  }
  .mk-container {
    max-height: 200px;
    overflow-y: auto;
    border: 1px solid #cbd5e1;
    border-radius: 0.75rem;
    padding: 1rem;
  }
  .mk-item {
    padding: 0.5rem;
    border-bottom: 1px solid #e9ecef;
  }
  .mk-item:last-child {
    border-bottom: none;
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3><i class="bi bi-person-badge me-2"></i><%= dosen ? 'Edit Dosen' : 'Tambah Dosen' %></h3>
    </div>
    <div class="form-body">
      <form method="POST" action="<%= dosen ? '/admin/dosen/' + dosen.id + '/update' : '/admin/dosen' %>" enctype="multipart/form-data">
        <!-- Preview Foto (jika edit dan ada foto) -->
        <% if (dosen && dosen.foto) { %>
          <div class="text-center mb-3">
            <img src="<%= dosen.foto %>" alt="foto" class="avatar-preview">
          </div>
        <% } %>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="nip" class="form-label">NIP <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="nip" name="nip" value="<%= dosen ? dosen.nip : '' %>" required>
          </div>
          <div class="col-md-6 mb-3">
            <label for="nama" class="form-label">Nama Lengkap <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="nama" name="nama" value="<%= dosen ? dosen.nama : '' %>" required>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" id="email" name="email" value="<%= dosen ? dosen.email : '' %>" required>
          </div>
          <div class="col-md-6 mb-3">
            <label for="kontak" class="form-label">Kontak (No. HP)</label>
            <input type="text" class="form-control" id="kontak" name="kontak" value="<%= dosen ? dosen.kontak : '' %>">
          </div>
        </div>

        <div class="mb-3">
          <label for="foto" class="form-label">Foto Profil</label>
          <input type="file" class="form-control" id="foto" name="foto" accept="image/*">
          <small class="text-muted">Kosongkan jika tidak ingin mengubah foto</small>
        </div>

        <div class="mb-3">
          <label class="form-label">Mata Kuliah Diampu</label>
          <div class="mk-container">
            <% mkList.forEach(mk => { %>
              <div class="mk-item">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="mataKuliahIds" value="<%= mk.id %>" id="mk_<%= mk.id %>"
                    <%= (dosen && dosen.mataKuliahIds && dosen.mataKuliahIds.includes(mk.id)) ? 'checked' : '' %>>
                  <label class="form-check-label" for="mk_<%= mk.id %>">
                    <%= mk.kode %> - <%= mk.nama %> (SKS <%= mk.sks %>)
                  </label>
                </div>
              </div>
            <% }) %>
          </div>
          <small class="text-muted">Pilih mata kuliah yang diampu</small>
        </div>

        <div class="d-flex justify-content-between mt-4">
          <a href="/admin/dosen" class="btn-outline-gradient">
            <i class="bi bi-arrow-left me-2"></i>Kembali
          </a>
          <button type="submit" class="btn-gradient">
            <i class="bi bi-save me-2"></i>Simpan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>