<%- include('../partials/header') %>

<style>
  .track-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .track-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .btn-action {
    margin: 2px;
    border-radius: 8px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
  }
  .filter-card {
    border-radius: 1rem;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    background: white;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .table-responsive {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .avatar-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 1.2rem;
  }
  .badge-status {
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
  }
  .badge-bekerja { background: #28a745; color: white; }
  .badge-wirausaha { background: #ffc107; color: #212529; }
  .badge-kuliah { background: #17a2b8; color: white; }
  .badge-belum { background: #6c757d; color: white; }
  .modal-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
</style>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Track Lulusan</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTrackModal">
      <i class="bi bi-plus-circle me-2"></i>Tambah Data Lulusan
    </button>
  </div>

  <!-- Notifikasi Sukses -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>Data lulusan berhasil <%= success %>.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Filter Card -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-2">
        <label for="angkatan" class="form-label fw-semibold">Angkatan</label>
        <select class="form-select" id="angkatan" name="angkatan">
          <option value="">Semua</option>
          <% tahunList.forEach(t => { %>
            <option value="<%= t %>" <%= t === filterAngkatan ? 'selected' : '' %>><%= t %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label for="status" class="form-label fw-semibold">Status</label>
        <select class="form-select" id="status" name="status">
          <option value="">Semua</option>
          <option value="bekerja" <%= filterStatus === 'bekerja' ? 'selected' : '' %>>Bekerja</option>
          <option value="wirausaha" <%= filterStatus === 'wirausaha' ? 'selected' : '' %>>Wirausaha</option>
          <option value="kuliah" <%= filterStatus === 'kuliah' ? 'selected' : '' %>>Kuliah</option>
          <option value="belum bekerja" <%= filterStatus === 'belum bekerja' ? 'selected' : '' %>>Belum Bekerja</option>
        </select>
      </div>
      <div class="col-md-4">
        <label for="search" class="form-label fw-semibold">Cari Nama/NIM</label>
        <input type="text" class="form-control" id="search" name="search" value="<%= filterSearch || '' %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
      <div class="col-md-2">
        <a href="/admin/tracklulusan" class="btn btn-outline-secondary w-100">Reset</a>
      </div>
    </form>
  </div>

  <!-- Tabel Lulusan -->
  <div class="table-responsive">
    <table class="table track-table">
      <thead>
        <tr>
          <th>Foto</th>
          <th>NIM</th>
          <th>Nama</th>
          <th>Tahun Lulus</th>
          <th>Status</th>
          <th>Pekerjaan</th>
          <th>Tempat Kerja</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (lulusan.length === 0) { %>
          <tr>
            <td colspan="8" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Belum ada data lulusan.</p>
            </td>
          </tr>
        <% } %>
        <% lulusan.forEach(l => { %>
          <tr>
            <td>
              <% if (l.foto) { %>
                <img src="<%= l.foto %>" alt="foto" style="width: 40px; height: 40px; object-fit: cover; border-radius: 50%;">
              <% } else { %>
                <div class="avatar-circle"><%= (l.nama || '?').charAt(0).toUpperCase() %></div>
              <% } %>
            </td>
            <td><span class="badge bg-secondary"><%= l.nim %></span></td>
            <td><%= l.nama %></td>
            <td><%= l.tahunLulus %></td>
            <td>
              <span class="badge-status 
                <%= l.status === 'bekerja' ? 'badge-bekerja' : '' %>
                <%= l.status === 'wirausaha' ? 'badge-wirausaha' : '' %>
                <%= l.status === 'kuliah' ? 'badge-kuliah' : '' %>
                <%= l.status === 'belum bekerja' ? 'badge-belum' : '' %>">
                <%= l.status %>
              </span>
            </td>
            <td><%= l.pekerjaan || '-' %></td>
            <td><%= l.tempatKerja || '-' %></td>
            <td>
              <button class="btn btn-sm btn-warning btn-action" onclick="editTrack('<%= l.id %>')" title="Edit">
                <i class="bi bi-pencil"></i>
              </button>
              <button class="btn btn-sm btn-danger btn-action" onclick="deleteTrack('<%= l.id %>')" title="Hapus">
                <i class="bi bi-trash"></i>
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal Tambah Lulusan -->
<div class="modal fade" id="addTrackModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Tambah Data Lulusan</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/admin/tracklulusan" enctype="multipart/form-data">
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="nim" class="form-label fw-semibold">NIM <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="nim" name="nim" required>
            </div>
            <div class="col-md-6 mb-3">
              <label for="nama" class="form-label fw-semibold">Nama <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="nama" name="nama" required>
            </div>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="tahunLulus" class="form-label fw-semibold">Tahun Lulus <span class="text-danger">*</span></label>
              <input type="number" class="form-control" id="tahunLulus" name="tahunLulus" min="2000" max="2100" required>
            </div>
            <div class="col-md-6 mb-3">
              <label for="status" class="form-label fw-semibold">Status</label>
              <select class="form-select" id="status" name="status">
                <option value="bekerja">Bekerja</option>
                <option value="wirausaha">Wirausaha</option>
                <option value="kuliah">Kuliah</option>
                <option value="belum bekerja">Belum Bekerja</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="pekerjaan" class="form-label fw-semibold">Pekerjaan</label>
              <input type="text" class="form-control" id="pekerjaan" name="pekerjaan">
            </div>
            <div class="col-md-6 mb-3">
              <label for="tempatKerja" class="form-label fw-semibold">Tempat Kerja</label>
              <input type="text" class="form-control" id="tempatKerja" name="tempatKerja">
            </div>
          </div>
          <div class="mb-3">
            <label for="alamatKerja" class="form-label fw-semibold">Alamat Kerja</label>
            <input type="text" class="form-control" id="alamatKerja" name="alamatKerja">
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="gaji" class="form-label fw-semibold">Kisaran Gaji</label>
              <select class="form-select" id="gaji" name="gaji">
                <option value="">-- Pilih --</option>
                <option value="< 1 juta">Kurang dari 1 juta</option>
                <option value="1-3 juta">1 - 3 juta</option>
                <option value="3-5 juta">3 - 5 juta</option>
                <option value="5-10 juta">5 - 10 juta</option>
                <option value="> 10 juta">Lebih dari 10 juta</option>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label for="foto" class="form-label fw-semibold">Foto (opsional)</label>
              <input type="file" class="form-control" id="foto" name="foto" accept="image/*">
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Edit Lulusan -->
<div class="modal fade" id="editTrackModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Data Lulusan</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/admin/tracklulusan/update" enctype="multipart/form-data" id="editForm">
        <input type="hidden" name="id" id="editId">
        <div class="modal-body">
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="editNim" class="form-label fw-semibold">NIM <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="editNim" name="nim" required>
            </div>
            <div class="col-md-6 mb-3">
              <label for="editNama" class="form-label fw-semibold">Nama <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="editNama" name="nama" required>
            </div>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="editTahunLulus" class="form-label fw-semibold">Tahun Lulus <span class="text-danger">*</span></label>
              <input type="number" class="form-control" id="editTahunLulus" name="tahunLulus" min="2000" max="2100" required>
            </div>
            <div class="col-md-6 mb-3">
              <label for="editStatus" class="form-label fw-semibold">Status</label>
              <select class="form-select" id="editStatus" name="status">
                <option value="bekerja">Bekerja</option>
                <option value="wirausaha">Wirausaha</option>
                <option value="kuliah">Kuliah</option>
                <option value="belum bekerja">Belum Bekerja</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="editPekerjaan" class="form-label fw-semibold">Pekerjaan</label>
              <input type="text" class="form-control" id="editPekerjaan" name="pekerjaan">
            </div>
            <div class="col-md-6 mb-3">
              <label for="editTempatKerja" class="form-label fw-semibold">Tempat Kerja</label>
              <input type="text" class="form-control" id="editTempatKerja" name="tempatKerja">
            </div>
          </div>
          <div class="mb-3">
            <label for="editAlamatKerja" class="form-label fw-semibold">Alamat Kerja</label>
            <input type="text" class="form-control" id="editAlamatKerja" name="alamatKerja">
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="editGaji" class="form-label fw-semibold">Kisaran Gaji</label>
              <select class="form-select" id="editGaji" name="gaji">
                <option value="">-- Pilih --</option>
                <option value="< 1 juta">Kurang dari 1 juta</option>
                <option value="1-3 juta">1 - 3 juta</option>
                <option value="3-5 juta">3 - 5 juta</option>
                <option value="5-10 juta">5 - 10 juta</option>
                <option value="> 10 juta">Lebih dari 10 juta</option>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label for="editFoto" class="form-label fw-semibold">Foto (opsional)</label>
              <input type="file" class="form-control" id="editFoto" name="foto" accept="image/*">
              <small class="text-muted">Kosongkan jika tidak ingin mengubah</small>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Update</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Form Delete (hidden) -->
<form method="POST" id="deleteForm" style="display: none;"></form>

<script>
  function editTrack(id) {
    fetch(`/admin/tracklulusan/${id}`)
      .then(res => res.json())
      .then(data => {
        document.getElementById('editId').value = id;
        document.getElementById('editNim').value = data.nim;
        document.getElementById('editNama').value = data.nama;
        document.getElementById('editTahunLulus').value = data.tahunLulus;
        document.getElementById('editStatus').value = data.status;
        document.getElementById('editPekerjaan').value = data.pekerjaan || '';
        document.getElementById('editTempatKerja').value = data.tempatKerja || '';
        document.getElementById('editAlamatKerja').value = data.alamatKerja || '';
        document.getElementById('editGaji').value = data.gaji || '';
        new bootstrap.Modal(document.getElementById('editTrackModal')).show();
      })
      .catch(err => alert('Gagal memuat data: ' + err.message));
  }

  function deleteTrack(id) {
    if (confirm('Yakin hapus data lulusan ini?')) {
      const form = document.getElementById('deleteForm');
      form.action = `/admin/tracklulusan/${id}/delete`;
      form.submit();
    }
  }
</script>

<%- include('../partials/footer') %>