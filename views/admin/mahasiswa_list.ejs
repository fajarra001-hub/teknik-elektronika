<%- include('../partials/header') %>

<style>
  .mahasiswa-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .mahasiswa-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .btn-action {
    margin: 2px;
    border-radius: 8px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
  }
  .avatar-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 1.2rem;
  }
  .filter-card {
    border-radius: 1rem;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    background: white;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .table-responsive {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .foto-mahasiswa {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 50%;
  }
</style>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Kelola Mahasiswa</h2>
    <a href="/admin/mahasiswa/create" class="btn btn-primary">
      <i class="bi bi-plus-circle me-2"></i>Tambah Mahasiswa
    </a>
  </div>

  <!-- Filter Card -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-3">
        <label for="angkatan" class="form-label fw-semibold">Angkatan</label>
        <select class="form-select" id="angkatan" name="angkatan">
          <option value="">Semua Angkatan</option>
          <% if (angkatanList && angkatanList.length) { %>
            <% angkatanList.forEach(a => { %>
              <option value="<%= a %>" <%= a === filterAngkatan ? 'selected' : '' %>><%= a %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="col-md-3">
        <label for="status" class="form-label fw-semibold">Status</label>
        <select class="form-select" id="status" name="status">
          <option value="">Semua</option>
          <option value="aktif" <%= filterStatus === 'aktif' ? 'selected' : '' %>>Aktif</option>
          <option value="lulus" <%= filterStatus === 'lulus' ? 'selected' : '' %>>Lulus</option>
          <option value="cuti" <%= filterStatus === 'cuti' ? 'selected' : '' %>>Cuti</option>
        </select>
      </div>
      <div class="col-md-4">
        <label for="search" class="form-label fw-semibold">Cari Nama/NIM</label>
        <input type="text" class="form-control" id="search" name="search" placeholder="Ketik nama atau NIM" value="<%= search || '' %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
    </form>
  </div>

  <!-- Notifikasi Sukses -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>Data mahasiswa berhasil <%= success %>.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Tabel Mahasiswa -->
  <div class="table-responsive">
    <table class="table mahasiswa-table">
      <thead>
        <tr>
          <th>Foto</th>
          <th>NIM</th>
          <th>Nama</th>
          <th>Email</th>
          <th>Angkatan</th>
          <th>Status</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (mahasiswa.length === 0) { %>
          <tr>
            <td colspan="7" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Belum ada data mahasiswa.</p>
            </td>
          </tr>
        <% } %>
        <% mahasiswa.forEach(m => { 
          let angkatan = m.nim && m.nim.length >= 2 ? '20' + m.nim.substring(0,2) : '-';
        %>
        <tr>
          <td>
            <% if (m.foto) { %>
              <img src="<%= m.foto %>" alt="foto" class="foto-mahasiswa">
            <% } else { %>
              <div class="avatar-circle"><%= (m.nama || '?').charAt(0).toUpperCase() %></div>
            <% } %>
          </td>
          <td><span class="badge bg-secondary"><%= m.nim || '-' %></span></td>
          <td><%= m.nama %></td>
          <td><%= m.email %></td>
          <td><%= angkatan %></td>
          <td>
            <span class="badge bg-<%= m.status === 'aktif' ? 'success' : (m.status === 'lulus' ? 'info' : 'warning') %>">
              <%= m.status || 'aktif' %>
            </span>
          </td>
          <td>
            <a href="/admin/mahasiswa/<%= m.id %>" class="btn btn-sm btn-info btn-action" title="Detail">
              <i class="bi bi-eye"></i>
            </a>
            <a href="/admin/mahasiswa/<%= m.id %>/edit" class="btn btn-sm btn-warning btn-action" title="Edit">
              <i class="bi bi-pencil"></i>
            </a>
            <button class="btn btn-sm btn-secondary btn-action" title="Reset Password" onclick="resetPassword('<%= m.email %>')">
              <i class="bi bi-key"></i>
            </button>
            <form method="POST" action="/admin/mahasiswa/<%= m.id %>/delete" style="display:inline;" onsubmit="return confirm('Yakin hapus mahasiswa ini? Semua data terkait akan hilang.')">
              <button type="submit" class="btn btn-sm btn-danger btn-action" title="Hapus">
                <i class="bi bi-trash"></i>
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<script>
  function resetPassword(email) {
    if (confirm(`Kirim email reset password ke ${email}?`)) {
      fetch('/admin/users/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      }).then(res => {
        if (res.ok) alert('Email reset telah dikirim.');
        else alert('Gagal mengirim email.');
      }).catch(() => alert('Terjadi kesalahan.'));
    }
  }
</script>

<%- include('../partials/footer') %>