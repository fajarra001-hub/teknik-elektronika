<%- include('../partials/header') %>

<style>
  .dosen-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .dosen-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .btn-action {
    margin: 2px;
    border-radius: 8px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
  }
  .filter-card {
    border-radius: 1rem;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    background: white;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .table-responsive {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .avatar-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 1.2rem;
  }
  .foto-dosen {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 50%;
  }
</style>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Kelola Dosen</h2>
    <a href="/admin/dosen/create" class="btn btn-primary">
      <i class="bi bi-plus-circle me-2"></i>Tambah Dosen
    </a>
  </div>

  <!-- Notifikasi Sukses (opsional) -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>Data dosen berhasil <%= success %>.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Tabel Dosen -->
  <div class="table-responsive">
    <table class="table dosen-table">
      <thead>
        <tr>
          <th>Foto</th>
          <th>NIP</th>
          <th>Nama</th>
          <th>Email</th>
          <th>Kontak</th>
          <th>Mata Kuliah Diampu</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (dosen.length === 0) { %>
          <tr>
            <td colspan="7" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Belum ada data dosen.</p>
            </td>
          </tr>
        <% } %>
        <% dosen.forEach(d => { %>
        <tr>
          <td>
            <% if (d.foto) { %>
              <img src="<%= d.foto %>" alt="foto" class="foto-dosen">
            <% } else { %>
              <div class="avatar-circle"><%= (d.nama || '?').charAt(0).toUpperCase() %></div>
            <% } %>
          </td>
          <td><%= d.nip || '-' %></td>
          <td><%= d.nama %></td>
          <td><%= d.email %></td>
          <td><%= d.kontak || '-' %></td>
          <td>
            <% if (d.mataKuliahIds && d.mataKuliahIds.length > 0) { %>
              <ul class="list-unstyled mb-0 small">
                <% d.mataKuliahIds.slice(0, 3).forEach(mkId => { %>
                  <li><span class="badge bg-primary bg-opacity-10 text-primary"><%= mkId %></span></li>
                <% }) %>
                <% if (d.mataKuliahIds.length > 3) { %>
                  <li class="text-muted">+ <%= d.mataKuliahIds.length - 3 %> lainnya</li>
                <% } %>
              </ul>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </td>
          <td>
            <a href="/admin/dosen/<%= d.id %>/edit" class="btn btn-sm btn-warning btn-action" title="Edit">
              <i class="bi bi-pencil"></i> Edit
            </a>
            <form method="POST" action="/admin/dosen/<%= d.id %>/delete" style="display:inline;" onsubmit="return confirm('Yakin hapus dosen ini?')">
              <button type="submit" class="btn btn-sm btn-danger btn-action" title="Hapus">
                <i class="bi bi-trash"></i> Hapus
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>