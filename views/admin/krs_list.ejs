<%- include('../partials/header') %>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --danger-bg: #fee2e2;
    --danger-text: #991b1b;
    --info-bg: #dbeafe;
    --info-text: #1e40af;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== FILTER CARD ===== */
  .filter-card {
    border-radius: 1.2rem;
    border: 1px solid rgba(30,58,138,0.1);
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    background: white;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .filter-card .form-label {
    font-weight: 600;
    color: #1e293b;
    font-size: 0.9rem;
  }
  .filter-card .form-select,
  .filter-card .form-control {
    border-radius: 50px;
    border: 1px solid #dee2e6;
    padding: 0.6rem 1rem;
    transition: all 0.2s;
    font-size: 0.95rem;
  }
  .filter-card .form-select:focus,
  .filter-card .form-control:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.25rem rgba(30,58,138,0.25);
  }
  .btn-filter {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
    width: 100%;
  }
  .btn-filter:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }
  .btn-reset {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    width: 100%;
    display: inline-block;
    text-align: center;
    text-decoration: none;
  }
  .btn-reset:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(30,58,138,0.3);
  }

  /* ===== TABEL ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .krs-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .krs-table thead th {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
    padding: 1rem;
    white-space: nowrap;
    text-align: left;
  }
  .krs-table tbody td {
    vertical-align: middle;
    padding: 1rem;
    border-bottom: 1px solid #e9ecef;
    font-size: 0.95rem;
  }
  .krs-table tbody tr:hover td {
    background-color: #f8fafc;
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    border: 1px solid transparent;
  }
  .badge-pending {
    background: var(--warning-bg);
    color: var(--warning-text);
    border-color: #fde68a;
  }
  .badge-approved {
    background: var(--success-bg);
    color: var(--success-text);
    border-color: #a7f3d0;
  }
  .badge-rejected {
    background: var(--danger-bg);
    color: var(--danger-text);
    border-color: #fecaca;
  }
  .badge-stored {
    background: var(--info-bg);
    color: var(--info-text);
    border-color: #bfdbfe;
  }

  /* ===== TOMBOL AKSI ===== */
  .btn-icon-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
    color: white;
    margin: 2px;
    background: transparent;
  }
  .btn-icon-sm i {
    font-size: 1rem;
  }
  .btn-approve {
    background: #10b981;
  }
  .btn-approve:hover {
    background: #059669;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(16,185,129,0.3);
  }
  .btn-reject {
    background: #ef4444;
  }
  .btn-reject:hover {
    background: #dc2626;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(239,68,68,0.3);
  }
  .btn-detail {
    background: var(--primary-start);
  }
  .btn-detail:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }
  .btn-delete {
    background: #6c757d;
  }
  .btn-delete:hover {
    background: #5a6268;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(108,117,125,0.3);
  }
  .btn-outline-file {
    padding: 0.3rem 1rem;
    font-size: 0.8rem;
    border-radius: 50px;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    background: transparent;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .btn-outline-file:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(30,58,138,0.3);
  }

  /* ===== AVATAR ===== */
  .avatar-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 1.2rem;
    box-shadow: 0 5px 10px rgba(30,58,138,0.2);
  }

  /* ===== MATA KULIAH BADGE ===== */
  .mk-badge {
    background: var(--primary-light);
    color: var(--primary-dark);
    padding: 0.2rem 0.6rem;
    border-radius: 50px;
    font-size: 0.75rem;
    display: inline-block;
    margin-right: 0.2rem;
    margin-bottom: 0.2rem;
    border: 1px solid rgba(30,58,138,0.2);
  }

  /* ===== ALERT ===== */
  .alert-custom {
    border-radius: 1rem;
    border-left: 4px solid;
    padding: 1rem 1.5rem;
    background: white;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    border: 1px solid rgba(30,58,138,0.1);
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
  }
  .empty-state p {
    color: #6c757d;
    font-size: 1rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .krs-table thead th { font-size: 0.8rem; padding: 0.75rem; }
    .krs-table tbody td { font-size: 0.9rem; padding: 0.75rem; }
    .filter-card .row { flex-direction: column; }
    .btn-filter, .btn-reset { width: 100%; margin-bottom: 0.5rem; }
  }

  @media (max-width: 576px) {
    html { font-size: 14px; }
    .badge-status { font-size: 0.7rem; padding: 0.2rem 0.6rem; }
    .mk-badge { font-size: 0.7rem; }
  }
</style>

<div class="container mt-4">
  <!-- Header -->
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="font-size: 2rem;"><i class="bi bi-file-earmark-text me-2" style="color: var(--primary-start);"></i>Daftar KRS Mahasiswa</h2>
    <span class="badge p-3" style="background: linear-gradient(135deg, var(--primary-start), var(--primary-end)); color: white; font-size: 1rem; border-radius: 50px;">
      <i class="bi bi-calendar-check me-1"></i>Semester Aktif: Genap 2025/2026
    </span>
  </div>

  <!-- Notifikasi Sukses -->
  <% if (typeof success !== 'undefined' && success === 'approved') { %>
    <div class="alert alert-success alert-dismissible fade show mb-4 alert-custom" role="alert" style="border-left-color: #10b981;">
      <i class="bi bi-check-circle-fill me-2"></i>KRS berhasil disetujui.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (typeof success !== 'undefined' && success === 'rejected') { %>
    <div class="alert alert-warning alert-dismissible fade show mb-4 alert-custom" role="alert" style="border-left-color: #f59e0b;">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>KRS ditolak.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (typeof success !== 'undefined' && success === 'deleted') { %>
    <div class="alert alert-info alert-dismissible fade show mb-4 alert-custom" role="alert" style="border-left-color: #3b82f6;">
      <i class="bi bi-trash-fill me-2"></i>KRS berhasil dihapus.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Filter Card -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-3">
        <label for="semester" class="form-label fw-semibold"><i class="bi bi-funnel me-1"></i>Filter Semester</label>
<select class="form-select" id="semester" name="semester">
  <option value="">Semua Semester</option>
  <%
    // Rentang tahun dari 2018 sampai 2028
    const startYear = 2018;
    const endYear = 2028;
    for (let year = endYear; year >= startYear; year--) {
      // Tampilkan Genap dulu (karena biasanya lebih baru)
      const genap = `Genap ${year-1}/${year}`;
      const ganjil = `Ganjil ${year-1}/${year}`;
  %>
  <option value="<%= genap %>" <%= filters && filters.semester === genap ? 'selected' : '' %>><%= genap %></option>
  <option value="<%= ganjil %>" <%= filters && filters.semester === ganjil ? 'selected' : '' %>><%= ganjil %></option>
  <% } %>
</select>
      </div>
      <div class="col-md-3">
        <label for="status" class="form-label fw-semibold"><i class="bi bi-tag me-1"></i>Filter Status</label>
        <select class="form-select" id="status" name="status">
          <option value="">Semua Status</option>
          <option value="pending" <%= filters && filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
          <option value="approved" <%= filters && filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
          <option value="rejected" <%= filters && filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
          <option value="stored" <%= filters && filters.status === 'stored' ? 'selected' : '' %>>Stored</option>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn-filter">Terapkan</button>
      </div>
      <div class="col-md-2">
        <a href="/admin/krs" class="btn-reset">Reset</a>
      </div>
    </form>
  </div>

  <!-- Tabel KRS -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table krs-table">
        <thead>
          <tr>
            <th>No</th>
            <th>Mahasiswa</th>
            <th>Semester</th>
            <th>Mata Kuliah</th>
            <th>File KRS</th>
            <th>Status</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% if (krsList.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <h4>Belum Ada KRS</h4>
                  <p class="text-muted">Belum ada KRS yang diajukan mahasiswa.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% krsList.forEach((krs, index) => { %>
            <tr>
              <td class="fw-bold"><%= index + 1 %></td>
              <td>
                <div class="d-flex align-items-center">
                  <% if (krs.mahasiswa?.foto) { 
                    const fileId = krs.mahasiswa.foto.match(/[?&]id=([^&]+)/) || krs.mahasiswa.foto.match(/\/d\/([^\/]+)/);
                    const imgUrl = fileId ? `https://drive.google.com/thumbnail?id=${fileId[1]}&sz=w100` : krs.mahasiswa.foto;
                  %>
                    <img src="<%= imgUrl %>" alt="foto" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover; border: 2px solid var(--primary-start);"
                         onerror="this.onerror=null; this.src='<%= krs.mahasiswa.foto %>';">
                  <% } else { %>
                    <div class="avatar-circle me-2"><%= (krs.mahasiswa?.nama || '?').charAt(0).toUpperCase() %></div>
                  <% } %>
                  <div>
                    <strong><%= krs.mahasiswa?.nama || 'Unknown' %></strong><br>
                    <small class="text-muted"><%= krs.mahasiswa?.nim || '-' %></small>
                  </div>
                </div>
              </td>
              <td><span class="fw-semibold"><%= krs.semester || '-' %></span></td>
              <td>
                <% if (krs.courses && krs.courses.length > 0) { %>
                  <div>
                    <% krs.courses.slice(0, 2).forEach(c => { %>
                      <span class="mk-badge"><%= c.kode %> - <%= c.nama.length > 15 ? c.nama.substring(0,15)+'...' : c.nama %></span>
                    <% }) %>
                    <% if (krs.courseCount > 2) { %>
                      <span class="mk-badge" style="background: #e9ecef; color: #6c757d;">+ <%= krs.courseCount - 2 %> lainnya</span>
                    <% } %>
                  </div>
                <% } else { %>
                  <span class="text-muted">-</span>
                <% } %>
              </td>
              <td>
                <% if (krs.driveFileLink) { %>
                  <a href="<%= krs.driveFileLink %>" target="_blank" class="btn-outline-file">
                    <i class="bi bi-file-earmark-pdf me-1"></i> Lihat
                  </a>
                <% } else { %>
                  <span class="badge bg-secondary">Tidak ada file</span>
                <% } %>
              </td>
              <td>
                <% if (krs.status === 'pending') { %>
                  <span class="badge-status badge-pending"><i class="bi bi-hourglass-split"></i> Menunggu</span>
                <% } else if (krs.status === 'approved') { %>
                  <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i> Disetujui</span>
                <% } else if (krs.status === 'rejected') { %>
                  <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i> Ditolak</span>
                <% } else if (krs.status === 'stored') { %>
                  <span class="badge-status badge-stored"><i class="bi bi-database"></i> Tersimpan</span>
                <% } %>
              </td>
              <td>
                <div class="d-flex flex-wrap gap-1">
                  <% if (krs.status === 'pending') { %>
                    <form method="POST" action="/admin/krs/<%= krs.id %>/approve" style="display:inline;">
                      <button class="btn-icon-sm btn-approve" title="Setujui"><i class="bi bi-check-lg"></i></button>
                    </form>
                    <form method="POST" action="/admin/krs/<%= krs.id %>/reject" style="display:inline;">
                      <button class="btn-icon-sm btn-reject" title="Tolak"><i class="bi bi-x-lg"></i></button>
                    </form>
                  <% } %>
                  <a href="/admin/krs/<%= krs.id %>" class="btn-icon-sm btn-detail" title="Detail"><i class="bi bi-eye"></i></a>
                  <form method="POST" action="/admin/krs/delete/<%= krs.id %>" style="display:inline;" onsubmit="return confirm('Hapus KRS ini? File di Drive juga akan dihapus.')">
                    <button class="btn-icon-sm btn-delete" title="Hapus"><i class="bi bi-trash"></i></button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>