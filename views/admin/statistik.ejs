<%- include('../partials/header') %>

<style>
  .stat-form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow: hidden;
  }
  .stat-form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 1.5rem;
    color: white;
  }
  .stat-form-header h3 {
    margin: 0;
    font-weight: 600;
  }
  .stat-form-body {
    padding: 2rem;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
  .angkatan-row {
    background: #f8f9fa;
    border-radius: 0.75rem;
    padding: 1rem;
    margin-bottom: 0.75rem;
    align-items: center;
  }
  .form-label {
    font-weight: 600;
    color: #1e293b;
  }
  .form-control, .form-select {
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid #cbd5e1;
    transition: all 0.3s;
  }
  .form-control:focus, .form-select:focus {
    border-color: #2193b0;
    box-shadow: 0 0 0 0.2rem rgba(33,147,176,0.25);
  }
</style>

<div class="container-fluid mt-4">
  <div class="stat-form-card">
    <div class="stat-form-header">
      <h3><i class="bi bi-pie-chart me-2"></i>Kelola Statistik Prodi</h3>
    </div>
    <div class="stat-form-body">
      <!-- Notifikasi Sukses -->
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
          <i class="bi bi-check-circle-fill me-2"></i>Statistik berhasil <%= success %>.
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <form method="POST" action="/admin/statistik" id="statForm">
        <!-- Jumlah Mahasiswa Aktif -->
        <div class="row mb-4">
          <div class="col-md-6">
            <label for="mahasiswaAktif" class="form-label">Jumlah Mahasiswa Aktif</label>
            <input type="number" class="form-control" id="mahasiswaAktif" name="mahasiswaAktif" 
                   value="<%= statistik.mahasiswaAktif || 0 %>" min="0" required>
          </div>
          <div class="col-md-6">
            <label for="mahasiswaMagang" class="form-label">Jumlah Mahasiswa Magang</label>
            <input type="number" class="form-control" id="mahasiswaMagang" name="mahasiswaMagang" 
                   value="<%= statistik.mahasiswaMagang || 0 %>" min="0" required>
          </div>
        </div>

        <!-- Data Angkatan -->
        <h5 class="fw-bold mb-3">Data Angkatan</h5>
        <div id="angkatanContainer">
          <% if (statistik.angkatan && statistik.angkatan.length > 0) { %>
            <% statistik.angkatan.forEach((a, index) => { %>
              <div class="row angkatan-row" id="row-<%= index %>">
                <div class="col-md-5">
                  <input type="text" class="form-control" name="angkatan[<%= index %>][tahun]" 
                         placeholder="Tahun (contoh: 2023)" value="<%= a.tahun %>" required>
                </div>
                <div class="col-md-5">
                  <input type="number" class="form-control" name="angkatan[<%= index %>][jumlah]" 
                         placeholder="Jumlah Mahasiswa" value="<%= a.jumlah %>" min="0" required>
                </div>
                <div class="col-md-2">
                  <button type="button" class="btn btn-outline-danger w-100" onclick="hapusAngkatan(<%= index %>)">
                    <i class="bi bi-trash"></i> Hapus
                  </button>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <!-- Jika belum ada data, tampilkan satu baris kosong -->
            <div class="row angkatan-row" id="row-0">
              <div class="col-md-5">
                <input type="text" class="form-control" name="angkatan[0][tahun]" placeholder="Tahun (contoh: 2023)" required>
              </div>
              <div class="col-md-5">
                <input type="number" class="form-control" name="angkatan[0][jumlah]" placeholder="Jumlah Mahasiswa" min="0" required>
              </div>
              <div class="col-md-2">
                <button type="button" class="btn btn-outline-danger w-100" onclick="hapusAngkatan(0)">
                  <i class="bi bi-trash"></i> Hapus
                </button>
              </div>
            </div>
          <% } %>
        </div>

        <!-- Tombol Tambah Angkatan -->
        <div class="text-center mt-3">
          <button type="button" class="btn btn-outline-gradient" onclick="tambahAngkatan()">
            <i class="bi bi-plus-circle me-2"></i>Tambah Angkatan
          </button>
        </div>

        <!-- Tombol Simpan -->
        <div class="d-flex justify-content-between mt-4">
          <a href="/admin/dashboard" class="btn-outline-gradient">
            <i class="bi bi-arrow-left me-2"></i>Kembali ke Dashboard
          </a>
          <button type="submit" class="btn-gradient">
            <i class="bi bi-save me-2"></i>Simpan Statistik
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  let angkatanIndex = <%= statistik.angkatan ? statistik.angkatan.length : 1 %>;

  function tambahAngkatan() {
    const container = document.getElementById('angkatanContainer');
    const newRow = document.createElement('div');
    newRow.className = 'row angkatan-row';
    newRow.id = `row-${angkatanIndex}`;
    newRow.innerHTML = `
      <div class="col-md-5">
        <input type="text" class="form-control" name="angkatan[${angkatanIndex}][tahun]" placeholder="Tahun (contoh: 2023)" required>
      </div>
      <div class="col-md-5">
        <input type="number" class="form-control" name="angkatan[${angkatanIndex}][jumlah]" placeholder="Jumlah Mahasiswa" min="0" required>
      </div>
      <div class="col-md-2">
        <button type="button" class="btn btn-outline-danger w-100" onclick="hapusAngkatan(${angkatanIndex})">
          <i class="bi bi-trash"></i> Hapus
        </button>
      </div>
    `;
    container.appendChild(newRow);
    angkatanIndex++;
  }

  function hapusAngkatan(id) {
    const row = document.getElementById(`row-${id}`);
    if (row) {
      row.remove();
    }
  }
</script>

<%- include('../partials/footer') %>