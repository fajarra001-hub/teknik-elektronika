<%- include('../partials/header') %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Mahasiswa Angkatan <%= tahun %></h2>
    <a href="/admin/berkas" class="btn btn-outline-secondary">Kembali</a>
  </div>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>NIM</th>
        <th>Nama</th>
        <th>Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% mahasiswa.forEach(m => { %>
        <tr>
          <td><%= m.nim %></td>
          <td><%= m.nama %></td>
          <td>
            <a href="/admin/berkas/mahasiswa/<%= m.id %>" class="btn btn-sm btn-primary">Lihat Berkas</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>