<%- include('../partials/header') %>

<style>
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 2rem;
    color: white;
  }
  .form-header h2 {
    font-weight: 700;
  }
  .form-body {
    padding: 2rem;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 600;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
</style>

<div class="container-fluid mt-4">
  <div class="form-card">
    <div class="form-header">
      <h2><i class="bi bi-cash-coin me-2"></i><%= mode === 'tambah' ? 'Tambah Tagihan' : 'Edit Tagihan' %></h2>
      <p class="mb-0">Mahasiswa: <%= mahasiswa.nama %> (NIM: <%= mahasiswa.nim || '-' %>)</p>
    </div>
    <div class="form-body">
      <form method="POST" action="<%= mode === 'tambah' ? `/admin/tagihan/mahasiswa/${mahasiswa.id}/tambah` : `/admin/tagihan/mahasiswa/${mahasiswa.id}/edit/${tagihanId}` %>">
        <div class="mb-3">
          <label for="semester" class="form-label fw-bold">Semester <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="semester" name="semester" value="<%= tagihan ? tagihan.semester : '' %>" placeholder="Contoh: Ganjil 2025/2026" required>
        </div>
        <div class="mb-3">
          <label for="jumlah" class="form-label fw-bold">Jumlah (Rp) <span class="text-danger">*</span></label>
          <input type="number" class="form-control" id="jumlah" name="jumlah" value="<%= tagihan ? tagihan.jumlah : '' %>" min="0" step="500" required>
        </div>
        <div class="mb-3">
          <label for="jatuhTempo" class="form-label fw-bold">Jatuh Tempo</label>
          <input type="date" class="form-control" id="jatuhTempo" name="jatuhTempo" value="<%= tagihan && tagihan.jatuhTempo ? tagihan.jatuhTempo.split('T')[0] : '' %>">
        </div>
        <div class="mb-3">
          <label for="status" class="form-label fw-bold">Status</label>
          <select class="form-select" id="status" name="status">
            <option value="belum lunas" <%= tagihan && tagihan.status === 'belum lunas' ? 'selected' : '' %>>Belum Lunas</option>
            <option value="lunas" <%= tagihan && tagihan.status === 'lunas' ? 'selected' : '' %>>Lunas</option>
          </select>
        </div>
        <div class="d-flex gap-3">
          <button type="submit" class="btn-gradient"><i class="bi bi-save me-2"></i>Simpan</button>
          <a href="/admin/tagihan/mahasiswa/<%= mahasiswa.id %>" class="btn-outline-gradient"><i class="bi bi-arrow-left me-2"></i>Kembali</a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>