<%- include('../partials/header') %>

<style>
  .rekap-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .rekap-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .table-responsive {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
</style>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Rekap Pengajaran per Semester</h2>
    <a href="/admin/pengajaran" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <div class="table-responsive">
    <table class="table rekap-table">
      <thead>
        <tr>
          <th>Semester</th>
          <th>Jumlah MK</th>
          <th>Total Pertemuan</th>
          <th>Total Terlaksana</th>
          <th>Persentase</th>
          <th>Progress</th>
        </tr>
      </thead>
      <tbody>
        <% if (rekapList.length === 0) { %>
          <tr>
            <td colspan="6" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Belum ada data mata kuliah.</p>
            </td>
          </tr>
        <% } %>
        <% rekapList.forEach(r => { %>
          <tr>
            <td><%= r.semester %></td>
            <td class="text-center"><%= r.totalMk %></td>
            <td class="text-center"><%= r.totalPertemuan %></td>
            <td class="text-center"><%= r.totalTerlaksana %></td>
            <td class="text-center"><%= r.rataPersentase %>%</td>
            <td style="min-width: 150px;">
              <div class="progress" style="height: 8px;">
                <div class="progress-bar bg-success" role="progressbar" style="width: <%= r.rataPersentase %>%"></div>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>