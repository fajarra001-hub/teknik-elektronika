<%- include('../partials/header') %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Berkas Mahasiswa: <%= mahasiswa.nama %> (<%= mahasiswa.nim %>)</h2>
    <a href="javascript:history.back()" class="btn btn-outline-secondary">Kembali</a>
  </div>

  <h4>KRS</h4>
  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Semester</th>
        <th>Tanggal Dibuat</th>
        <th>Status</th>
        <th>Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% krsList.forEach(krs => { %>
        <tr>
          <td><%= krs.semester || '-' %></td>
          <td><%= krs.createdAt ? new Date(krs.createdAt).toLocaleDateString('id-ID') : '-' %></td>
          <td><%= krs.status || '-' %></td>
          <td>
            <a href="/admin/berkas/krs/<%= krs.id %>" class="btn btn-sm btn-info">Detail</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <h4 class="mt-4">KHS</h4>
  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Semester</th>
        <th>IP</th>
        <th>Aksi</th>
      </tr>
    </thead>
    <tbody>
      <% khsList.forEach(khs => { %>
        <tr>
          <td><%= khs.semester || '-' %></td>
          <td><%= khs.ip || '-' %></td>
          <td>
            <a href="/admin/berkas/khs/<%= khs.id %>" class="btn btn-sm btn-info">Detail</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>