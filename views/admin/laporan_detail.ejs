<%- include('../partials/header') %>

<%
  // Set default values to prevent undefined errors
  if (typeof laporanList === 'undefined') laporanList = [];
  // Pastikan mahasiswa terdefinisi
  const mhs = typeof mahasiswa !== 'undefined' ? mahasiswa : { nama: 'Unknown', nim: '-' };
%>

<% if (typeof success !== 'undefined' && success === 'updated') { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i>Status laporan berhasil diperbarui.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } else if (typeof success !== 'undefined' && success === 'deleted') { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i>Laporan berhasil dihapus.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } else if (typeof success !== 'undefined' && success === 'comment') { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i>Komentar berhasil ditambahkan.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<style>
  /* ===== VARIABEL WARNA ===== */
  :root {
    --primary-start: #2193b0;
    --primary-end: #6dd5ed;
    --primary-light: rgba(33,147,176,0.1);
    --primary-dark: #1a7a8f;
  }

  /* ===== HEADER ===== */
  .page-header {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(33,147,176,0.25);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .page-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }
  .page-header p {
    margin-bottom: 0;
    opacity: 0.9;
    position: relative;
    z-index: 1;
  }
  .btn-back {
    background: white;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    color: var(--primary-start);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    border: none;
  }
  .btn-back:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }

  /* ===== LAPORAN CARD ===== */
  .laporan-card {
    background: white;
    border-radius: 1.2rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(33,147,176,0.1);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .laporan-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 35px rgba(33,147,176,0.15);
  }
  .laporan-title {
    font-weight: 700;
    color: var(--primary-dark);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--primary-light);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .laporan-title i {
    color: var(--primary-start);
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.85rem;
    background: #f8f9fa;
    border: 1px solid transparent;
  }
  .badge-submitted {
    background: #fff3cd;
    color: #856404;
    border-color: #ffeeba;
  }
  .badge-approved {
    background: #d4edda;
    color: #155724;
    border-color: #c3e6cb;
  }
  .badge-rejected {
    background: #f8d7da;
    color: #721c24;
    border-color: #f5c6cb;
  }

  /* ===== TOMBOL ===== */
  .btn-icon-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
    color: white;
  }
  .btn-icon-sm i {
    font-size: 1rem;
  }
  .btn-update {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-update:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(33,147,176,0.3);
  }
  .btn-delete {
    background: #dc3545;
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-delete:hover {
    background: #c82333;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(220,53,69,0.3);
  }
  .btn-gradient {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
  }

  /* ===== KOMENTAR ===== */
  .komentar-section {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px dashed #dee2e6;
  }
  .komentar-item {
    background-color: #f8f9fa;
    border-radius: 1rem;
    padding: 0.75rem 1rem;
    margin-bottom: 0.75rem;
    border-left: 4px solid var(--primary-start);
  }
  .komentar-item .penulis {
    font-weight: 600;
    color: #1e293b;
  }
  .komentar-item .tanggal {
    font-size: 0.7rem;
    color: #6c757d;
  }
  .komentar-item p {
    margin-top: 0.3rem;
    margin-bottom: 0;
    font-size: 0.9rem;
  }
  .komentar-form textarea {
    border-radius: 1rem;
    border: 1px solid #ced4da;
    transition: all 0.2s;
  }
  .komentar-form textarea:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.2rem rgba(33,147,176,0.25);
  }
</style>

<div class="container-fluid mt-4">
  <!-- Header -->
  <div class="page-header d-flex flex-wrap justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-file-earmark-pdf-fill me-2"></i>Laporan Magang - <%= mhs.nama %></h2>
      <p class="mb-0"><i class="bi bi-qr-code me-2"></i>NIM: <%= mhs.nim %></p>
    </div>
    <a href="/admin/laporan-magang/rekap" class="btn-back mt-2 mt-sm-0">
      <i class="bi bi-arrow-left"></i> Kembali
    </a>
  </div>

  <% if (!laporanList || laporanList.length === 0) { %>
    <div class="alert alert-info">
      <i class="bi bi-info-circle me-2"></i>Mahasiswa ini belum mengupload laporan apapun.
    </div>
  <% } %>

  <% for (let i = 1; i <= 3; i++) { 
    const laporan = laporanList.find(l => l.laporanKe === i);
  %>
    <div class="laporan-card">
      <div class="laporan-title">
        <i class="bi bi-file-earmark-pdf"></i> Laporan Magang <%= i %>
        <% if (laporan) { %>
          <span class="badge-status 
            <%= laporan.status === 'submitted' ? 'badge-submitted' : '' %>
            <%= laporan.status === 'approved' ? 'badge-approved' : '' %>
            <%= laporan.status === 'rejected' ? 'badge-rejected' : '' %>">
            <i class="bi 
              <%= laporan.status === 'submitted' ? 'bi-hourglass-split' : '' %>
              <%= laporan.status === 'approved' ? 'bi-check-circle' : '' %>
              <%= laporan.status === 'rejected' ? 'bi-x-circle' : '' %>">
            </i>
            <%= laporan.status === 'submitted' ? 'Menunggu' : (laporan.status === 'approved' ? 'Disetujui' : (laporan.status === 'rejected' ? 'Ditolak' : laporan.status)) %>
          </span>
        <% } %>
      </div>

      <% if (laporan) { %>
        <div class="row">
          <div class="col-md-7">
            <table class="table table-borderless mb-3" style="width: auto;">
              <tr>
                <td><strong>File:</strong></td>
                <td><a href="<%= laporan.fileUrl %>" target="_blank" class="text-decoration-none"><i class="bi bi-file-earmark-pdf text-danger me-1"></i><%= laporan.fileName || 'file.pdf' %></a></td>
              </tr>
              <tr>
                <td><strong>Diunggah:</strong></td>
                <td><%= laporan.uploadedAt ? new Date(laporan.uploadedAt).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '-' %></td>
              </tr>
              <% if (laporan.catatanAdmin) { %>
                <tr>
                  <td><strong>Catatan:</strong></td>
                  <td><%= laporan.catatanAdmin %></td>
                </tr>
              <% } %>
            </table>
          </div>
          <div class="col-md-5">
            <form method="POST" action="/admin/laporan-magang/<%= laporan.id %>/status" class="mb-2">
              <div class="input-group">
                <select name="status" class="form-select" style="border-radius: 50px 0 0 50px;">
                  <option value="submitted" <%= laporan.status === 'submitted' ? 'selected' : '' %>>Menunggu</option>
                  <option value="approved" <%= laporan.status === 'approved' ? 'selected' : '' %>>Disetujui</option>
                  <option value="rejected" <%= laporan.status === 'rejected' ? 'selected' : '' %>>Ditolak</option>
                </select>
                <input type="text" name="catatan" class="form-control" placeholder="Catatan" value="<%= laporan.catatanAdmin || '' %>" style="border-radius: 0;">
                <button type="submit" class="btn-update" style="border-radius: 0 50px 50px 0; padding: 0.5rem 1rem;">
                  <i class="bi bi-check-lg"></i> Update
                </button>
              </div>
            </form>
            <form method="POST" action="/admin/laporan-magang/<%= laporan.id %>/delete" onsubmit="return confirm('Hapus laporan ini? File di Drive juga akan dihapus.')">
              <button type="submit" class="btn-delete w-100">
                <i class="bi bi-trash me-2"></i>Hapus Laporan
              </button>
            </form>
          </div>
        </div>

        <!-- KOMENTAR SECTION -->
        <div class="komentar-section">
          <h5 class="fw-bold mb-3"><i class="bi bi-chat-dots me-2"></i>Komentar</h5>

          <!-- Daftar komentar -->
          <% if (laporan.komentar && laporan.komentar.length > 0) { %>
            <% laporan.komentar.sort((a, b) => new Date(b.tanggal) - new Date(a.tanggal)).forEach(k => { %>
              <div class="komentar-item">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="penulis"><%= k.penulis %></span>
                  <span class="tanggal"><%= new Date(k.tanggal).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></span>
                </div>
                <p><%= k.isi %></p>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-muted small">Belum ada komentar.</p>
          <% } %>

          <!-- Form tambah komentar -->
          <div class="komentar-form mt-3">
            <form method="POST" action="/admin/laporan-magang/<%= laporan.id %>/comment">
              <div class="mb-2">
                <textarea class="form-control" name="isi" rows="2" placeholder="Tulis komentar..." required></textarea>
              </div>
              <button type="submit" class="btn-gradient btn-sm">
                <i class="bi bi-send me-2"></i>Kirim Komentar
              </button>
            </form>
          </div>
        </div>
      <% } else { %>
        <p class="text-muted"><i class="bi bi-dash-circle me-2"></i>Belum ada laporan diupload.</p>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>