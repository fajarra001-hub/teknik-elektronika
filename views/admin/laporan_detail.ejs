<%- include('../partials/header') %>

<style>
  .detail-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-radius: 1rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
  }
  .laporan-card {
    background: white;
    border-radius: 1rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
</style>

<div class="container-fluid mt-4">
  <div class="detail-header d-flex justify-content-between align-items-center">
    <div>
      <h2><i class="bi bi-file-earmark-pdf me-2"></i>Laporan Magang - <%= mahasiswa.nama || 'Unknown' %></h2>
      <p class="mb-0 opacity-75">NIM: <%= mahasiswa.nim || '-' %></p>
    </div>
    <a href="/admin/laporan-magang" class="btn btn-light">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <% if (!laporanList || laporanList.length === 0) { %>
    <div class="alert alert-info">Mahasiswa ini belum mengupload laporan apapun.</div>
  <% } %>

  <% for (let i = 1; i <= 3; i++) { 
    const laporan = laporanList ? laporanList.find(l => l.laporanKe === i) : null;
  %>
    <div class="laporan-card">
      <h5 class="fw-bold mb-3">Laporan Magang <%= i %></h5>
      <% if (laporan) { %>
        <div class="row">
          <div class="col-md-6">
            <p><strong>File:</strong> <a href="<%= laporan.fileUrl || '#' %>" target="_blank"><%= laporan.fileName || 'file.pdf' %></a></p>
            <p><strong>Diunggah:</strong> <%= laporan.uploadedAt ? new Date(laporan.uploadedAt).toLocaleString('id-ID') : '-' %></p>
            <p><strong>Status:</strong> 
              <% if (laporan.status === 'submitted') { %>
                <span class="badge bg-warning text-dark">Menunggu</span>
              <% } else if (laporan.status === 'approved') { %>
                <span class="badge bg-success">Disetujui</span>
              <% } else if (laporan.status === 'rejected') { %>
                <span class="badge bg-danger">Ditolak</span>
              <% } else { %>
                <span class="badge bg-secondary"><%= laporan.status || '-' %></span>
              <% } %>
            </p>
            <% if (laporan.catatanAdmin) { %>
              <p><strong>Catatan:</strong> <%= laporan.catatanAdmin %></p>
            <% } %>
          </div>
          <div class="col-md-6">
            <form method="POST" action="/admin/laporan-magang/<%= laporan.id %>/status" class="mb-2">
              <div class="input-group">
                <select name="status" class="form-select form-select-sm">
                  <option value="submitted" <%= laporan.status === 'submitted' ? 'selected' : '' %>>Menunggu</option>
                  <option value="approved" <%= laporan.status === 'approved' ? 'selected' : '' %>>Disetujui</option>
                  <option value="rejected" <%= laporan.status === 'rejected' ? 'selected' : '' %>>Ditolak</option>
                </select>
                <input type="text" name="catatan" class="form-control form-control-sm" placeholder="Catatan" value="<%= laporan.catatanAdmin || '' %>">
                <button type="submit" class="btn btn-sm btn-primary">Update</button>
              </div>
            </form>
            <form method="POST" action="/admin/laporan-magang/<%= laporan.id %>/hapus" onsubmit="return confirm('Hapus laporan ini? File di Drive juga akan dihapus.')">
              <button type="submit" class="btn btn-sm btn-danger w-100">Hapus Laporan</button>
            </form>
          </div>
        </div>
      <% } else { %>
        <p class="text-muted">Belum ada laporan.</p>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>