<%- include('../partials/header') %>

<style>
  .form-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    overflow: hidden;
    max-width: 800px;
    margin: 0 auto;
  }
  .form-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 1.5rem;
    color: white;
  }
  .form-header h3 {
    margin: 0;
    font-weight: 600;
  }
  .form-body {
    padding: 2rem;
  }
  .btn-gradient {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-gradient:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(33,147,176,0.3);
    color: white;
  }
  .btn-outline-gradient {
    background: transparent;
    border: 2px solid #2193b0;
    color: #2193b0;
    font-weight: 500;
    padding: 0.6rem 2rem;
    border-radius: 50px;
    transition: all 0.3s;
  }
  .btn-outline-gradient:hover {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-color: transparent;
    color: white;
  }
  .form-label {
    font-weight: 600;
    color: #1e293b;
  }
  .form-control, .form-select {
    border-radius: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid #cbd5e1;
    transition: all 0.3s;
  }
  .form-control:focus, .form-select:focus {
    border-color: #2193b0;
    box-shadow: 0 0 0 0.2rem rgba(33,147,176,0.25);
  }
  .avatar-preview {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #2193b0;
    margin-bottom: 1rem;
  }
</style>

<div class="container mt-4">
  <div class="form-card">
    <div class="form-header">
      <h3><i class="bi bi-person-lines-fill me-2"></i><%= mahasiswa ? 'Edit Mahasiswa' : 'Tambah Mahasiswa' %></h3>
    </div>
    <div class="form-body">
      <form method="POST" action="<%= mahasiswa ? '/admin/mahasiswa/' + mahasiswa.id + '/update' : '/admin/mahasiswa' %>" enctype="multipart/form-data">
        <!-- Preview Foto (jika edit dan ada foto) -->
        <% if (mahasiswa && mahasiswa.foto) { %>
          <div class="text-center mb-3">
            <img src="<%= mahasiswa.foto %>" alt="foto" class="avatar-preview">
          </div>
        <% } %>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="nim" class="form-label">NIM <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="nim" name="nim" value="<%= mahasiswa ? mahasiswa.nim : '' %>" required>
            <small class="text-muted">2 digit pertama = angkatan</small>
          </div>
          <div class="col-md-6 mb-3">
            <label for="nama" class="form-label">Nama Lengkap <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="nama" name="nama" value="<%= mahasiswa ? mahasiswa.nama : '' %>" required>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="email" class="form-label">Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" id="email" name="email" value="<%= mahasiswa ? mahasiswa.email : '' %>" required>
          </div>
          <div class="col-md-6 mb-3">
            <label for="noHp" class="form-label">Nomor HP</label>
            <input type="text" class="form-control" id="noHp" name="noHp" value="<%= mahasiswa ? mahasiswa.noHp : '' %>">
          </div>
        </div>

        <% if (!mahasiswa) { %>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="password" class="form-label">Password <span class="text-danger">*</span></label>
              <input type="password" class="form-control" id="password" name="password" required>
            </div>
            <div class="col-md-6 mb-3">
              <label for="confirmPassword" class="form-label">Konfirmasi Password <span class="text-danger">*</span></label>
              <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
            </div>
          </div>
        <% } %>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label for="status" class="form-label">Status</label>
            <select class="form-select" id="status" name="status">
              <option value="aktif" <%= mahasiswa && mahasiswa.status === 'aktif' ? 'selected' : '' %>>Aktif</option>
              <option value="lulus" <%= mahasiswa && mahasiswa.status === 'lulus' ? 'selected' : '' %>>Lulus</option>
              <option value="cuti" <%= mahasiswa && mahasiswa.status === 'cuti' ? 'selected' : '' %>>Cuti</option>
            </select>
          </div>
          <div class="col-md-6 mb-3">
            <label for="foto" class="form-label">Foto Profil</label>
            <input type="file" class="form-control" id="foto" name="foto" accept="image/*">
            <small class="text-muted">Kosongkan jika tidak ingin mengubah foto</small>
          </div>
        </div>

        <div class="d-flex justify-content-between mt-4">
          <a href="/admin/mahasiswa" class="btn-outline-gradient">
            <i class="bi bi-arrow-left me-2"></i>Kembali
          </a>
          <button type="submit" class="btn-gradient">
            <i class="bi bi-save me-2"></i>Simpan
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<% if (!mahasiswa) { %>
<script>
  // Validasi password sama
  document.querySelector('form').addEventListener('submit', function(e) {
    const password = document.getElementById('password').value;
    const confirm = document.getElementById('confirmPassword').value;
    if (password !== confirm) {
      e.preventDefault();
      alert('Password dan konfirmasi tidak sama!');
    }
  });
</script>
<% } %>

<%- include('../partials/footer') %>