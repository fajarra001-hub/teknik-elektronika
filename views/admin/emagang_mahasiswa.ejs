<%- include('../partials/header') %>

<style>
  .profile-card {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    border-radius: 1rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
  }
  .avatar-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid white;
  }
  .avatar-circle-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: white;
    color: #2193b0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 600;
  }
  .filter-card {
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
  }
  .logbook-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .table-responsive {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .thumbnail {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid #ddd;
  }
  .thumbnail:hover {
    opacity: 0.8;
  }
  .btn-aksi {
    margin: 2px;
    padding: 0.2rem 0.5rem;
    font-size: 0.8rem;
  }
</style>

<div class="container-fluid mt-4">
  <!-- Profil Mahasiswa -->
  <div class="profile-card">
    <div class="d-flex align-items-center">
      <div class="flex-shrink-0 me-4">
        <% if (mahasiswa.foto) { %>
          <img src="<%= mahasiswa.foto %>" alt="foto" class="avatar-large">
        <% } else { %>
          <div class="avatar-circle-large"><%= (mahasiswa.nama || '?').charAt(0).toUpperCase() %></div>
        <% } %>
      </div>
      <div>
        <h2 class="fw-bold"><%= mahasiswa.nama %></h2>
        <p class="mb-1"><i class="bi bi-qr-code me-2"></i>NIM: <%= mahasiswa.nim %></p>
        <p class="mb-1"><i class="bi bi-envelope me-2"></i><%= mahasiswa.email %></p>
        <p class="mb-0"><i class="bi bi-telephone me-2"></i><%= mahasiswa.noHp || '-' %></p>
      </div>
    </div>
  </div>
  
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold">Logbook Magang</h4>
    <div>
      <a href="/admin/emagang/print?userId=<%= mahasiswa.id %>&semester=<%= selectedSemester %>" class="btn btn-info me-2" target="_blank">
        <i class="bi bi-printer me-2"></i>Print
      </a>
      <a href="/admin/emagang" class="btn btn-outline-primary">
        <i class="bi bi-arrow-left me-2"></i>Kembali
      </a>
    </div>
  </div>
  
  <!-- Filter Semester -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label for="semester" class="form-label fw-semibold">Filter Semester</label>
        <select class="form-select" id="semester" name="semester">
          <option value="">Semua Semester</option>
          <% if (semesterList && semesterList.length > 0) { %>
            <% semesterList.forEach(s => { %>
              <option value="<%= s %>" <%= s === selectedSemester ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
      <div class="col-md-2">
        <a href="/admin/emagang/mahasiswa/<%= mahasiswa.id %>" class="btn btn-outline-secondary w-100">Reset</a>
      </div>
    </form>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold">Logbook Magang</h4>
    <a href="/admin/emagang" class="btn btn-outline-primary">
      <i class="bi bi-arrow-left me-2"></i>Kembali
    </a>
  </div>

  <!-- Tabel Logbook -->
  <div class="table-responsive">
    <table class="table logbook-table">
      <thead>
        <tr>
          <th>No</th>
          <th>Tanggal</th>
          <th>Kegiatan</th>
          <th>Durasi</th>
          <th>Lokasi</th>
          <th>Semester</th>
          <th>Gambar</th>
          <th>Status</th>
          <th>Aksi</th> <!-- Kolom baru -->
          <th>Waktu Input</th>
        </tr>
      </thead>
      <tbody>
        <% if (logbookList.length === 0) { %>
          <tr>
            <td colspan="10" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Tidak ada logbook untuk semester ini.</p>
            </td>
          </tr>
        <% } %>
        <% logbookList.forEach((item, index) => { %>
          <tr>
            <td class="text-center"><%= index + 1 %></td>
            <td><%= item.tanggalFormatted %></td>
            <td><%= item.kegiatan %></td>
            <td class="text-center"><%= item.durasi || '-' %></td>
            <td><%= item.lokasi || '-' %></td>
            <td><%= item.semester || '-' %></td>
            <td class="text-center">
              <% if (item.imageUrls && item.imageUrls.length > 0) { 
                // Ekstrak file ID dari URL pertama
                let fileId = '';
                let url = item.imageUrls[0];
                if (url.includes('id=')) {
                  fileId = url.split('id=')[1].split('&')[0];
                } else if (url.includes('/d/')) {
                  fileId = url.split('/d/')[1].split('/')[0];
                } else {
                  fileId = url.split('/').pop();
                }
              %>
                <img src="https://drive.google.com/thumbnail?id=<%= fileId %>&sz=w200" 
                     class="thumbnail" alt="dokumentasi"
                     onclick='lihatGambar(<%= JSON.stringify(item.imageUrls) %>)'
                     onerror="this.onerror=null; this.src='https://drive.google.com/uc?export=view&id=<%= fileId %>';">
              <% } else { %>
                -
              <% } %>
            </td>
            <td>
              <% if (item.status === 'approved') { %>
                <span class="badge bg-success">Disetujui</span>
              <% } else if (item.status === 'rejected') { %>
                <span class="badge bg-danger">Ditolak</span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% } %>
            </td>
            <td>
              <% if (item.status === 'pending') { %>
                <form method="POST" action="/admin/emagang/logbook/<%= item.id %>/approve" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-success btn-aksi" onclick="return confirm('Setujui logbook ini?')">
                    <i class="bi bi-check-lg"></i> Setujui
                  </button>
                </form>
                <form method="POST" action="/admin/emagang/logbook/<%= item.id %>/reject" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-danger btn-aksi" onclick="return confirm('Tolak logbook ini?')">
                    <i class="bi bi-x-lg"></i> Tolak
                  </button>
                </form>
              <% } else { %>
                <span class="text-muted">-</span>
              <% } %>
            </td>
            <td><small class="text-muted"><%= item.createdAt ? new Date(item.createdAt).toLocaleString('id-ID') : '-' %></small></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Lightbox Modal untuk melihat semua gambar -->
<div class="modal fade lightbox-modal" id="galleryModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Dokumentasi</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="galleryCarousel" class="carousel slide" data-bs-ride="false">
          <div class="carousel-inner" id="galleryCarouselInner"></div>
          <button class="carousel-control-prev" type="button" data-bs-target="#galleryCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#galleryCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function lihatGambar(imageUrls) {
    const inner = document.getElementById('galleryCarouselInner');
    inner.innerHTML = '';
    imageUrls.forEach((url, index) => {
      const activeClass = index === 0 ? 'active' : '';
      const item = `
        <div class="carousel-item ${activeClass}">
          <img src="${url}" class="d-block w-100" alt="Dokumentasi">
        </div>
      `;
      inner.innerHTML += item;
    });
    new bootstrap.Modal(document.getElementById('galleryModal')).show();
  }
</script>

<%- include('../partials/footer') %>