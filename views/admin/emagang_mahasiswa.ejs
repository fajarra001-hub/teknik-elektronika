<%- include('../partials/header') %>

<%
  // Fungsi untuk mengekstrak ID file dari URL Google Drive
  const getFileIdFromUrl = (url) => {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  };
%>

<style>
  /* ===== VARIABEL WARNA (sesuai navbar) ===== */
  :root {
    --primary-start: #1e3a8a;
    --primary-end: #3b82f6;
    --primary-light: rgba(30,58,138,0.1);
    --primary-dark: #0f2b5c;
    --warning-bg: #fef3c7;
    --warning-text: #92400e;
    --success-bg: #d1fae5;
    --success-text: #065f46;
    --danger-bg: #fee2e2;
    --danger-text: #991b1b;
    --font-base: 16px;
  }

  html {
    font-size: 16px;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    background-color: #f8fafc;
  }

  /* ===== PROFILE CARD ===== */
  .profile-card {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-radius: 1.5rem;
    padding: 2rem;
    color: white;
    margin-bottom: 2rem;
    box-shadow: 0 15px 30px rgba(30,58,138,0.3);
    position: relative;
    overflow: hidden;
  }
  .profile-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    transform: rotate(25deg);
  }
  .avatar-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255,255,255,0.5);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  .avatar-circle-large {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: white;
    color: var(--primary-start);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 600;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }

  /* ===== FILTER CARD ===== */
  .filter-card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    border: 1px solid rgba(30,58,138,0.1);
  }
  .filter-card .form-label {
    font-weight: 600;
    color: #1e293b;
    font-size: 0.9rem;
  }
  .filter-card .form-select,
  .filter-card .form-control {
    border-radius: 50px;
    border: 1px solid #dee2e6;
    padding: 0.6rem 1rem;
    transition: all 0.2s;
    font-size: 0.95rem;
  }
  .filter-card .form-select:focus,
  .filter-card .form-control:focus {
    border-color: var(--primary-start);
    box-shadow: 0 0 0 0.25rem rgba(30,58,138,0.25);
  }
  .btn-filter {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border: none;
    color: white;
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(30,58,138,0.2);
    width: 100%;
  }
  .btn-filter:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(30,58,138,0.4);
    color: white;
  }
  .btn-reset {
    background: transparent;
    border: 1.5px solid var(--primary-start);
    color: var(--primary-start);
    font-weight: 500;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    transition: all 0.3s;
    width: 100%;
    text-align: center;
    display: inline-block;
    text-decoration: none;
  }
  .btn-reset:hover {
    background: linear-gradient(135deg, var(--primary-start), var(--primary-end));
    border-color: transparent;
    color: white;
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(30,58,138,0.3);
  }

  /* ===== TOMBOL KEMBALI & PRINT ===== */
  .btn-back {
    background: white;
    color: var(--primary-start);
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    border: none;
  }
  .btn-back:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: var(--primary-dark);
  }
  .btn-print {
    background: #17a2b8;
    border: none;
    color: white;
    border-radius: 50px;
    padding: 0.5rem 1.5rem;
    font-weight: 500;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(23,162,184,0.2);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  .btn-print:hover {
    background: #138496;
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(23,162,184,0.3);
  }

  /* ===== TABEL MINIMALIS ===== */
  .table-container {
    background: white;
    border-radius: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
  }
  .table-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .logbook-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0;
  }
  .logbook-table thead th {
    background: #f8f9fa;
    color: #1e293b;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: 1px solid #dee2e6;
    padding: 0.75rem;
    white-space: nowrap;
    text-align: center;
  }
  .logbook-table tbody td {
    vertical-align: middle;
    padding: 0.75rem;
    border: 1px solid #dee2e6;
    font-size: 0.95rem;
  }
  .logbook-table tbody tr:hover {
    background-color: #f2f2f2;
  }

  /* ===== THUMBNAIL ===== */
  .thumbnail {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.2s;
  }
  .thumbnail:hover {
    border-color: var(--primary-start);
    transform: scale(1.05);
  }

  /* ===== BADGE STATUS ===== */
  .badge-status {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 1rem;
    border-radius: 50px;
    font-weight: 500;
    font-size: 0.8rem;
    border: 1px solid transparent;
  }
  .badge-pending {
    background: var(--warning-bg);
    color: var(--warning-text);
    border-color: #fde68a;
  }
  .badge-approved {
    background: var(--success-bg);
    color: var(--success-text);
    border-color: #a7f3d0;
  }
  .badge-rejected {
    background: var(--danger-bg);
    color: var(--danger-text);
    border-color: #fecaca;
  }

  /* ===== TOMBOL AKSI (APPROVE/REJECT) ===== */
  .btn-icon-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: all 0.2s;
    color: white;
    margin: 0 2px;
    background: transparent;
    border: none;
  }
  .btn-icon-sm i {
    font-size: 1rem;
  }
  .btn-approve {
    background: #10b981;
  }
  .btn-approve:hover {
    background: #059669;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(16,185,129,0.3);
  }
  .btn-reject {
    background: #ef4444;
  }
  .btn-reject:hover {
    background: #dc2626;
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(239,68,68,0.3);
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background: #f8f9fa;
    border-radius: 1.5rem;
  }
  .empty-state i {
    font-size: 4rem;
    color: #adb5bd;
    margin-bottom: 1rem;
  }
  .empty-state h4 {
    font-weight: 600;
    color: #495057;
    margin-bottom: 0.5rem;
    font-size: 1.3rem;
  }
  .empty-state p {
    color: #6c757d;
    font-size: 1rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    html { font-size: 15px; }
    .profile-card { padding: 1.5rem; }
    .avatar-large { width: 60px; height: 60px; }
    .avatar-circle-large { width: 60px; height: 60px; font-size: 2rem; }
    .logbook-table thead th { font-size: 0.8rem; padding: 0.5rem; }
    .logbook-table tbody td { font-size: 0.9rem; padding: 0.5rem; }
  }
  @media (max-width: 576px) {
    html { font-size: 14px; }
    .badge-status { font-size: 0.7rem; padding: 0.2rem 0.6rem; }
    .btn-print, .btn-back { padding: 0.4rem 1rem; font-size: 0.85rem; }
  }
</style>

<div class="container mt-4">
  <!-- Profil Mahasiswa -->
  <div class="profile-card">
    <div class="d-flex align-items-center flex-wrap">
      <div class="flex-shrink-0 me-4">
        <% if (mahasiswa.foto) { 
          const fileId = getFileIdFromUrl(mahasiswa.foto);
          if (fileId) { %>
            <img src="https://drive.google.com/thumbnail?id=<%= fileId %>&sz=w200" 
                 alt="foto" 
                 class="avatar-large"
                 onerror="this.onerror=null; this.src='<%= mahasiswa.foto %>';">
          <% } else { %>
            <img src="<%= mahasiswa.foto %>" 
                 alt="foto" 
                 class="avatar-large"
                 onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(mahasiswa.nama || '') %>&background=1e3a8a&color=fff&size=80';">
          <% } %>
        <% } else { %>
          <div class="avatar-circle-large"><%= (mahasiswa.nama || '?').charAt(0).toUpperCase() %></div>
        <% } %>
      </div>
      <div>
        <h2 class="fw-bold"><%= mahasiswa.nama %></h2>
        <p class="mb-1"><i class="bi bi-qr-code me-2"></i>NIM: <%= mahasiswa.nim || '-' %></p>
        <p class="mb-1"><i class="bi bi-envelope me-2"></i><%= mahasiswa.email %></p>
        <p class="mb-0"><i class="bi bi-telephone me-2"></i><%= mahasiswa.noHp || '-' %></p>
      </div>
    </div>
  </div>

  <!-- Header dengan judul dan tombol aksi -->
  <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
    <h4 class="fw-bold"><i class="bi bi-journal-bookmark-fill me-2" style="color: var(--primary-start);"></i>Logbook Magang</h4>
    <div class="d-flex gap-2">
      <a href="/admin/emagang/print?userId=<%= mahasiswa.id %>&semester=<%= selectedSemester %>" class="btn-print" target="_blank">
        <i class="bi bi-printer"></i> Print
      </a>
      <a href="/admin/emagang" class="btn-back">
        <i class="bi bi-arrow-left"></i> Kembali
      </a>
    </div>
  </div>

  <!-- Filter Semester -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label for="semester" class="form-label fw-semibold"><i class="bi bi-calendar3 me-1"></i>Filter Semester</label>
        <select class="form-select" id="semester" name="semester">
          <option value="">Semua Semester</option>
          <% if (semesterList && semesterList.length > 0) { %>
            <% semesterList.forEach(s => { %>
              <option value="<%= s %>" <%= s === selectedSemester ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn-filter"><i class="bi bi-funnel"></i> Terapkan</button>
      </div>
      <div class="col-md-2">
        <a href="/admin/emagang/mahasiswa/<%= mahasiswa.id %>" class="btn-reset"><i class="bi bi-arrow-counterclockwise"></i> Reset</a>
      </div>
    </form>
  </div>

  <!-- Info jumlah -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <p class="mb-0 fw-semibold"><i class="bi bi-files me-1" style="color: var(--primary-start);"></i> Menampilkan <strong><%= logbookList.length %></strong> entri logbook</p>
  </div>

  <!-- Tabel Logbook -->
  <div class="table-container">
    <div class="table-responsive">
      <table class="table logbook-table">
        <thead>
          <tr>
            <th>No</th>
            <th>Tanggal</th>
            <th>Kegiatan</th>
            <th>Durasi</th>
            <th>Lokasi</th>
            <th>Semester</th>
            <th>Gambar</th>
            <th>Status</th>
            <th>Aksi</th>
            <th>Waktu Input</th>
          </tr>
        </thead>
        <tbody>
          <% if (logbookList.length === 0) { %>
            <tr>
              <td colspan="10" class="text-center py-5">
                <div class="empty-state">
                  <i class="bi bi-inbox"></i>
                  <h4>Belum Ada Data</h4>
                  <p class="text-muted">Tidak ada logbook untuk ditampilkan.</p>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% logbookList.forEach((item, index) => { %>
              <tr>
                <td class="fw-bold text-center"><%= index + 1 %></td>
                <td><%= item.tanggalFormatted %></td>
                <td><%= item.kegiatan.length > 50 ? item.kegiatan.substring(0,50)+'...' : item.kegiatan %></td>
                <td class="text-center"><%= item.durasi ? item.durasi + ' jam' : '-' %></td>
                <td><%= item.lokasi || '-' %></td>
                <td class="text-center"><%= item.semester || '-' %></td>
                <td class="text-center">
                  <% if (item.imageUrls && item.imageUrls.length > 0) { 
                    const firstUrl = item.imageUrls[0];
                    const fileId = getFileIdFromUrl(firstUrl);
                  %>
                    <img src="https://drive.google.com/thumbnail?id=<%= fileId %>&sz=w100" 
                         class="thumbnail" 
                         alt="dokumentasi"
                         onclick='lihatGambar(<%= JSON.stringify(item.imageUrls) %>)'
                         onerror="this.onerror=null; this.src='<%= firstUrl %>';">
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>
                <td>
                  <% if (item.status === 'approved') { %>
                    <span class="badge-status badge-approved"><i class="bi bi-check-circle"></i> Disetujui</span>
                  <% } else if (item.status === 'rejected') { %>
                    <span class="badge-status badge-rejected"><i class="bi bi-x-circle"></i> Ditolak</span>
                  <% } else { %>
                    <span class="badge-status badge-pending"><i class="bi bi-hourglass-split"></i> Menunggu</span>
                  <% } %>
                </td>
                <td class="text-center">
                  <div class="d-flex gap-1 justify-content-center">
                    <% if (item.status === 'pending') { %>
                      <form method="POST" action="/admin/emagang/logbook/<%= item.id %>/approve" style="display:inline;">
                        <button class="btn-icon-sm btn-approve" title="Setujui" onclick="return confirm('Setujui logbook ini?')">
                          <i class="bi bi-check-lg"></i>
                        </button>
                      </form>
                      <form method="POST" action="/admin/emagang/logbook/<%= item.id %>/reject" style="display:inline;">
                        <button class="btn-icon-sm btn-reject" title="Tolak" onclick="return confirm('Tolak logbook ini?')">
                          <i class="bi bi-x-lg"></i>
                        </button>
                      </form>
                    <% } else { %>
                      <span class="text-muted">-</span>
                    <% } %>
                  </div>
                </td>
                <td><small class="text-muted"><%= item.createdAt ? new Date(item.createdAt).toLocaleDateString('id-ID', { day:'numeric', month:'short', year:'numeric' }) : '-' %></small></td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Lightbox Modal untuk melihat semua gambar -->
<div class="modal fade lightbox-modal" id="galleryModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-images"></i> Dokumentasi</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <div id="galleryCarousel" class="carousel slide" data-bs-ride="false">
          <div class="carousel-inner" id="galleryCarouselInner"></div>
          <button class="carousel-control-prev" type="button" data-bs-target="#galleryCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#galleryCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function lihatGambar(imageUrls) {
    const inner = document.getElementById('galleryCarouselInner');
    inner.innerHTML = '';
    if (!imageUrls || imageUrls.length === 0) {
      alert('Tidak ada gambar untuk ditampilkan.');
      return;
    }
    imageUrls.forEach((url, index) => {
      let imgUrl = url;
      const fileId = getFileIdFromUrl(url);
      if (fileId) {
        imgUrl = `https://drive.google.com/thumbnail?id=${fileId}&sz=w800`;
      }
      const activeClass = index === 0 ? 'active' : '';
      const item = `
        <div class="carousel-item ${activeClass}">
          <img src="${imgUrl}" 
               class="d-block w-100" 
               alt="Dokumentasi"
               onerror="this.onerror=null; this.src='${url}';">
        </div>
      `;
      inner.innerHTML += item;
    });
    new bootstrap.Modal(document.getElementById('galleryModal')).show();
  }

  function getFileIdFromUrl(url) {
    if (!url) return null;
    let match = url.match(/[?&]id=([^&]+)/);
    if (match) return match[1];
    match = url.match(/\/d\/([^\/]+)/);
    if (match) return match[1];
    return null;
  }
</script>

<%- include('../partials/footer') %>