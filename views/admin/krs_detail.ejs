<%- include('../partials/header') %>

<style>
  .detail-card {
    border: none;
    border-radius: 1rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    overflow: hidden;
  }
  .detail-header {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    padding: 2rem;
    color: white;
  }
  .detail-header h2 {
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .detail-body {
    padding: 2rem;
  }
  .info-table th {
    width: 200px;
    font-weight: 600;
    color: #1e293b;
  }
  .badge-status {
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .badge-pending { background: #ffc107; color: #212529; }
  .badge-approved { background: #28a745; color: white; }
  .badge-rejected { background: #dc3545; color: white; }
  .badge-stored { background: #17a2b8; color: white; }
  .mk-table th {
    background: #f8f9fa;
    font-weight: 600;
  }
  .btn-action {
    padding: 0.5rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    transition: all 0.3s;
  }
  .btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
</style>

<div class="container-fluid mt-4">
  <div class="detail-card">
    <div class="detail-header">
      <div class="d-flex justify-content-between align-items-center">
        <h2>Detail KRS</h2>
        <span class="badge-status 
          <%= krs.status === 'pending' ? 'badge-pending' : '' %>
          <%= krs.status === 'approved' ? 'badge-approved' : '' %>
          <%= krs.status === 'rejected' ? 'badge-rejected' : '' %>
          <%= krs.status === 'stored' ? 'badge-stored' : '' %>">
          <%= krs.status %>
        </span>
      </div>
      <p class="mb-0">Semester: <%= krs.semester || '-' %></p>
    </div>
    <div class="detail-body">
      <!-- Data Mahasiswa -->
      <h5 class="fw-bold mb-3">Data Mahasiswa</h5>
      <table class="table table-borderless info-table">
        <tr>
          <th>NIM</th>
          <td><%= mahasiswa.nim || '-' %></td>
        </tr>
        <tr>
          <th>Nama</th>
          <td><%= mahasiswa.nama || '-' %></td>
        </tr>
        <tr>
          <th>Program Studi</th>
          <td>Teknik Elektronika</td>
        </tr>
        <tr>
          <th>Angkatan</th>
          <td><%= mahasiswa.nim ? '20' + mahasiswa.nim.substring(0,2) : '-' %></td>
        </tr>
      </table>

      <hr>

      <!-- Daftar Mata Kuliah -->
      <h5 class="fw-bold mb-3">Mata Kuliah yang Direncanakan</h5>
      <div class="table-responsive">
        <table class="table table-bordered mk-table">
          <thead>
            <tr>
              <th>No</th>
              <th>Kode</th>
              <th>Nama Mata Kuliah</th>
              <th>SKS</th>
            </tr>
          </thead>
          <tbody>
            <% if (mkList && mkList.length > 0) { %>
              <% mkList.forEach((mk, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= mk.kode || '-' %></td>
                <td><%= mk.nama || '-' %></td>
                <td><%= mk.sks || '-' %></td>
              </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center text-muted">Tidak ada mata kuliah yang dipilih.</td>
              </tr>
            <% } %>
          </tbody>
          <tfoot>
            <tr>
              <th colspan="3" class="text-end">Total SKS</th>
              <th>
                <% 
                  let total = 0;
                  if (mkList) mkList.forEach(m => total += (m.sks || 0));
                %>
                <%= total %>
              </th>
            </tr>
          </tfoot>
        </table>
      </div>

      <hr>

      <!-- File KRS -->
      <h5 class="fw-bold mb-3">File KRS</h5>
      <% if (krs.driveFileLink) { %>
        <div class="alert alert-success d-flex align-items-center">
          <i class="bi bi-file-earmark-pdf-fill fs-3 me-3"></i>
          <div>
            <strong>File telah diupload</strong><br>
            <a href="<%= krs.driveFileLink %>" target="_blank" class="text-decoration-none">Lihat di Google Drive</a>
          </div>
        </div>
      <% } else { %>
        <div class="alert alert-warning">
          <i class="bi bi-exclamation-triangle me-2"></i>
          Mahasiswa belum mengupload file KRS.
        </div>
      <% } %>

      <!-- Tombol Aksi -->
      <div class="mt-4 d-flex gap-3">
        <% if (krs.status === 'pending') { %>
          <form method="POST" action="/admin/krs/<%= krs.id %>/approve" style="display:inline;">
            <button class="btn btn-success btn-action"><i class="bi bi-check-lg me-2"></i>Setujui KRS</button>
          </form>
          <form method="POST" action="/admin/krs/<%= krs.id %>/reject" style="display:inline;">
            <button class="btn btn-danger btn-action"><i class="bi bi-x-lg me-2"></i>Tolak KRS</button>
          </form>
        <% } %>
        
        <!-- Tombol Hapus (muncul untuk semua status) -->
        <form method="POST" action="/admin/krs/delete/<%= krs.id %>" style="display:inline;" onsubmit="return confirm('Yakin ingin menghapus KRS ini? Data akan dihapus permanen, termasuk file di Drive.')">
          <button class="btn btn-outline-danger btn-action"><i class="bi bi-trash me-2"></i>Hapus KRS</button>
        </form>
        
        <a href="/admin/krs" class="btn btn-outline-secondary btn-action"><i class="bi bi-arrow-left me-2"></i>Kembali</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>