<%- include('../partials/header') %>

<style>
  .matkul-table th {
    background: linear-gradient(135deg, #2193b0, #6dd5ed);
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.5px;
    border: none;
  }
  .matkul-table td {
    vertical-align: middle;
    padding: 1rem 0.75rem;
  }
  .btn-action {
    margin: 2px;
    border-radius: 8px;
    padding: 0.3rem 0.8rem;
    font-size: 0.85rem;
    transition: all 0.2s;
  }
  .btn-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
  }
  .filter-card {
    border-radius: 1rem;
    border: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    background: white;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }
  .table-responsive {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
  }
  .badge-dosen {
    background: #e9ecef;
    color: #495057;
    font-size: 0.8rem;
    padding: 0.3rem 0.6rem;
    border-radius: 20px;
    margin-right: 0.3rem;
    margin-bottom: 0.3rem;
    display: inline-block;
  }
</style>

<div class="container-fluid mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">Kelola Mata Kuliah</h2>
    <a href="/admin/matakuliah/create" class="btn btn-primary">
      <i class="bi bi-plus-circle me-2"></i>Tambah Mata Kuliah
    </a>
  </div>

  <!-- Filter Card -->
  <div class="filter-card">
    <form method="GET" class="row g-3 align-items-end">
      <div class="col-md-3">
        <label for="semester" class="form-label fw-semibold">Semester</label>
        <select class="form-select" id="semester" name="semester">
          <option value="">Semua Semester</option>
          <option value="1" <%= filterSemester === '1' ? 'selected' : '' %>>Semester 1</option>
          <option value="2" <%= filterSemester === '2' ? 'selected' : '' %>>Semester 2</option>
          <option value="3" <%= filterSemester === '3' ? 'selected' : '' %>>Semester 3</option>
          <option value="4" <%= filterSemester === '4' ? 'selected' : '' %>>Semester 4</option>
          <option value="5" <%= filterSemester === '5' ? 'selected' : '' %>>Semester 5</option>
          <option value="6" <%= filterSemester === '6' ? 'selected' : '' %>>Semester 6</option>
        </select>
      </div>
      <div class="col-md-3">
        <label for="search" class="form-label fw-semibold">Cari Kode/Nama</label>
        <input type="text" class="form-control" id="search" name="search" placeholder="Ketik kode atau nama" value="<%= search || '' %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
      </div>
      <div class="col-md-2">
        <a href="/admin/matakuliah" class="btn btn-outline-secondary w-100">Reset</a>
      </div>
    </form>
  </div>

  <!-- Notifikasi Sukses -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>Data mata kuliah berhasil <%= success %>.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Tabel Mata Kuliah -->
  <div class="table-responsive">
    <table class="table matkul-table">
      <thead>
        <tr>
          <th>Kode</th>
          <th>Nama MK</th>
          <th>SKS</th>
          <th>Semester</th>
          <th>Dosen Pengampu</th>
          <th>Jadwal</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (matakuliah.length === 0) { %>
          <tr>
            <td colspan="7" class="text-center py-5">
              <i class="bi bi-inbox fs-1 text-muted d-block mb-3"></i>
              <p class="text-muted">Belum ada data mata kuliah.</p>
            </td>
          </tr>
        <% } %>
        <% matakuliah.forEach(mk => { %>
        <tr>
          <td><span class="badge bg-primary bg-opacity-10 text-primary"><%= mk.kode %></span></td>
          <td><strong><%= mk.nama %></strong></td>
          <td class="text-center"><%= mk.sks %></td>
          <td class="text-center"><%= mk.semester || '-' %></td>
          <td>
            <% if (mk.dosenNames && mk.dosenNames.length > 0) { %>
              <div>
                <% mk.dosenNames.forEach(nama => { %>
                  <span class="badge-dosen"><%= nama %></span>
                <% }) %>
              </div>
            <% } else if (mk.dosenIds && mk.dosenIds.length > 0) { %>
              <span class="badge bg-secondary"><%= mk.dosenIds.length %> dosen</span>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </td>
          <td><small><%= mk.jadwal || '-' %></small></td>
          <td>
            <a href="/admin/matakuliah/<%= mk.id %>/edit" class="btn btn-sm btn-warning btn-action" title="Edit">
              <i class="bi bi-pencil"></i> Edit
            </a>
            <form method="POST" action="/admin/matakuliah/<%= mk.id %>/delete" style="display:inline;" onsubmit="return confirm('Yakin hapus mata kuliah ini?')">
              <button type="submit" class="btn btn-sm btn-danger btn-action" title="Hapus">
                <i class="bi bi-trash"></i> Hapus
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>